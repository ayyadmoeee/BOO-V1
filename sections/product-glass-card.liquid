    .pgc-{{ section_id }}__qtyRow {
      margin: 0 0 1rem 0;
    }

    .pgc-{{ section_id }}__cta {
      margin: 8px 0 12px;
      padding: 14px 16px;
    }

    .pgc-minimal__accordion {
