  @media (max-width: 900px){
    .pgc-{{ section_id }}{
      min-height: auto;
      overflow-x: hidden;
    }
    .pgc-{{ section_id }}__grid{ 
      grid-template-columns: 1fr; 
      min-height:auto;
      position:relative;
      width: 100%;
      max-width: 100%;
      overflow-x: hidden;
    }
    .pgc-{{ section_id }}__middle{ display:none !important; }
    .pgc-{{ section_id }}__word--left:not(.pgc-{{ section_id }}__word--mobile){ display:none !important; }
    .pgc-{{ section_id }}__word--right{ display:none !important; }
    .pgc-{{ section_id }}__left{ 
      justify-content:center; 
      padding: {{ section.settings.section_padding }}px 8px;
      position:relative;
