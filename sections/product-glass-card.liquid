      border-top: {{ section.settings.glass_border_width }}px solid rgba(255,255,255,{{ section.settings.glass_border_opacity | divided_by: 100.0 }});
      backdrop-filter: blur({{ section.settings.glass_blur | plus: section.settings.glass_blur_mobile_offset | at_least: 0 }}px) saturate(190%) contrast(120%);
      -webkit-backdrop-filter: blur({{ section.settings.glass_blur | plus: section.settings.glass_blur_mobile_offset | at_least: 0 }}px) saturate(190%) contrast(120%);
      {% if glass_bg_gradient == blank and section.settings.glass_card_bg_gradient == blank %}
      background: rgba(
        {{ glass_color | color_extract: 'red' }},
        {{ glass_color | color_extract: 'green' }},
        {{ glass_color | color_extract: 'blue' }},
        {{ section.settings.glass_opacity | times: section.settings.glass_opacity_mobile_factor | divided_by: 10000.0 | at_most: 1.0 | at_least: 0.0 }}
      );
      {% endif %}
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    .pgc-{{ section_id }}__card::before{
      display:none;
    }
    .pgc-{{ section_id }}__panel{
      width: 100%;
      max-width: 100%;
      padding: 0;
      box-sizing: border-box;
    }
    .pgc-{{ section_id }}__cardInner{
      padding: 16px 10px;
      max-width: 100%;
