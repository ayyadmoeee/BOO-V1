      top:auto !important;
      bottom:-2.1rem !important;
      left:50% !important;
      transform:translateX(-50%) !important;
      width:100%;
      text-align:center;
      margin:0 !important;
      padding:0 !important;
      z-index: 10;
      writing-mode:horizontal-tb !important;
      font-size: 62px;
      opacity: {{ section.settings.middle_text_opacity | divided_by: 100.0 }};
