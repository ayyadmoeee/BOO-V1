    /* Accordions come last */
    .pgc-minimal__accordion {
      order: 3;
  }

    .pgc-{{ section_id }} .payment-methods-inline .payment-icon{
      opacity: 1;
    }
  }
{% endstyle %}

{% if product_obj %}
<section class="pgc-{{ section_id }}">
  <div class="pgc-{{ section_id }}__bg" aria-hidden="true">
    {% if bg_url != blank %}
      <img src="{{ bg_url }}" alt="" loading="lazy">
    {% else %}
      <div class="pgc-{{ section_id }}__bgPlaceholder"></div>
    {% endif %}
  </div>

  <div class="pgc-{{ section_id }}__container">
    <div class="pgc-{{ section_id }}__grid">

      <div class="pgc-{{ section_id }}__left">
        <div class="pgc-{{ section_id }}__leftInner">

          <div class="pgc-{{ section_id }}__carousel" data-carousel>
            <div class="pgc-{{ section_id }}__track" data-track>
              {% assign media_list = product_obj.media %}
              {% if media_list and media_list.size > 0 %}
                {% for m in media_list %}
                  <div class="pgc-{{ section_id }}__slide" data-slide>
                    {% case m.media_type %}
                      {% when 'image' %}
                        <img src="{{ m | image_url: width: 2000 }}" alt="{{ m.alt | escape }}" loading="lazy">
                      {% when 'video' %}
                        {{ m | video_tag: controls: true, playsinline: true, preload: 'none' }}
                      {% when 'external_video' %}
                        {{ m | external_video_tag: loading: 'lazy' }}
                      {% when 'model' %}
                        {{ m | model_viewer_tag }}
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                    {% endcase %}
                  </div>
                {% endfor %}
              {% else %}
                <div class="pgc-{{ section_id }}__slide" data-slide>
                  {% if product_obj.featured_image %}
                    <img
                      src="{{ product_obj.featured_image | image_url: width: 2000 }}"
                      alt="{{ product_obj.title | escape }}"
                      loading="lazy"
                      width="{{ product_obj.featured_image.width }}"
                      height="{{ product_obj.featured_image.height }}"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {% endif %}
                </div>
              {% endif %}
            </div>

            <button type="button" class="pgc-{{ section_id }}__navBtn pgc-{{ section_id }}__navPrev" aria-label="Previous" data-prev>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button type="button" class="pgc-{{ section_id }}__navBtn pgc-{{ section_id }}__navNext" aria-label="Next" data-next>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>

          <div class="pgc-{{ section_id }}__word pgc-{{ section_id }}__word--left pgc-{{ section_id }}__word--mobile">
            {{ mid_text }}
          </div>

          <div class="pgc-{{ section_id }}__dots" data-dots></div>
          <div class="pgc-{{ section_id }}__thumbs" data-thumbs></div>

        </div>
      </div>

      <div class="pgc-{{ section_id }}__middle" aria-hidden="true">
        <div class="pgc-{{ section_id }}__word pgc-{{ section_id }}__word--left">
          {{ mid_text }}
        </div>
      </div>

      <div class="pgc-{{ section_id }}__panel">
        <div class="pgc-{{ section_id }}__card">
          <div class="pgc-{{ section_id }}__word pgc-{{ section_id }}__word--right" aria-hidden="true">
            {{ mid_text }}
          </div>

          <div class="pgc-{{ section_id }}__cardInner pgc-minimal-pdp">
            {%- liquid
              assign title_source_product = context_product | default: product_obj
              assign composed_title = title_source_product.title | escape
              
              # Optionally append color to title
              if section.settings.append_color_option
                assign color_value = ''
                for opt in title_source_product.options_with_values
                  assign opt_name_down = opt.name | downcase
                  if opt_name_down == 'color' or opt_name_down == 'colour'
                    assign color_value = opt.selected_value
                  endif
                endfor
                if color_value != blank
                  assign composed_title = composed_title | append: ' - ' | append: color_value | escape
                endif
              endif

              # Get selected size
              assign selected_size = ''
              for opt in product_obj.options_with_values
                assign opt_name_down = opt.name | downcase
                if opt_name_down contains 'size'
                  assign selected_size = opt.selected_value
                endif
              endfor
              if selected_size == blank
                assign selected_size = product_obj.selected_or_first_available_variant.title
              endif
              if selected_size == 'Default Title'
                assign selected_size = ''
              endif

              assign selected_variant = product_obj.selected_or_first_available_variant
              assign selected_on_sale = false
              if selected_variant and selected_variant.compare_at_price and selected_variant.compare_at_price > selected_variant.price
                assign selected_on_sale = true
              endif
            -%}

            <div class="pgc-minimal__header">
              <h1 class="pgc-minimal__title">{{ composed_title }}</h1>

              <div class="pgc-minimal__fitrow">
                <div class="pgc-minimal__left">
                  <div class="pgc-minimal__kicker">{{ section.settings.fit_label | default: 'FIT' }}</div>
                  {%- if section.settings.show_selected_size and selected_size != blank -%}
                    <div class="pgc-minimal__size" data-pgc-size>{{ selected_size }}</div>
                  {%- endif -%}

                  <div class="pgc-minimal__price" id="pgc-price-{{ section_id }}">
                    {%- render 'price',
                      product: product_obj,
                      use_variant: true,
                      show_badges: false,
                      price_class: 'price--large'
                    -%}
                    <span class="pgc-minimal__sale-badge" data-pgc-sale-badge{% unless selected_on_sale %} style="display:none;"{% endunless %}>
                      {{ 'products.product.on_sale' | t }}
                    </span>
                  </div>
            </div>

              </div>
            </div>

            {%- assign product_form_id = 'product-form-pgc-' | append: section_id -%}
            {% form 'product', product_obj, id: product_form_id %}
              {% unless product_obj.has_only_default_variant %}
                {% for option in product_obj.options_with_values %}
                  {%- assign opt_name_down = option.name | downcase -%}
                  {%- assign is_color = false -%}
                  {%- if opt_name_down == 'color' or opt_name_down == 'colour' -%}
                    {%- assign is_color = true -%}
                  {%- endif -%}
                  
                  <div class="pgc-variant-option {% if is_color %}pgc-variant-option--color{% endif %} {% if opt_name_down contains 'size' and section.settings.size_guide_image != blank %}pgc-variant-option--has-size-guide{% endif %}">
                    {%- if opt_name_down contains 'size' and section.settings.size_guide_image != blank -%}
                      <div class="pgc-minimal__variant-label-row">
                        <label class="pgc-minimal__variant-label" for="Option-{{ section_id }}-{{ forloop.index0 }}">
                          {{ option.name }}
                        </label>
                        <button type="button" class="pgc-minimal__size-guide-link" data-pgc-size-guide-open aria-label="Open size guide">
                          Size guide
                        </button>
                      </div>
                    {%- else -%}
                      <label class="pgc-minimal__variant-label" for="Option-{{ section_id }}-{{ forloop.index0 }}">
                        {{ option.name }}
                      </label>
                    {%- endif -%}
                    
                    {%- if opt_name_down contains 'size' -%}
                      {%- assign size_option_position = forloop.index0 -%}
                      <div class="pgc-minimal__size-buttons">
                    {% for value in option.values %}
                          {%- assign size_value_available = false -%}
                          {%- for variant in product_obj.variants -%}
                            {%- if variant.options[size_option_position] == value and variant.available -%}
                              {%- assign size_value_available = true -%}
                              {%- break -%}
                            {%- endif -%}
                          {%- endfor -%}
                          <button 
                            type="button"
                            class="pgc-minimal__size-btn {% if option.selected_value == value %}pgc-minimal__size-btn--selected{% endif %}{% unless size_value_available %} pgc-minimal__size-btn--soldout{% endunless %}"
                            data-value="{{ value | escape }}"
                            data-option-name="{{ option.name | escape }}"
                            data-option-position="{{ forloop.index0 }}"
                            {% unless size_value_available %}data-unavailable="true" aria-label="{{ value | escape }} sold out"{% endunless %}
                          >
                            {{ value }}
                          </button>
                        {% endfor %}
                        <select 
                          class="pgc-minimal__variant-select pgc-minimal__variant-select--hidden" 
                          id="Option-{{ section_id }}-{{ forloop.index0 }}"
                          name="options[{{ option.name | escape }}]"
                          data-option-position="{{ forloop.index0 }}"
                        >
                          {% for value in option.values %}
                            <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                              {{ value }}
                            </option>
                    {% endfor %}
                  </select>
                      </div>
                    {%- else -%}
                      <select 
                        class="pgc-minimal__variant-select {% if is_color %}pgc-minimal__variant-select--color{% endif %}" 
                        id="Option-{{ section_id }}-{{ forloop.index0 }}"
                        name="options[{{ option.name | escape }}]"
                        data-option-position="{{ forloop.index0 }}"
                      >
                        {% for value in option.values %}
                          <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                            {{ value }}
                          </option>
                {% endfor %}
                      </select>
                    {%- endif -%}
                  </div>
                {% endfor %}
              {% endunless %}

              <label class="pgc-minimal__quantity-label" for="Quantity-pgc-{{ section_id }}">Quantity</label>
              <div class="pgc-{{ section_id }}__qtyRow">
                <button type="button" class="pgc-{{ section_id }}__qtyBtn" data-qty="dec" aria-label="Decrease">−</button>
                <input 
                  class="pgc-{{ section_id }}__qtyInput" 
                  type="number" 
                  id="Quantity-pgc-{{ section_id }}"
                  name="quantity" 
                  value="1" 
                  min="1"
                >
                <button type="button" class="pgc-{{ section_id }}__qtyBtn" data-qty="inc" aria-label="Increase">+</button>
              </div>

              <input type="hidden" name="id" value="{{ product_obj.selected_or_first_available_variant.id }}" data-variant-id>

              <button class="pgc-{{ section_id }}__cta" type="submit" style="width: 100%; margin-top: 2rem; text-transform: uppercase;">
                {{ section.settings.button_text }}
              </button>

              {%- assign payment_method_blocks = section.blocks | where: 'type', 'payment_method' -%}
              <div class="payment-methods-inline" aria-label="Supported payment methods">
                {%- if payment_method_blocks.size > 0 -%}
                  {%- for block in payment_method_blocks -%}
                    {%- assign payment_label = block.settings.label | default: 'Payment method' -%}
                    <span class="payment-icon" aria-label="{{ payment_label | escape }}" role="img" {{ block.shopify_attributes }}>
                      {%- if block.settings.icon != blank -%}
                        {{ block.settings.icon | image_url: width: 72 | image_tag: loading: 'lazy', alt: payment_label }}
                      {%- else -%}
                        <span class="payment-icon__label">{{ payment_label | escape }}</span>
                      {%- endif -%}
                    </span>
                  {%- endfor -%}
                {%- else -%}
                  <span class="payment-icon" aria-label="Cash on Delivery" role="img">
                    {%- if section.settings.payment_icon_cod != blank -%}
                      {{ section.settings.payment_icon_cod | image_url: width: 72 | image_tag: loading: 'lazy', alt: 'Cash on Delivery' }}
                    {%- else -%}
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <rect x="3.5" y="6.5" width="17" height="11" rx="2"></rect>
                        <circle cx="12" cy="12" r="2.2"></circle>
                        <path d="M6.5 9.2h2.4M15.1 14.8h2.4"></path>
                      </svg>
                    {%- endif -%}
                  </span>
                  <span class="payment-icon" aria-label="Whish Pay" role="img">
                    {%- if section.settings.payment_icon_whish != blank -%}
                      {{ section.settings.payment_icon_whish | image_url: width: 72 | image_tag: loading: 'lazy', alt: 'Whish Pay' }}
                    {%- else -%}
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <rect x="4" y="5" width="16" height="14" rx="2"></rect>
                        <path d="M4 9h16"></path>
                        <path d="M8 14h4M14 14h2"></path>
                      </svg>
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </div>
            {% endform %}

            {%- assign accordion_blocks = section.blocks | where: 'type', 'accordion' -%}
            {%- if accordion_blocks.size > 0 -%}
              <div class="pgc-minimal__accordion accordion" style="margin-top: 2rem;">
                {%- for block in accordion_blocks -%}
                  {%- liquid
                    assign accordion_content = blank
                    assign show_accordion = false

                    case block.settings.content_type
                      when 'product_description'
                        if product_obj.description != blank
                          assign accordion_content = product_obj.description
                          assign show_accordion = true
                        endif
                      when 'shipping_policy'
                        if shop.shipping_policy.body != blank
                          assign accordion_content = shop.shipping_policy.body
                          assign show_accordion = true
                        endif
                      when 'refund_policy'
                        if shop.refund_policy.body != blank
                          assign accordion_content = shop.refund_policy.body
                          assign show_accordion = true
                        endif
                      when 'shipping_and_refund'
                        if shop.shipping_policy.body != blank or shop.refund_policy.body != blank
                          assign show_accordion = true
                        endif
                      when 'custom'
                        if block.settings.custom_content != blank
                          assign accordion_content = block.settings.custom_content
                          assign show_accordion = true
                        endif
                    endcase
                  -%}
                  {%- if show_accordion -%}
                    <details id="Details-{{ block.id }}-pgc-{{ section_id }}" {{ block.shopify_attributes }}>
                      <summary>
                        <div class="summary__title">
                          <h2 class="h4 accordion__title">
                            {{ block.settings.heading | default: 'Dropdown' | escape }}
                          </h2>
                        </div>
                        <span class="pgc-accordion-icon"></span>
                      </summary>
                      <div class="accordion__content rte" id="Accordion-{{ block.id }}-pgc-{{ section_id }}">
                        {%- if block.settings.content_type == 'custom' -%}
                          {{ accordion_content | newline_to_br }}
                        {%- elsif block.settings.content_type == 'shipping_and_refund' -%}
                          {%- if shop.shipping_policy.body != blank -%}
                            <div class="pgc-minimal__policy">{{ shop.shipping_policy.body }}</div>
                          {%- endif -%}
                          {%- if shop.refund_policy.body != blank -%}
                            <div class="pgc-minimal__policy">{{ shop.refund_policy.body }}</div>
                          {%- endif -%}
                        {%- else -%}
                          {{ accordion_content }}
                        {%- endif -%}
                      </div>
                    </details>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- else -%}
              {%- comment -%} Fallback when no blocks: original Description + Shipping accordions {%- endcomment -%}
              {% if product_obj.description != blank %}
                <div class="pgc-minimal__accordion accordion" style="margin-top: 2rem;">
                  <details id="Details-description-pgc-{{ section_id }}">
                    <summary>
                      <div class="summary__title">
                        <h2 class="h4 accordion__title">
                          {{ section.settings.description_heading | default: 'DESCRIPTION' | escape }}
                        </h2>
                      </div>
                      <span class="pgc-accordion-icon"></span>
                    </summary>
                    <div class="accordion__content rte" id="Accordion-description-pgc-{{ section_id }}">
                      {{ product_obj.description }}
                    </div>
                  </details>
                </div>
              {% endif %}
              <div class="pgc-minimal__accordion accordion">
                <details id="Details-shipping-pgc-{{ section_id }}">
                  <summary>
                    <div class="summary__title">
                      <h2 class="h4 accordion__title">
                        {{ section.settings.shipping_heading | default: 'SHIPPING AND RETURNS' | escape }}
                      </h2>
                    </div>
                    <span class="pgc-accordion-icon"></span>
                  </summary>
                  <div class="accordion__content rte" id="Accordion-shipping-pgc-{{ section_id }}">
                    {%- if shop.shipping_policy.body != blank -%}
                      <div class="pgc-minimal__policy">{{ shop.shipping_policy.body }}</div>
                    {%- endif -%}
                    {%- if shop.refund_policy.body != blank -%}
                      <div class="pgc-minimal__policy">{{ shop.refund_policy.body }}</div>
                    {%- endif -%}
                  </div>
                </details>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

    </div>
  </div>

  {%- if section.settings.size_guide_image != blank -%}
    <div class="pgc-size-guide-modal" id="pgc-size-guide-modal-{{ section_id }}" hidden aria-modal="true" role="dialog" aria-label="Size guide">
      <div class="pgc-size-guide-overlay" data-pgc-size-guide-close></div>
      <div class="pgc-size-guide-popup">
        <button type="button" class="pgc-size-guide-close" data-pgc-size-guide-close aria-label="Close size guide">&times;</button>
        {%- if section.settings.size_guide_heading != blank -%}
          <h2 class="pgc-size-guide-popup__heading">{{ section.settings.size_guide_heading | escape }}</h2>
        {%- endif -%}
        <div class="pgc-size-guide-popup__image-wrap">
          <img src="{{ section.settings.size_guide_image | image_url: width: 1290 }}" alt="Size guide" loading="lazy" width="644" height="483">
        </div>
      </div>
    </div>
  {%- endif -%}
</section>
{% endif %}

<script>
  (function(){
    const root = document.querySelector('.pgc-{{ section_id }}');
    if(!root) return;

    // Size guide popup
    const sizeGuideModal = root.querySelector('#pgc-size-guide-modal-{{ section_id }}');
    if (sizeGuideModal) {
      const popupPanel = sizeGuideModal.querySelector('.pgc-size-guide-popup');
      function closeSizeGuide() {
        sizeGuideModal.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }
      root.querySelectorAll('[data-pgc-size-guide-open]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          sizeGuideModal.removeAttribute('hidden');
          document.body.style.overflow = 'hidden';
        });
      });
      root.querySelectorAll('[data-pgc-size-guide-close]').forEach(function(btn) {
        btn.addEventListener('click', closeSizeGuide);
      });
      sizeGuideModal.addEventListener('click', function(e) {
        if (e.target === sizeGuideModal || e.target.classList.contains('pgc-size-guide-overlay')) {
          closeSizeGuide();
        }
      });
      sizeGuideModal.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeSizeGuide();
      });
    }

    // Accordion: only one dropdown open at a time
    root.querySelectorAll('.pgc-minimal__accordion').forEach(function(accordion) {
      const details = accordion.querySelectorAll('details');
      details.forEach(function(d) {
        d.addEventListener('toggle', function() {
          if (this.hasAttribute('open')) {
            details.forEach(function(other) {
              if (other !== d) other.removeAttribute('open');
            });
          }
        });
      });
    });

    const track = root.querySelector('[data-track]');
    const carousel = root.querySelector('[data-carousel]');
    const realSlides = track ? Array.from(track.querySelectorAll('[data-slide]')) : [];
    const prev = root.querySelector('[data-prev]');
    const next = root.querySelector('[data-next]');
    const dots = root.querySelector('[data-dots]');
    const thumbs = root.querySelector('[data-thumbs]');
    const totalSlides = realSlides.length;

    let slides = realSlides.slice();
    let i = 0;
    let visualIndex = 0;
    let isTransitioning = false;
    const transitionMs = 400;

    function pauseAllMedia() {
      slides.forEach(s => {
        const v = s.querySelector('video');
        if (v && !v.paused) v.pause();
        const f = s.querySelector('iframe');
        if (f && f.src) { const src = f.src; f.src = src; }
      });
    }

    // Lazy-load: activate media only for the real slide at logical index n
    function activateSlideMedia(n) {
      realSlides.forEach((s, idx) => {
        const v = s.querySelector('video');
        if (v) {
          if (idx === n) {
            if (v.preload === 'none') v.preload = 'metadata';
          } else {
            if (!v.paused) v.pause();
          }
        }
        const f = s.querySelector('iframe');
        if (f && idx === n && f.dataset.src) {
          f.src = f.dataset.src;
          delete f.dataset.src;
        }
      });
    }

    function applyTransform(index, animate) {
      if (!track) return;
      track.style.transition = animate ? `transform ${transitionMs}ms ease` : 'none';
      track.style.transform = `translateX(${-index * 100}%)`;
      if (!animate) {
        // Force reflow so the next animated move does not interpolate from the pre-snap position.
        track.offsetHeight;
        track.style.transition = '';
      }
    }

    function initInfiniteLoop() {
      if (!track || totalSlides <= 1) return;

      const firstClone = realSlides[0].cloneNode(true);
      const lastClone = realSlides[totalSlides - 1].cloneNode(true);
      firstClone.setAttribute('data-slide-clone', 'first');
      lastClone.setAttribute('data-slide-clone', 'last');

      track.insertBefore(lastClone, realSlides[0]);
      track.appendChild(firstClone);
      slides = Array.from(track.querySelectorAll('[data-slide]'));

      visualIndex = 1;
      applyTransform(visualIndex, false);

      track.addEventListener('transitionend', function (event) {
        if (event.target !== track || event.propertyName !== 'transform') return;
        if (visualIndex === 0) {
          visualIndex = totalSlides;
          applyTransform(visualIndex, false);
        } else if (visualIndex === totalSlides + 1) {
          visualIndex = 1;
          applyTransform(visualIndex, false);
        }
        isTransitioning = false;
      });
    }

    function setSlide(n){
      if(!track || totalSlides <= 1 || isTransitioning || n === i) return;

      if (n > i) {
        i = (i + 1) % totalSlides;
        visualIndex += 1;
      } else {
        i = (i - 1 + totalSlides) % totalSlides;
        visualIndex -= 1;
      }

      isTransitioning = true;
      applyTransform(visualIndex, true);
      pauseAllMedia();
      activateSlideMedia(i);
    }

    function buildDots(){
      if(!track || totalSlides <= 1){
        if(prev) prev.style.display = 'none';
        if(next) next.style.display = 'none';
        if(dots) dots.style.display = 'none';
        return;
      }
      if(prev) prev.addEventListener('click', ()=> setSlide(i - 1));
      if(next) next.addEventListener('click', ()=> setSlide(i + 1));
    }

    function initSwipe(){
      if(!carousel || totalSlides <= 1) return;

      let startX = 0;
      let startY = 0;
      let isPointerDown = false;
      let isHorizontal = false;

      const swipeThreshold = 36;

      function onStart(e){
        const p = e.touches ? e.touches[0] : e;
        startX = p.clientX;
        startY = p.clientY;
        isPointerDown = true;
        isHorizontal = false;
      }

      function onMove(e){
        if(!isPointerDown) return;
        const p = e.touches ? e.touches[0] : e;
        const dx = p.clientX - startX;
        const dy = p.clientY - startY;
        if(!isHorizontal && Math.abs(dx) > 8 && Math.abs(dx) > Math.abs(dy)) {
          isHorizontal = true;
        }
        if(isHorizontal && e.cancelable) e.preventDefault();
      }

      function onEnd(e){
        if(!isPointerDown) return;
        isPointerDown = false;
        const p = (e.changedTouches && e.changedTouches[0]) ? e.changedTouches[0] : e;
        const dx = p.clientX - startX;
        const dy = p.clientY - startY;
        if(Math.abs(dx) < swipeThreshold || Math.abs(dx) <= Math.abs(dy)) return;
        if(dx < 0) setSlide(i + 1);
        else setSlide(i - 1);
      }

      carousel.addEventListener('touchstart', onStart, { passive: true });
      carousel.addEventListener('touchmove', onMove, { passive: false });
      carousel.addEventListener('touchend', onEnd, { passive: true });
      carousel.addEventListener('pointerdown', onStart);
      carousel.addEventListener('pointermove', onMove);
      carousel.addEventListener('pointerup', onEnd);
      carousel.addEventListener('pointercancel', onEnd);
    }

    function buildThumbs(){
      if(thumbs) thumbs.style.display = 'none';
    }

    root.querySelectorAll('[data-qty]').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const input = btn.closest('form')?.querySelector('input[name="quantity"]') || root.querySelector('input[name="quantity"]');
        const v = parseInt(input.value, 10) || 1;
        input.value = btn.dataset.qty === 'inc' ? v + 1 : Math.max(1, v - 1);
      });
    });

    initInfiniteLoop();
    buildDots();
    buildThumbs();
    initSwipe();
    activateSlideMedia(0); // lazy-load first slide's media on init

    // Minimalist PDP: Update size and price on variant change
    const form = root.querySelector('#product-form-pgc-{{ section_id }}');
    const sizeEl = root.querySelector('[data-pgc-size]');
    const priceEl = root.querySelector('#pgc-price-{{ section_id }}');
    const saleBadgeEl = root.querySelector('[data-pgc-sale-badge]');
    const variantIdInput = root.querySelector('[data-variant-id]');
    const ctaButton = form ? form.querySelector('.pgc-{{ section_id }}__cta') : null;
    const defaultCtaText = {{ section.settings.button_text | json }};
    const productData = {% if product_obj %}{{ product_obj | json }}{% else %}null{% endif %};

    if (form && productData) {
      // Listen for variant changes from variant-selects component
      const variantSelects = root.querySelector('variant-selects');
      
      function updateAddToCartState(variant) {
        if (!ctaButton) return;
        const isSoldOut = !variant || !variant.available;
        ctaButton.textContent = isSoldOut ? 'SOLD OUT' : defaultCtaText;
        ctaButton.disabled = isSoldOut;
        ctaButton.setAttribute('aria-disabled', isSoldOut ? 'true' : 'false');
      }

      function updateSizeAndPrice(variant) {
        updateAddToCartState(variant);
        if (!variant) return;
        
        if (variantIdInput) variantIdInput.value = variant.id;
        
        // Update size
        if (sizeEl && variant.options && productData && productData.options) {
          const sizeOptionIndex = productData.options.findIndex(opt => 
            opt && opt.name && opt.name.toLowerCase().includes('size')
          );
          if (sizeOptionIndex !== -1 && variant.options[sizeOptionIndex]) {
            sizeEl.textContent = variant.options[sizeOptionIndex];
          } else if (variant.title && variant.title !== 'Default Title') {
            sizeEl.textContent = variant.title;
          }
        }

        // Update price
        if (priceEl && variant.price) {
          const priceText = new Intl.NumberFormat('{{ localization.language.iso_code }}', {
            style: 'currency',
            currency: '{{ cart.currency.iso_code }}'
          }).format(variant.price / 100);

          const isOnSale = !!(variant.compare_at_price && variant.compare_at_price > variant.price);
          const compareText = isOnSale
            ? new Intl.NumberFormat('{{ localization.language.iso_code }}', {
                style: 'currency',
                currency: '{{ cart.currency.iso_code }}'
              }).format(variant.compare_at_price / 100)
            : '';

          const priceWrapper = priceEl.querySelector('.price');

          if (priceWrapper) {
            const regularPriceEl = priceWrapper.querySelector('.price__regular .price-item--regular');
            const comparePriceEl = priceWrapper.querySelector('.price__sale .price-item--regular');
            const salePriceEl = priceWrapper.querySelector('.price__sale .price-item--sale, .price__sale .price-item--last');

            if (regularPriceEl) regularPriceEl.textContent = priceText;
            if (salePriceEl) salePriceEl.textContent = priceText;
            if (comparePriceEl) comparePriceEl.textContent = compareText || priceText;

            priceWrapper.classList.toggle('price--on-sale', isOnSale);
          }

          if (saleBadgeEl) {
            saleBadgeEl.style.display = isOnSale ? 'inline-flex' : 'none';
          }
        }
      }

      // Listen to variant-selects component events
      if (variantSelects) {
        variantSelects.addEventListener('change', (e) => {
          const variantId = e.detail?.variant?.id || variantIdInput?.value;
          if (variantId && productData.variants) {
            const variant = productData.variants.find(v => v.id.toString() === variantId.toString());
            updateSizeAndPrice(variant);
          }
        });
      }

      // Listen to direct option changes (dropdown selects)
      const optionSelects = form.querySelectorAll('select[name^="options"]');
      
      function updateVariant() {
        const selectedOptions = Array.from(optionSelects).map(select => select.value);

        const variant = productData.variants.find(v => {
          return v.options.every((opt, idx) => opt === selectedOptions[idx]);
        });

        updateSizeAndPrice(variant);
      }

      optionSelects.forEach(select => {
        select.addEventListener('change', updateVariant);
      });
      

      // Size button functionality - clean implementation
      function initSizeButtons() {
        // Find the size display element
        const sizeDisplayEl = root.querySelector('[data-pgc-size]');
        
        // Function to update size display
        function updateSizeDisplay(value) {
          if (sizeDisplayEl && value) {
            sizeDisplayEl.textContent = value;
          }
        }
        
        // Find all size button containers
        const sizeButtonContainers = root.querySelectorAll('.pgc-minimal__size-buttons');
        
        sizeButtonContainers.forEach(container => {
          // Find the hidden select for this container
          const select = container.querySelector('.pgc-minimal__variant-select');
          if (!select) return;
          
          const optionPosition = select.dataset.optionPosition;
          if (optionPosition === undefined) return;
          
          // Get all buttons in this container
          const buttons = container.querySelectorAll('.pgc-minimal__size-btn');
          
          // Attach click handler to each button
          buttons.forEach(button => {
            button.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopPropagation();
              
              const selectedValue = button.dataset.value;
              if (!selectedValue) return;
              
              // Remove selected class from all buttons in this container
              buttons.forEach(btn => {
                btn.classList.remove('pgc-minimal__size-btn--selected');
              });
              
              // Add selected class to clicked button
              button.classList.add('pgc-minimal__size-btn--selected');
              
              // Update size display
              updateSizeDisplay(selectedValue);
              
              // Update hidden select value
              select.value = selectedValue;
              
              // Dispatch change event to trigger Shopify variant logic
              const changeEvent = new Event('change', { 
                bubbles: true, 
                cancelable: true 
              });
              select.dispatchEvent(changeEvent);
            });
          });
          
          // Sync initial button state with select value
          const currentValue = select.value;
          buttons.forEach(button => {
            if (button.dataset.value === currentValue) {
              button.classList.add('pgc-minimal__size-btn--selected');
            } else {
              button.classList.remove('pgc-minimal__size-btn--selected');
            }
          });
          
          // Update initial size display
          if (currentValue) {
            updateSizeDisplay(currentValue);
          }
          
          // Listen for select changes (from other sources) and update buttons
          select.addEventListener('change', function() {
            const newValue = select.value;
            buttons.forEach(button => {
              if (button.dataset.value === newValue) {
                button.classList.add('pgc-minimal__size-btn--selected');
              } else {
                button.classList.remove('pgc-minimal__size-btn--selected');
              }
            });
            // Update size display when select changes
            updateSizeDisplay(newValue);
          });
        });
      }
      
      // Initialize size buttons
      initSizeButtons();

      // Listen for variant changes
      optionSelects.forEach(select => {
        select.addEventListener('change', () => {
          updateVariant();
        });
      });

      // Listen to variant-selects component events
      if (variantSelects) {
        variantSelects.addEventListener('change', (e) => {
          const variantId = e.detail?.variant?.id || variantIdInput?.value;
          if (variantId && productData.variants) {
            const variant = productData.variants.find(v => v.id.toString() === variantId.toString());
            if (variant) {
              updateSizeAndPrice(variant);
            }
          }
        });
      }
      
       // Initial update
       updateVariant();
     }
  })();
   
</script>

