      min-width: 0;
    }

    .pgc-minimal__header {
      margin-bottom: 0.75rem;
    }

    .pgc-minimal__variant-label-row {
      margin: 1rem 0 0.6rem 0;
      flex-wrap: nowrap !important;
      justify-content: space-between;
      gap: 8px;
      overflow: hidden;
    }

    .pgc-minimal__variant-option:not(.pgc-variant-option--has-size-guide) .pgc-minimal__variant-label {
