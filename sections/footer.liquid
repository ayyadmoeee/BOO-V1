{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{%- liquid
  assign hide_footer = false
  if collection.handle == 'all' or collection.handle == 'shop-all'
    assign hide_footer = true
  elsif page.handle == 'shop-all' or page.handle == 'all'
    assign hide_footer = true
  elsif request.page_type == 'collection' and collection.handle == 'all'
    assign hide_footer = true
  elsif page.template_suffix == 'contact' or page.handle == 'contact'
    assign hide_footer = true
  elsif request.page_type == '404'
    assign hide_footer = true
  endif
-%}

{%- unless hide_footer -%}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{{ 'footer.css' | asset_url | stylesheet_tag }}

{% if section.settings.lb_font_heading or section.settings.lb_font_body or section.settings.lb_font_button %}
  <style>
    {% if section.settings.lb_font_heading %}{{ section.settings.lb_font_heading | font_face: font_display: 'swap' }}{% endif %}
    {% if section.settings.lb_font_body %}{{ section.settings.lb_font_body | font_face: font_display: 'swap' }}{% endif %}
    {% if section.settings.lb_font_button %}{{ section.settings.lb_font_button | font_face: font_display: 'swap' }}{% endif %}
  </style>
{% endif %}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: 12px;
    padding-bottom: 12px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lb-footer.section-{{ section.id }}-padding {
    --lb-footer-brand-title-size: {{ section.settings.lb_brand_title_size }}px;
    --lb-footer-brand-title-weight: {{ section.settings.lb_brand_title_weight }};
    --lb-footer-brand-copy-size: {{ section.settings.lb_brand_copy_size }}px;
    --lb-footer-brand-copy-weight: {{ section.settings.lb_brand_copy_weight }};
    --lb-footer-column-title-size: {{ section.settings.lb_column_title_size }}px;
    --lb-footer-column-title-weight: {{ section.settings.lb_column_title_weight }};
    --lb-footer-link-size: {{ section.settings.lb_link_size }}px;
    --lb-footer-link-weight: {{ section.settings.lb_link_weight }};
    --lb-footer-newsletter-input-size: {{ section.settings.lb_newsletter_input_size }}px;
    --lb-footer-newsletter-input-weight: {{ section.settings.lb_newsletter_input_weight }};
    --lb-footer-newsletter-button-size: {{ section.settings.lb_newsletter_button_size }}px;
    --lb-footer-newsletter-button-weight: {{ section.settings.lb_newsletter_button_weight }};
    --lb-footer-bottom-text-size: {{ section.settings.lb_bottom_text_size }}px;
    --lb-footer-bottom-text-weight: {{ section.settings.lb_bottom_text_weight }};
  }

  .lb-footer.section-{{ section.id }}-padding .lb-footer__brand-image {
    width: min(100%, {{ section.settings.lb_brand_image_max_width | default: 360 }}px) !important;
    max-width: 100% !important;
    height: auto !important;
  }
 {%- endstyle -%}

{%- liquid
  assign lb_social_whatsapp_link = section.settings.lb_social_whatsapp_link
  if lb_social_whatsapp_link == blank and settings.social_whatsapp_link != blank
    assign lb_social_whatsapp_link = settings.social_whatsapp_link
  endif

  assign has_social_icons = false
  if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or lb_social_whatsapp_link != blank
    assign has_social_icons = true
  endif

  assign link_list_blocks = section.blocks | where: 'type', 'link_list'
  assign payment_blocks = section.blocks | where: 'type', 'payment_option'
  assign company_block = blank
  assign policies_block = blank
  assign lb_mobile_custom_block = blank

  for link_block in link_list_blocks
    assign heading_downcase = link_block.settings.heading | downcase
    if company_block == blank
      if heading_downcase contains 'company' or heading_downcase contains 'about'
        assign company_block = link_block
      endif
    endif
    if policies_block == blank
      if heading_downcase contains 'polic' or heading_downcase contains 'return' or heading_downcase contains 'shipping' or heading_downcase contains 'privacy' or heading_downcase contains 'term'
        assign policies_block = link_block
      endif
    endif
  endfor

  if company_block == blank and link_list_blocks.size > 0
    assign company_block = link_list_blocks.first
  endif
  if policies_block == blank and link_list_blocks.size > 1
    for link_block in link_list_blocks
      if forloop.index == 2
        assign policies_block = link_block
      endif
    endfor
  endif

  for link_block in link_list_blocks
    if link_block.settings.lb_mobile_custom_menu
      assign lb_mobile_custom_block = link_block
      break
    endif
  endfor

  assign text_block = section.blocks | where: 'type', 'text' | first
  assign lb_bg_alpha = section.settings.lb_background_opacity | divided_by: 100.0
  assign lb_glass_alpha = section.settings.lb_glass_opacity | divided_by: 100.0
  assign lb_glass_border_alpha = section.settings.lb_glass_border_opacity | divided_by: 100.0
  assign lb_bg_solid = section.settings.lb_background_color | color_modify: 'alpha', lb_bg_alpha
  assign lb_bg_selected = lb_bg_solid
  assign lb_has_gradient = false
  assign lb_gradient_css = section.settings.lb_background_gradient_css | strip
  if lb_gradient_css == blank and section.settings.lb_background_gradient != blank
    assign lb_gradient_css = section.settings.lb_background_gradient
  endif
  if lb_gradient_css != blank
    assign lb_has_gradient = true
  endif
  assign lb_has_bg_image = false
  assign lb_use_background_image = true
  assign lb_settings_json = section.settings | json
  if lb_settings_json contains '"lb_use_background_image":false'
    assign lb_use_background_image = false
  endif
  if section.settings.lb_use_gradient_background and lb_has_gradient
    assign lb_bg_selected = lb_gradient_css
  endif
  if lb_use_background_image and section.settings.lb_background_image != blank
    assign lb_has_bg_image = true
  endif
  assign lb_glass_overlay = section.settings.lb_background_color | color_modify: 'alpha', lb_glass_alpha
  assign lb_glass_border = section.settings.lb_glass_border_color | color_modify: 'alpha', lb_glass_border_alpha
  assign lb_text_color = section.settings.lb_text_color | default: '#ffffff'
  assign lb_text_color_90 = lb_text_color | color_modify: 'alpha', 0.9
  assign lb_text_color_86 = lb_text_color | color_modify: 'alpha', 0.86
  assign lb_text_color_82 = lb_text_color | color_modify: 'alpha', 0.82
  assign lb_text_color_80 = lb_text_color | color_modify: 'alpha', 0.8
  assign lb_text_color_76 = lb_text_color | color_modify: 'alpha', 0.76
  assign lb_text_color_72 = lb_text_color | color_modify: 'alpha', 0.72
  assign lb_text_color_58 = lb_text_color | color_modify: 'alpha', 0.58

  assign lb_brand_title = section.settings.lb_brand_title
  if lb_brand_title == blank
    assign lb_brand_title = settings.brand_headline
  endif
  if lb_brand_title == blank
    assign lb_brand_title = 'BOO'
  endif

  assign lb_brand_description = section.settings.lb_brand_description
  if lb_brand_description == blank and settings.brand_description != blank
    assign lb_brand_description = settings.brand_description
  endif
  if lb_brand_description == blank and text_block != blank and text_block.settings.subtext != blank
    assign lb_brand_description = text_block.settings.subtext
  endif
  if lb_brand_description == blank
    assign lb_brand_description = '<p>Contemporary culture, elevated essentials, and timeless pieces built with intention.</p>'
  endif

  assign lb_company_title = section.settings.lb_company_title
  if lb_company_title == blank and company_block != blank and company_block.settings.heading != blank
    assign lb_company_title = company_block.settings.heading
  endif
  if lb_company_title == blank
    assign lb_company_title = 'COMPANY'
  endif

  assign lb_policies_title = section.settings.lb_policies_title
  if lb_policies_title == blank and policies_block != blank and policies_block.settings.heading != blank
    assign lb_policies_title = policies_block.settings.heading
  endif
  if lb_policies_title == blank
    assign lb_policies_title = 'POLICIES'
  endif

  assign lb_newsletter_placeholder = section.settings.lb_newsletter_placeholder
  if lb_newsletter_placeholder == blank
    assign lb_newsletter_placeholder = 'Your email'
  endif

  assign lb_newsletter_button_label = section.settings.lb_newsletter_button_label
  if lb_newsletter_button_label == blank
    assign lb_newsletter_button_label = 'newsletter.button_label' | t
  endif
  if lb_newsletter_button_label == blank
    assign lb_newsletter_button_label = 'SUBSCRIBE'
  endif

  assign lb_fallback_about_label = section.settings.lb_fallback_about_label
  if lb_fallback_about_label == blank
    assign lb_fallback_about_label = 'About Us'
  endif
  assign lb_fallback_about_url = section.settings.lb_fallback_about_url
  if lb_fallback_about_url == blank
    assign lb_fallback_about_url = routes.root_url | append: 'pages/about-us'
  endif

  assign lb_fallback_contact_label = section.settings.lb_fallback_contact_label
  if lb_fallback_contact_label == blank
    assign lb_fallback_contact_label = 'Contacts'
  endif
  assign lb_fallback_contact_url = section.settings.lb_fallback_contact_url
  if lb_fallback_contact_url == blank
    assign lb_fallback_contact_url = routes.root_url | append: 'pages/contact'
  endif

  assign lb_copyright_template = section.settings.lb_copyright_text
  if lb_copyright_template == blank
    assign lb_copyright_template = '© [year] [shop_name]'
  endif
  assign lb_current_year = 'now' | date: '%Y'
  assign lb_copyright_text = lb_copyright_template | replace: '[year]', lb_current_year | replace: '[shop_name]', shop.name
-%}

<footer
  class="footer lb-footer section-{{ section.id }}-padding{% if section.settings.lb_glassy_background %} lb-footer--glassy{% endif %}{% if lb_has_bg_image %} lb-footer--image{% elsif section.settings.lb_use_gradient_background and lb_has_gradient %} lb-footer--gradient{% else %} lb-footer--solid{% endif %}"
  style="--lb-footer-bg-selected: {{ lb_bg_selected }}; --lb-footer-bg-solid: {{ lb_bg_solid }}; --lb-footer-glass-overlay: {{ lb_glass_overlay }}; --lb-footer-glass-border: {{ lb_glass_border }}; --lb-footer-glass-blur: {{ section.settings.lb_glass_blur }}px; --lb-footer-text-color: {{ lb_text_color }}; --lb-footer-text-90: {{ lb_text_color_90 }}; --lb-footer-text-86: {{ lb_text_color_86 }}; --lb-footer-text-82: {{ lb_text_color_82 }}; --lb-footer-text-80: {{ lb_text_color_80 }}; --lb-footer-text-76: {{ lb_text_color_76 }}; --lb-footer-text-72: {{ lb_text_color_72 }}; --lb-footer-text-58: {{ lb_text_color_58 }}; --lb-footer-payment-padding-x: {{ section.settings.lb_payment_padding_x | default: 0 }}px; --lb-footer-payment-padding-y: {{ section.settings.lb_payment_padding_y | default: 0 }}px; --lb-footer-font-heading: {{ section.settings.lb_font_heading.family }}, {{ section.settings.lb_font_heading.fallback_families }}; --lb-footer-font-body: {{ section.settings.lb_font_body.family }}, {{ section.settings.lb_font_body.fallback_families }}; --lb-footer-font-button: {{ section.settings.lb_font_button.family }}, {{ section.settings.lb_font_button.fallback_families }}; --lb-footer-brand-title-size: {{ section.settings.lb_brand_title_size }}px; --lb-footer-brand-title-weight: {{ section.settings.lb_brand_title_weight }}; --lb-footer-brand-image-max-width: {{ section.settings.lb_brand_image_max_width | default: 360 }}px; --lb-footer-brand-copy-size: {{ section.settings.lb_brand_copy_size }}px; --lb-footer-brand-copy-weight: {{ section.settings.lb_brand_copy_weight }}; --lb-footer-column-title-size: {{ section.settings.lb_column_title_size }}px; --lb-footer-column-title-weight: {{ section.settings.lb_column_title_weight }}; --lb-footer-link-size: {{ section.settings.lb_link_size }}px; --lb-footer-link-weight: {{ section.settings.lb_link_weight }}; --lb-footer-newsletter-input-size: {{ section.settings.lb_newsletter_input_size }}px; --lb-footer-newsletter-input-weight: {{ section.settings.lb_newsletter_input_weight }}; --lb-footer-newsletter-button-size: {{ section.settings.lb_newsletter_button_size }}px; --lb-footer-newsletter-button-weight: {{ section.settings.lb_newsletter_button_weight }}; --lb-footer-bottom-text-size: {{ section.settings.lb_bottom_text_size }}px; --lb-footer-bottom-text-weight: {{ section.settings.lb_bottom_text_weight }};"
>
  {%- if lb_has_bg_image -%}
    <div class="lb-footer__bg-image" aria-hidden="true">
      {{
        section.settings.lb_background_image
        | image_url: width: 3000
        | image_tag: class: 'lb-footer__bg-image-media', loading: 'lazy', alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="lb-footer__inner">
    <div class="lb-footer__grid">
      <div class="lb-footer__col lb-footer__col--brand">
        {%- if section.settings.lb_brand_image != blank -%}
          <div class="lb-footer__brand-image-wrap">
            {{
              section.settings.lb_brand_image
              | image_url: width: 1200
              | image_tag: class: 'lb-footer__brand-image', loading: 'lazy', alt: lb_brand_title
            }}
          </div>
        {%- else -%}
          <h2 class="lb-footer__brand-title">
            {{ lb_brand_title }}
          </h2>
        {%- endif -%}
        <div class="lb-footer__brand-copy rte">
          {{ lb_brand_description }}
        </div>
      </div>

      <div class="lb-footer__col lb-footer__col--company">
        <h3 class="lb-footer__title">{{ lb_company_title }}</h3>
        <ul class="lb-footer__links list-unstyled">
          {%- if company_block != blank and company_block.settings.menu != blank -%}
            {%- for link in company_block.settings.menu.links -%}
              <li>
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="{{ lb_fallback_about_url }}">{{ lb_fallback_about_label | escape }}</a></li>
            <li><a href="{{ lb_fallback_contact_url }}">{{ lb_fallback_contact_label | escape }}</a></li>
          {%- endif -%}
        </ul>
      </div>

      <div class="lb-footer__col lb-footer__col--policies">
        <h3 class="lb-footer__title">{{ lb_policies_title }}</h3>
        <ul class="lb-footer__links list-unstyled">
          {%- if section.settings.lb_policies_custom_menu != blank -%}
            {%- for link in section.settings.lb_policies_custom_menu.links -%}
              <li>
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
              </li>
            {%- endfor -%}
          {%- elsif policies_block != blank and policies_block.settings.menu != blank -%}
            {%- for link in policies_block.settings.menu.links -%}
              <li>
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>

      <div class="lb-footer__col lb-footer__col--newsletter">
        <div class="lb-footer__newsletter-glass">
          <h3 class="lb-footer__title">{{ section.settings.newsletter_heading | default: 'NEWSLETTER' }}</h3>

          {%- if section.settings.newsletter_enable -%}
            {%- form 'customer', id: 'ContactFooter', class: 'lb-footer__newsletter-form newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="lb-footer__newsletter-row">
                <div class="lb-footer__newsletter-field">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="ContactFooter-error"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="ContactFooter-success"
                    {% endif %}
                    placeholder="{{ lb_newsletter_placeholder | escape }}"
                    required
                  >
                </div>
                <button type="submit" name="commit" aria-label="{{ lb_newsletter_button_label | escape }}">
                  {{ lb_newsletter_button_label | escape }}
                </button>
              </div>

              {%- if form.errors -%}
                <small class="lb-footer__newsletter-message form__message" id="ContactFooter-error">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
              {%- if form.posted_successfully? -%}
                <small class="lb-footer__newsletter-message lb-footer__newsletter-message--success" id="ContactFooter-success">
                  {{- 'newsletter.success' | t -}}
                </small>
              {%- endif -%}
            {%- endform -%}
          {%- endif -%}
        </div>

        {%- if section.settings.show_social and has_social_icons -%}
          <ul class="lb-footer__social list-unstyled" role="list">
            {%- if settings.social_facebook_link != blank -%}
              <li>
                <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'general.social.links.facebook' | t }}">
                  {{- 'icon-facebook.svg' | inline_asset_content -}}
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <li>
                <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'general.social.links.instagram' | t }}">
                  {{- 'icon-instagram.svg' | inline_asset_content -}}
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li>
                <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'general.social.links.tiktok' | t }}">
                  {{- 'icon-tiktok.svg' | inline_asset_content -}}
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <li>
                <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                  {{- 'icon-twitter.svg' | inline_asset_content -}}
                </a>
              </li>
            {%- endif -%}
            {%- if lb_social_whatsapp_link != blank -%}
              <li>
                <a href="{{ lb_social_whatsapp_link }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
                  {{- 'icon-whatsapp.svg' | inline_asset_content -}}
                </a>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="lb-footer__col lb-footer__col--mobile-custom">
        <h3 class="lb-footer__title" aria-hidden="true">&nbsp;</h3>
        <ul class="lb-footer__links list-unstyled">
          {%- if lb_mobile_custom_block != blank and lb_mobile_custom_block.settings.menu != blank -%}
            {%- for link in lb_mobile_custom_block.settings.menu.links -%}
              <li>
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>
    </div>

    <div class="lb-footer__bottom">
      <div class="lb-footer__bottom-item lb-footer__bottom-item--left">
        <small class="lb-footer__copyright">
          {{ lb_copyright_text | escape }} Developed By <a href="https://www.voxire.com/" target="_blank" rel="noopener noreferrer">Voxire</a>
        </small>
      </div>

      <div class="lb-footer__bottom-item lb-footer__bottom-item--center">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      <div class="lb-footer__bottom-item lb-footer__bottom-item--right">
        {%- if section.settings.payment_enable -%}
          {%- if payment_blocks.size > 0 -%}
            <ul class="list lb-footer__payment lb-footer__payment--custom" role="list">
              {%- for payment_block in payment_blocks -%}
                {%- assign payment_label = payment_block.settings.payment_label | strip -%}
                {%- if payment_label == blank and payment_block.settings.payment_icon != blank -%}
                  {%- assign payment_label = 'Payment option' -%}
                {%- endif -%}
                {%- if payment_block.settings.payment_icon != blank or payment_label != blank -%}
                  <li class="lb-footer__payment-item" {{ payment_block.shopify_attributes }}>
                    {%- if payment_block.settings.payment_link != blank -%}
                      <a href="{{ payment_block.settings.payment_link }}" class="lb-footer__payment-link" aria-label="{{ payment_label | escape }}">
                    {%- endif -%}
                    {%- if payment_block.settings.payment_icon != blank -%}
                      {{ payment_block.settings.payment_icon | image_url: width: 120 | image_tag: loading: 'lazy', class: 'lb-footer__payment-icon-image', alt: payment_label }}
                    {%- else -%}
                      <span class="lb-footer__payment-label">{{ payment_label | escape }}</span>
                    {%- endif -%}
                    {%- if payment_block.settings.payment_link != blank -%}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- else -%}
            <ul class="list list-payment lb-footer__payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>
{%- endunless -%}

{% render 'voxire-credit' %}
{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        },
        {
          "type": "checkbox",
          "id": "lb_mobile_custom_menu",
          "default": false,
          "label": "Use as mobile custom menu"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
