{% assign sid = section.id | replace: '_', '' | downcase %}

{% if section.settings.section_font %}
  <style>
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  </style>
{% endif %}

{%- liquid
  assign section_padding_top = section.settings.section_padding_top | default: 0
  assign section_padding_bottom = section.settings.section_padding_bottom | default: 0
  assign section_padding_left = section.settings.section_padding_left | default: 0
  assign section_padding_right = section.settings.section_padding_right | default: 0
  assign section_margin_top = section.settings.section_margin_top | default: 0
  assign section_margin_bottom = section.settings.section_margin_bottom | default: 0
  assign heading_padding_top = section.settings.heading_padding_top | default: 0
  assign heading_padding_bottom = section.settings.heading_padding_bottom | default: 0
  assign heading_padding_left = section.settings.heading_padding_left | default: 20
  assign heading_padding_right = section.settings.heading_padding_right | default: 20
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign age_filter_margin_top = section.settings.age_filter_margin_top | default: 16
  assign age_filter_margin_bottom = section.settings.age_filter_margin_bottom | default: 0
  assign filter_btn_bg = section.settings.filter_btn_bg_color | default: '#4a4a4a'
  assign filter_btn_text = section.settings.filter_btn_text_color | default: '#ffffff'
  assign filter_btn_active_bg = section.settings.filter_btn_active_bg_color | default: '#2a2a2a'
  assign filter_btn_radius = section.settings.filter_btn_radius | default: 8
  assign mobile_carousel_padding_top = section.settings.mobile_carousel_padding_top | default: 20
  assign mobile_carousel_padding_bottom = section.settings.mobile_carousel_padding_bottom | default: 40
  assign mobile_carousel_padding_left = section.settings.mobile_carousel_padding_left | default: 0
  assign mobile_carousel_padding_right = section.settings.mobile_carousel_padding_right | default: 0
  assign grid_wrap_padding_top = section.settings.grid_wrap_padding_top | default: 0
  assign grid_wrap_padding_bottom = section.settings.grid_wrap_padding_bottom | default: 0
  assign grid_wrap_padding_left = section.settings.grid_wrap_padding_left | default: 40
  assign grid_wrap_padding_right = section.settings.grid_wrap_padding_right | default: 40
  assign tile_icon_size = section.settings.tile_icon_size | default: 36
  assign tile_icon_size_2x = tile_icon_size | times: 2
  assign tile_icon_offset_top = section.settings.tile_icon_offset_top | default: 12
  assign tile_icon_offset_left = section.settings.tile_icon_offset_left | default: 12
  assign section_bg_image = section.settings.section_bg_image
  if section_bg_image != blank
    assign section_bg_image_url = section_bg_image | image_url: width: 2400
  endif
-%}

{% style %}
/* ===== ANIMATED GAMING STYLE ===== */
.scg-heading-wrapper {
  text-align: center;
  padding: {{ heading_padding_top }}px {{ heading_padding_right }}px {{ heading_padding_bottom }}px {{ heading_padding_left }}px;
  position: relative;
  overflow: visible;
}

.scg-{{ sid }},
.scg-{{ sid }} * {
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
}

.scg-main-heading {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: {{ section.settings.heading_weight | default: 900 }};
  margin: 0 0 15px 0;
  letter-spacing: -0.5px;
  line-height: 1;
  text-transform: none;
  position: relative;
  font-family: inherit;
  /* Default gradient - will be overridden if custom color is set */
  background: linear-gradient(90deg, 
    #ff3366 0%, 
    #ff9933 25%, 
    #33ff66 50%, 
    #3366ff 75%, 
    #cc33ff 100%);
  background-size: 300% 300%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradient-shift 4s ease infinite, 
             text-glow 2s ease-in-out infinite alternate;
  text-shadow: 0 0 30px rgba(255, 51, 102, 0.3);
}

/* If custom color is set, disable gradient animation */
.scg-main-heading[style*="color:"] {
  animation: none;
  text-shadow: none;
}

@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes text-glow {
  from { text-shadow: 0 0 30px rgba(255, 51, 102, 0.3), 
                      0 0 60px rgba(51, 102, 255, 0.2); }
  to { text-shadow: 0 0 40px rgba(255, 51, 102, 0.5), 
                    0 0 80px rgba(51, 102, 255, 0.3),
                    0 0 100px rgba(204, 51, 255, 0.2); }
}

.scg-main-heading::before,
.scg-main-heading::after {
  content: '✦';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1.8rem;
  opacity: 0.7;
  animation: sparkle 2s infinite;
}

.scg-main-heading::before {
  left: -50px;
  animation-delay: 0.5s;
}

.scg-main-heading::after {
  right: -50px;
  animation-delay: 1s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: translateY(-50%) scale(0.8); }
  50% { opacity: 1; transform: translateY(-50%) scale(1.2); }
}

.scg-subheading {
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  color: #111; /* Solid dark color */
  margin: 0;
  font-weight: {{ section.settings.subheading_weight | default: 600 }};
  letter-spacing: 2px;
  text-transform: uppercase;
  position: relative;
  display: inline-block;
  padding: 10px 25px;
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 50px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.2),
    0 0 20px rgba(255, 255, 255, 0.5) inset;
  text-shadow: 0 3px 5px rgba(255, 255, 255, 0.8);
  animation: pulse-border 3s infinite;
}

@keyframes pulse-border {
  0%, 100% { border-color: rgba(255,255,255,0.3); }
  50% { border-color: rgba(255, 51, 102, 0.6); }
}

/* Decorative background elements */
.scg-heading-wrapper::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, 
    rgba(255,51,102,0.1) 0%,
    rgba(51,102,255,0.05) 40%,
    transparent 70%);
  z-index: -1;
  animation: pulse 6s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(0.8); }
  50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.2); }
}

.scg-{{ sid }}__wrap {
  position: relative;
  z-index: 2;
}

/* ===== AGE FILTER STYLES ===== */
.scg-age-filter {
  margin-top: {{ age_filter_margin_top }}px;
  margin-bottom: {{ age_filter_margin_bottom }}px;
  text-align: center;
}

.scg-age-filter__title {
  font-size: 16px;
  font-weight: {{ section.settings.filter_title_weight | default: 600 }};
  color: #4a4a4a;
  margin: 0 0 16px 0;
  text-transform: none;
  letter-spacing: 0;
}

.scg-age-filter__buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.scg-age-filter__btn {
  padding: 12px 24px;
  background: {{ filter_btn_bg }};
  color: {{ filter_btn_text }};
  border: none;
  border-radius: {{ filter_btn_radius }}px;
  font-size: 14px;
  font-weight: {{ section.settings.filter_button_weight | default: 500 }};
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 140px;
  text-align: center;
}

.scg-age-filter__btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.scg-age-filter__btn.scg-age-filter__btn--active {
  background: {{ filter_btn_active_bg }};
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.scg-age-filter__reset {
  width: 40px;
  height: 40px;
  border-radius: {{ filter_btn_radius }}px;
  background: {{ filter_btn_bg }};
  color: {{ filter_btn_text }};
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  padding: 0;
  flex-shrink: 0;
}

.scg-age-filter__reset:hover {
  opacity: 0.9;
  transform: rotate(90deg);
}

.scg-age-filter__reset svg,
.scg-age-filter__reset .scg-age-filter__reset-icon-img {
  width: 18px;
  height: 18px;
  object-fit: contain;
}
.scg-age-filter__reset .scg-age-filter__reset-icon-img {
  display: block;
}

@media (max-width: 768px) {
  .scg-age-filter__buttons {
    gap: 10px;
  }
  
  .scg-age-filter__btn {
    min-width: 120px;
    padding: 10px 20px;
    font-size: 13px;
  }
  
  .scg-age-filter__reset {
    width: 36px;
    height: 36px;
  }
}
/* ===== END AGE FILTER STYLES ===== */

/* ===== AGE FILTER FUNCTIONALITY ===== */
.scg-{{ sid }}__tile,
.scg-carousel__slide {
  transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
}

/* Filtered items remain visible but inactive */
.scg-{{ sid }}__tile.scg-filtered-out,
.scg-carousel__slide.scg-filtered-out {
  opacity: 0.55;
  transform: scale(0.985);
  pointer-events: none;
}

/* Desktop: filtered tiles stay blurred/dimmed (no scale to avoid cropping with contain) */
.scg-{{ sid }}__tile.scg-filtered-out .scg-{{ sid }}__media img {
  filter: blur(var(--scg-blur));
}

/* Prevent filtered tiles from becoming active */
.scg-{{ sid }}__tile.scg-filtered-out.scg-is-active {
  transform: scale(0.985);
  opacity: 0.55;
}

.scg-{{ sid }}__tile.scg-filtered-out .scg-{{ sid }}__hover-text {
  opacity: 0;
}

.scg-{{ sid }}__wrap.scg-filtering {
  min-height: auto;
}
/* ===== END AGE FILTER FUNCTIONALITY ===== */

/* ===== END GAMING STYLE ===== */
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} *{
    box-sizing:border-box;
  }
  #shopify-section-{{ section.id }}{
    background: {{ section.settings.section_bg }} !important;
    {% if section_bg_image_url != blank %}
    background-image: url('{{ section_bg_image_url }}') !important;
    background-size: cover !important;
    background-position: center center !important;
    background-repeat: no-repeat !important;
    {% endif %}
    margin: {{ section_margin_top }}px 0 {{ section_margin_bottom }}px 0 !important;
    padding: {{ section_padding_top }}px {{ section_padding_right }}px {{ section_padding_bottom }}px {{ section_padding_left }}px !important;
  }
  #shopify-section-{{ section.id }} .page-width{
    max-width:none !important;
    padding:0 !important;
  }
  #shopify-section-{{ section.id }} .gradient,
  #shopify-section-{{ section.id }} .color-background-1,
  #shopify-section-{{ section.id }} .color-background-2{
    background: transparent !important;
  }

  {% assign ar_desktop_raw = section.settings.tile_aspect_ratio | strip %}
  {% if ar_desktop_raw == '' or ar_desktop_raw == 'auto' %}
    {% assign ar_desktop = '3/4' %}
  {% else %}
    {% assign ar_desktop = ar_desktop_raw | replace: ':', '/' %}
  {% endif %}

  /* section: full viewport, extends under header; overflow allowed so header sits on section */
  .scg-{{ sid }}{
    width: 100vw;
    min-height: 100dvh;
    height: 100dvh;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    padding-top: var(--header-height, 72px);
    box-sizing: border-box;
    background: {{ section.settings.section_bg }};
    {% if section_bg_image_url != blank %}
    background-image: url('{{ section_bg_image_url }}');
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    {% endif %}
    --scg-blur: 3px;
    --scg-grid-align: {{ section.settings.grid_vertical_align | default: 'start' }};
    --scg-grid-offset-top: {{ section.settings.grid_offset_top | default: 0 }}px;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .scg-{{ sid }}__scale-inner {
    width: 100%;
    height: auto;
    flex: 0 0 auto;
    transform: scale(var(--scg-fit-scale, 1));
    transform-origin: center center;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* heading + filter: never shrink, always above grid */
  .scg-{{ sid }} .scg-heading-wrapper {
    flex: 0 0 auto;
    position: relative;
    z-index: 5;
  }

  /* grid wrapper: can shrink, never overlap heading */
  .scg-{{ sid }}__wrap{
    width:100%;
    max-width:{{ section.settings.max_width }}px;
    margin:0 auto;
    margin-top: var(--scg-grid-offset-top);
    padding:{{ grid_wrap_padding_top }}px {{ grid_wrap_padding_right }}px {{ grid_wrap_padding_bottom }}px {{ grid_wrap_padding_left }}px;
    min-height: 0;
    height: auto;
    flex: 1 1 auto;
    overflow: hidden;
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, minmax(0,1fr));
    gap: {{ section.settings.gap }}px;
    align-content: var(--scg-grid-align);
    justify-content: center;
    grid-auto-rows: min-content;
  }

  /* allow hover in editor */
  .scg-{{ sid }}__tile,.scg-{{ sid }}__tile *{pointer-events:auto}
  .scg-{{ sid }}__tile .shopify-section,
  .scg-{{ sid }}__tile [data-shopify-editor-section],
  .scg-{{ sid }}__tile [data-shopify-editor-block],
  .scg-{{ sid }}__tile .shopify-block,
  .scg-{{ sid }}__tile .shopify-section__block{pointer-events:none}
  /* Keep filtered-out tiles truly non-interactive */
  .scg-{{ sid }}__tile.scg-filtered-out,
  .scg-{{ sid }}__tile.scg-filtered-out *{
    pointer-events:none !important;
    cursor: default;
  }

  /* tiles: aspect-ratio only */
  .scg-{{ sid }}__tile{
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    width: 100%;
    aspect-ratio: {{ ar_desktop }};
    height: auto;
    align-self: start;
    border-radius: {{ section.settings.radius }}px;
    box-shadow: 0 18px 45px rgba(0,0,0,.14);
    transition: filter .35s ease, opacity .35s ease, transform .35s ease;
    background: {{ section.settings.tile_bg }};
  }

  /* media fills tile, contained */
  .scg-{{ sid }}__media{
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .scg-{{ sid }}__media img{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.image_fit | default: 'contain' }};
    object-position: center center;
    {% if section.settings.image_fit == 'contain' %}
    transform: scale(1);
    {% else %}
    transform: scale({{ section.settings.image_scale | divided_by: 100.0 }});
    {% endif %}
    transition: transform .5s ease;
    background: {{ section.settings.tile_bg }};
  }

  /* overlay */
  .scg-{{ sid }}__overlay{
    position:absolute;inset:0;z-index:1;
    background:linear-gradient(
      180deg,
      rgba(0,0,0,0) 20%,
      rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 100%
    );
    opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
    transition:opacity .35s ease;
  }

  /* hover vertical text */
  .scg-{{ sid }}__hover-text{
    position:absolute;
    right:18px;
    bottom:18px;
    writing-mode:vertical-rl;
    transform:rotate(180deg);
    font-size:22px;
    font-weight: {{ section.settings.hover_text_weight | default: 900 }};
    letter-spacing:2px;
    color:var(--scg-text);
    opacity:0;
    transition:opacity .3s ease;
    z-index:3;
    pointer-events:none;
  }

  /* Quick add (+) and popup */
  .scg-{{ sid }}__quickadd-trigger{
    position:absolute;
    bottom:12px;
    left:12px;
    z-index:6;
    width: {{ section.settings.quick_add_circle_size | default: 40 }}px;
    height: {{ section.settings.quick_add_circle_size | default: 40 }}px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,0.35);
    background: rgba(0,0,0,0.35);
    color:#fff;
    font-size: {{ section.settings.quick_add_plus_size | default: 26 }}px;
    line-height:1;
    display:flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    opacity:0;
    transform: translateY(6px);
    transition: opacity .2s ease, transform .2s ease, background .2s ease;
  }
  .scg-{{ sid }}__tile.scg-is-active .scg-{{ sid }}__quickadd-trigger,
  .scg-{{ sid }}__tile:hover .scg-{{ sid }}__quickadd-trigger{
    opacity:1;
    transform: translateY(0);
  }
  .scg-{{ sid }}__quickadd-trigger:hover{
    background: rgba(0,0,0,0.52);
  }

  .scg-{{ sid }}__quickadd-panel{
    position:absolute;
    left:0;
    right:0;
    bottom:0;
    top:auto;
    transform: translateY(12px);
    width:100%;
    height:auto;
    max-height:none;
    overflow:visible;
    z-index:7;
    border-radius:16px 16px 0 0;
    border:1px solid rgba(255,255,255,0.28);
    background: rgba(12,12,12,0.74);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding:18px 12px;
    opacity:0;
    visibility:hidden;
    pointer-events:none;
    transition: opacity .2s ease, transform .2s ease;
  }
  .scg-{{ sid }}__tile.scg-quickadd-open .scg-{{ sid }}__quickadd-panel{
    opacity:1;
    visibility:visible;
    pointer-events:auto;
    transform: translateY(0);
  }

  .scg-{{ sid }}__tile--soldout .scg-{{ sid }}__quickadd-trigger,
  .scg-{{ sid }}__tile--soldout .scg-{{ sid }}__quickadd-panel{
    display:none !important;
  }
  .scg-{{ sid }}__quickadd-title{
    margin:0 0 14px;
    font-size:13px;
    color:#fff;
    font-weight: {{ section.settings.quick_add_title_weight | default: 700 }};
    text-align:center;
    letter-spacing:.04em;
    text-transform:uppercase;
  }
  .scg-{{ sid }}__quickadd-sizes{
    display:grid;
    grid-template-columns: 1fr;
    gap:10px;
    justify-items:center;
  }
  .scg-{{ sid }}__quickadd-size{
    border:1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.12);
    color:#fff;
    border-radius:999px;
    width:{% if section.settings.quick_add_size_button_width > 0 %}{{ section.settings.quick_add_size_button_width }}px{% else %}100%{% endif %};
    max-width:100%;
    min-height:34px;
    padding:6px 10px;
    font-size:12px;
    font-weight: {{ section.settings.quick_add_size_weight | default: 600 }};
    cursor:pointer;
    transition: background .18s ease, border-color .18s ease;
  }
  .scg-{{ sid }}__quickadd-size:hover{
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.45);
  }
  .scg-{{ sid }}__quickadd-size[disabled]{
    opacity:.55;
    cursor:not-allowed;
  }
  .scg-{{ sid }}__quickadd-size--soldout{
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }
  .scg-{{ sid }}__quickadd-size-guide{
    margin-top:14px;
    width:100%;
    border:0;
    background:transparent;
    color:#fff;
    text-decoration:underline;
    font-size:12px;
    font-weight: {{ section.settings.quick_add_size_guide_link_weight | default: 500 }};
    cursor:pointer;
    opacity:.88;
  }

  .scg-{{ sid }}__size-guide-modal{
    position:fixed;
    inset:0;
    z-index:1200;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:20px;
  }
  .scg-{{ sid }}__size-guide-modal[hidden]{ display:none !important; }
  .scg-{{ sid }}__size-guide-overlay{
    position:absolute;
    inset:0;
    background: rgba(0,0,0,.55);
  }
  .scg-{{ sid }}__size-guide-popup{
    position:relative;
    width:752px;
    height:631px;
    max-width:calc(100vw - 40px);
    max-height:calc(100vh - 40px);
    border-radius:14px;
    background:#fff;
    overflow:hidden;
    z-index:1;
    box-shadow: 0 24px 70px rgba(0,0,0,.32);
    display:flex;
    flex-direction:column;
  }
  .scg-{{ sid }}__size-guide-heading{
    margin:0;
    padding:18px 52px 14px 20px;
    color:#121212;
    font-size:24px;
    font-weight: {{ section.settings.size_guide_heading_weight | default: 700 }};
    line-height:1.2;
    flex:0 0 auto;
  }
  .scg-{{ sid }}__size-guide-image-wrap{
    width:644px;
    height:483px;
    margin:0 auto;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#f7f7f7;
    flex:0 0 auto;
  }
  .scg-{{ sid }}__size-guide-image-wrap img{
    width:644px;
    height:483px;
    object-fit:contain;
    display:block;
  }
  .scg-{{ sid }}__size-guide-close{
    position:absolute;
    top:10px;
    right:10px;
    width:36px;
    height:36px;
    border:0;
    border-radius:8px;
    background:transparent;
    color:#111;
    font-size:26px;
    line-height:1;
    cursor:pointer;
  }

  /* === Smooth hover system (no :has) === */
  .scg-{{ sid }}__wrap {
    contain: layout style;
    overflow: hidden;
    padding-top: 18px;
    margin-top: calc(var(--scg-grid-offset-top) - 18px);
  }
  /* Allow active tile to lift without clipping the top corners */
  .scg-{{ sid }}__wrap.scg-is-hovering {
    overflow: visible;
  }

  .scg-{{ sid }}__tile {
    will-change: transform, opacity;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .scg-{{ sid }}__media {
    will-change: transform;
    transform: translateZ(0);
  }

  .scg-{{ sid }}__media img {
    will-change: transform;
    {% if section.settings.image_fit == 'contain' %}
    transform: scale(1) translateZ(0);
    {% else %}
    transform: scale({{ section.settings.image_scale | divided_by: 100.0 }}) translateZ(0);
    {% endif %}
  }

  /* Active tile hover effects */
  .scg-{{ sid }}__tile.scg-is-active .scg-{{ sid }}__hover-text{opacity:1}
  .scg-{{ sid }}__tile.scg-is-active .scg-{{ sid }}__overlay{opacity:{{ section.settings.overlay_hover_opacity | divided_by: 100.0 }}}
  .scg-{{ sid }}__tile.scg-is-active .scg-{{ sid }}__media img{
    {% if section.settings.image_fit == 'contain' %}
    transform: scale(1);
    {% else %}
    transform: scale({{ section.settings.image_scale | divided_by: 100.0 }}) scale({{ section.settings.hover_zoom | divided_by: 100.0 }});
    {% endif %}
  }

  /* When hovering any tile (JS adds .scg-is-hovering on wrap) */
  .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile {
    opacity: 0.55;
    transform: translateZ(0) scale(0.985);
  }

  /* Blur ONLY the image layer of non-active tiles (much faster than blurring the whole card) */
  .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile:not(.scg-is-active) .scg-{{ sid }}__media img {
    filter: blur(var(--scg-blur));
  }

  /* Active tile pops */
  .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile.scg-is-active {
    opacity: 1;
    transform: translateY(-14px) scale(1.03) translateZ(0);
    z-index: 3;
  }

  /* Show hover text only on active tile */
  .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile:not(.scg-is-active) .scg-{{ sid }}__hover-text {
    opacity: 0;
  }
  .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile.scg-is-active .scg-{{ sid }}__hover-text {
    opacity: 1;
  }

  /* Optional: reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .scg-{{ sid }}__tile,
    .scg-{{ sid }}__media img {
      transition: none !important;
    }
    .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile:not(.scg-is-active) .scg-{{ sid }}__media img {
      filter: none !important;
    }
  }

  /* Disable blur interaction on touch devices (no hover) */
  @media (hover: none) {
    .scg-{{ sid }}__quickadd-trigger,
    .scg-{{ sid }}__quickadd-panel {
      display:none !important;
    }
    .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile {
      opacity: 1;
      transform: none;
    }
    .scg-{{ sid }}__wrap.scg-is-hovering .scg-{{ sid }}__tile:not(.scg-is-active) .scg-{{ sid }}__media img {
      filter: none;
    }
  }

    /* ===== MOBILE CAROUSEL - HIDDEN BY DEFAULT ===== */
.scg-mobile-carousel {
  display: none; /* Hidden on desktop */
  width: 100%;
  overflow: hidden;
  position: relative;
  padding: {{ mobile_carousel_padding_top }}px {{ mobile_carousel_padding_right }}px {{ mobile_carousel_padding_bottom }}px {{ mobile_carousel_padding_left }}px;
}

.scg-carousel__container {
  display: flex;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  gap: 0;
  padding: 0;
  width: 100%;
  -webkit-overflow-scrolling: touch; /* Better mobile scrolling */
}
.scg-carousel__container * {
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.scg-carousel__slide {
  flex: 0 0 100%;
  min-width: 100%;
  flex-shrink: 0;
  will-change: transform; /* Optimize animations */
}

{% assign ar_mobile_raw = section.settings.tile_aspect_ratio_mobile | strip %}
{% if ar_mobile_raw == '' or ar_mobile_raw == 'auto' %}
  {% assign ar_mobile = '' %}
{% else %}
  {% assign ar_mobile = ar_mobile_raw | replace: ':', '/' %}
{% endif %}

.scg-carousel__link {
  position: relative;
  display: block;
  margin: 0 15px;
  {% if ar_mobile == '' %}
  height: {{ section.settings.tile_h_mobile }}px;
  {% else %}
  width: 100%;
  aspect-ratio: {{ ar_mobile }};
  height: auto;
  {% endif %}
  text-decoration: none;
  border-radius: {{ section.settings.radius }}px;
  box-shadow: 0 10px 30px rgba(0,0,0,.2);
  background: {{ section.settings.tile_bg }};
  overflow: hidden;
}

.scg-carousel__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.scg-carousel__media img {
  width: 100% !important;
  height: 100% !important;
  display: block !important;
  object-fit: {{ section.settings.image_fit | default: 'contain' }} !important;
  object-position: center center !important;
  background: {{ section.settings.tile_bg }};
  transition: transform 0.5s ease;
}

.scg-carousel__link:hover .scg-carousel__media img {
  {% if section.settings.image_fit == 'contain' %}
  transform: scale(1);
  {% else %}
  transform: scale(1.05);
  {% endif %}
}

.scg-carousel__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0) 20%,
    rgba(0,0,0,0.6) 100%
  );
}

.scg-carousel__title {
  position: absolute;
  bottom: 20px;
  left: 20px;
  right: 20px;
  font-size: 18px;
  font-weight: {{ section.settings.carousel_title_weight | default: 700 }};
  color: #fff;
  z-index: 3;
  text-align: center;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.scg-{{ sid }}__card-icon {
  position: absolute;
  top: {{ tile_icon_offset_top }}px;
  left: {{ tile_icon_offset_left }}px;
  width: {{ tile_icon_size }}px;
  height: {{ tile_icon_size }}px;
  z-index: 4;
  pointer-events: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.scg-{{ sid }}__card-icon img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.scg-carousel__dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 20px;
}

.scg-carousel__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(0,0,0,0.2);
  cursor: pointer;
  transition: background 0.3s ease;
}

.scg-carousel__dot.active {
  background: #ff3366;
  transform: scale(1.2);
}

