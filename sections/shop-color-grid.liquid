              aria-label="Quick add {{ p.title | escape }}"
            >+</button>

            <div class="scg-{{ sid }}__quickadd-panel" data-scg-qa-panel>
              <p class="scg-{{ sid }}__quickadd-title">{{ section.settings.quick_add_title | default: 'Choose size' }}</p>
              <div class="scg-{{ sid }}__quickadd-sizes">
                {%- for v in p.variants -%}
                  <button
                    type="button"
                    class="scg-{{ sid }}__quickadd-size{% unless v.available %} scg-{{ sid }}__quickadd-size--soldout{% endunless %}"
                    data-scg-qa-size
                    data-variant-id="{{ v.id }}"
                    aria-label="Add {{ p.title | escape }} size {{ v.title | escape }}"
                    {% unless v.available %}disabled aria-disabled="true"{% endunless %}
                  >
                    {{ v.title }}
                  </button>
                {%- endfor -%}
                {%- if p.variants.size == 0 -%}
                  <button type="button" class="scg-{{ sid }}__quickadd-size" disabled>Sold out</button>
                {%- endif -%}
              </div>

              {%- if section.settings.quick_add_size_guide_image != blank -%}
