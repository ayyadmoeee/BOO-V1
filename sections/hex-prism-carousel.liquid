      // Don't allow clicks on filtered cards
      if (faceLink.getAttribute('data-filtered') === 'true') {
        e.preventDefault();
        e.stopPropagation();
        return;
      }
      
      e.preventDefault();
      e.stopPropagation();
      const href = faceLink.getAttribute('href');
      if (href && href !== '#') {
        window.location.href = href;
      }
    }
    
    function handleKeydown(e) {
      if (!section.contains(document.activeElement) && !section.matches(':hover')) return;
      
