{%- liquid
  assign section_id = section.id
  assign perspective = section.settings.perspective | default: 1400
  assign perspective_mobile = section.settings.perspective_mobile | default: 1000
  assign radius_base = section.settings.radius | default: 300
  assign radius_mobile_base = section.settings.radius_mobile | default: 220
  assign card_gap_multiplier = section.settings.card_gap_multiplier | default: 100 | divided_by: 100.0
  assign radius = radius_base | times: card_gap_multiplier | round
  assign radius_mobile = radius_mobile_base | times: card_gap_multiplier | round
  assign face_width = section.settings.face_width | default: 360
  assign face_height = section.settings.face_height | default: 520
  assign face_width_mobile = section.settings.face_width_mobile | default: 280
  assign face_height_mobile = section.settings.face_height_mobile | default: 420
  assign card_aspect_ratio = section.settings.card_aspect_ratio | default: ''
  
  comment
    If aspect ratio is provided, calculate height from width
    Aspect ratio format: "4 / 5" or "1 / 1" etc.
  endcomment
  if card_aspect_ratio != blank
    assign ratio_parts = card_aspect_ratio | split: '/'
    if ratio_parts.size == 2
      assign ratio_width = ratio_parts[0] | strip | plus: 0.0
      assign ratio_height = ratio_parts[1] | strip | plus: 0.0
      if ratio_width > 0 and ratio_height > 0
        assign calculated_height = face_width | times: ratio_height | divided_by: ratio_width
        assign face_height = calculated_height | round
        assign calculated_height_mobile = face_width_mobile | times: ratio_height | divided_by: ratio_width
        assign face_height_mobile = calculated_height_mobile | round
      endif
    endif
  endif
  assign corner_radius = section.settings.corner_radius | default: 14
  assign side_opacity_raw = section.settings.side_opacity | default: 2
  assign side_opacity = side_opacity_raw | divided_by: 10.0
  assign side2_opacity_raw = section.settings.side2_opacity | default: 2
  assign side2_opacity = side2_opacity_raw | divided_by: 10.0
  assign background_color = section.settings.background_color | default: '#ffffff'
  assign section_bg_image = section.settings.section_bg_image
  assign image_max_width = section.settings.image_max_width | default: 700
  assign padding_top = section.settings.padding_top | default: 0
  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign blocks_count = section.blocks.size
  assign section_title = section.settings.section_title | default: ''
  assign section_title_tag = section.settings.section_title_tag | default: 'h2'
  assign section_title_color = section.settings.section_title_color | default: 'rgba(255,255,255,0.95)'
  assign section_title_top_padding = section.settings.section_title_top_padding | default: 60
  assign section_title_size = section.settings.section_title_size | default: 32
  assign section_title_mobile_size = section.settings.section_title_mobile_size | default: 24
  assign section_title_weight = section.settings.section_title_weight | default: '800'
  assign show_age_filter = section.settings.show_age_filter
  assign age_filter_title = section.settings.age_filter_title | default: 'Choose Age'
  assign age_filter_title_color = section.settings.age_filter_title_color | default: 'rgba(255,255,255,0.9)'
  assign age_filter_title_size = section.settings.age_filter_title_size | default: 16
  assign age_filter_title_weight = section.settings.age_filter_title_weight | default: '700'
  assign side_icon_size = section.settings.side_icon_size | default: 24
  assign side_icon_width_2x = side_icon_size | times: 2
  assign side_icon_alt = section.settings.side_icon_alt | default: ''
  assign side_icon_json_url = section.settings.side_icon_json_url | default: ''
  assign tile_icon_size = section.settings.tile_icon_size | default: 36
  assign tile_icon_size_2x = tile_icon_size | times: 2
  assign tile_icon_offset_top = section.settings.tile_icon_offset_top | default: 12
  assign tile_icon_offset_left = section.settings.tile_icon_offset_left | default: 12
  assign age_filter_values = section.settings.age_filter_values | default: '0.5-4,4-7,7-10'
  assign age_filters = age_filter_values | split: ','
  assign filter_gap = section.settings.filter_gap | default: 10
  assign filter_top_padding = section.settings.filter_top_padding | default: 60
  assign filter_bottom_margin = section.settings.filter_bottom_margin | default: 24
  assign filter_ui_scale = section.settings.filter_ui_scale | default: 100 | divided_by: 100.0
  assign carousel_box_scale = section.settings.carousel_box_scale | default: 100 | divided_by: 100.0
  assign card_name_size = section.settings.card_name_size | default: 12
  assign card_name_weight = section.settings.card_name_weight | default: '800'
  assign hide_on_desktop = section.settings.hide_on_desktop
-%}

<section
  class="hex-prism-carousel hex-prism-carousel--{{ section_id }}"
  data-section-id="{{ section_id }}"
  data-perspective="{{ perspective }}"
  data-radius="{{ radius }}"
  data-face-width="{{ face_width }}"
  data-face-height="{{ face_height }}"
  data-corner-radius="{{ corner_radius }}"
  data-side-opacity="{{ side_opacity }}"
  style="background-color: {{ background_color }};{% if section_bg_image != blank %} background-image: url('{{ section_bg_image | image_url: width: 1200 }}'); background-size: cover; background-position: center;{% endif %} --card-r: {{ corner_radius }}px; --card-w: {{ face_width }}px; --card-h: {{ face_height }}px; --card-w-m: {{ face_width_mobile }}px; --card-h-m: {{ face_height_mobile }}px; --persp-d: {{ perspective }}px; --persp-m: {{ perspective_mobile }}px; --radius-d: {{ radius }}px; --radius-m: {{ radius_mobile }}px; --faces: {{ blocks_count }}; --filter-ui-scale: {{ filter_ui_scale }}; --carousel-box-scale: {{ carousel_box_scale }};"
>
  {%- if section_title != blank -%}
    <{{ section_title_tag }} class="hex-prism-carousel__section-title hex-prism-carousel__section-title--{{ section_id }}">
      {{ section_title }}
    </{{ section_title_tag }}>
  {%- endif -%}
  {%- if show_age_filter or section.settings.side_icon != blank or side_icon_json_url != blank -%}
    <div class="hex-prism-carousel__filters hex-prism-carousel__filters--{{ section_id }}"{% if show_age_filter %} data-filters{% endif %}>
      <div class="hex-prism-carousel__filters-header hex-prism-carousel__filters-header--{{ section_id }}{% unless show_age_filter %} hex-prism-carousel__filters-header--icon-only--{{ section_id }}{% endunless %}">
        {%- if show_age_filter -%}
          <div class="hex-prism-carousel__filters-title hex-prism-carousel__filters-title--{{ section_id }}">
            {{ age_filter_title }}
          </div>
        {%- endif -%}
        {%- unless show_age_filter -%}
          {%- if section.settings.side_icon != blank or side_icon_json_url != blank -%}
            <span class="hex-prism-carousel__side-icon-wrap hex-prism-carousel__side-icon-wrap--{{ section_id }}">
              {%- if side_icon_json_url != blank -%}
                <span
                  class="hex-prism-carousel__side-icon hex-prism-carousel__side-icon--{{ section_id }} hex-prism-carousel__side-icon--lottie--{{ section_id }}"
                  data-hpc-side-icon-json="{{ side_icon_json_url | escape }}"
                  {% if side_icon_alt != blank %}
                    role="img"
                    aria-label="{{ side_icon_alt | escape }}"
                  {% else %}
                    aria-hidden="true"
                  {% endif %}
                ></span>
              {%- elsif section.settings.side_icon != blank -%}
                <img
                  src="{{ section.settings.side_icon | image_url: width: side_icon_width_2x }}"
                  alt="{{ side_icon_alt | escape }}"
                  width="{{ side_icon_size }}"
                  height="{{ side_icon_size }}"
                  loading="lazy"
                  class="hex-prism-carousel__side-icon hex-prism-carousel__side-icon--{{ section_id }}"
                  {% if side_icon_alt == blank %}aria-hidden="true"{% endif %}
                >
              {%- endif -%}
            </span>
          {%- endif -%}
        {%- endunless -%}
      </div>
      {%- if show_age_filter -%}
        <div class="hex-prism-carousel__filters-row hex-prism-carousel__filters-row--{{ section_id }}">
          <div class="hex-prism-carousel__filters-chip-group hex-prism-carousel__filters-chip-group--{{ section_id }}">
            {%- for f in age_filters -%}
              {%- assign v = f | strip -%}
              {%- if v != blank and v != 'all' and v != 'All' -%}
                <button type="button"
                  class="hex-prism-carousel__chip hex-prism-carousel__chip--{{ section_id }}"
                  data-age-filter="{{ v | escape }}">
                  {{ v }}
                </button>
              {%- endif -%}
            {%- endfor -%}

            <button type="button"
              class="hex-prism-carousel__chip hex-prism-carousel__chip--{{ section_id }} hex-prism-carousel__chip--reset hex-prism-carousel__chip--reset--{{ section_id }}"
              data-age-reset
              aria-label="Reset filters"
              title="Reset filters">
              {%- if section.settings.reset_icon != blank -%}
                <img
                  src="{{ section.settings.reset_icon | image_url: width: 72 }}"
                  alt=""
                  width="18"
                  height="18"
                  loading="lazy"
                  class="hex-prism-carousel__reset-icon"
                >
              {%- else -%}
                ↺
              {%- endif -%}
            </button>
          </div>
          {%- if section.settings.side_icon != blank or side_icon_json_url != blank -%}
            <span class="hex-prism-carousel__side-icon-wrap hex-prism-carousel__side-icon-wrap--{{ section_id }} hex-prism-carousel__side-icon-wrap--row--{{ section_id }}">
              {%- if side_icon_json_url != blank -%}
                <span
                  class="hex-prism-carousel__side-icon hex-prism-carousel__side-icon--{{ section_id }} hex-prism-carousel__side-icon--lottie--{{ section_id }}"
                  data-hpc-side-icon-json="{{ side_icon_json_url | escape }}"
                  {% if side_icon_alt != blank %}
                    role="img"
                    aria-label="{{ side_icon_alt | escape }}"
                  {% else %}
                    aria-hidden="true"
                  {% endif %}
                ></span>
              {%- elsif section.settings.side_icon != blank -%}
                <img
                  src="{{ section.settings.side_icon | image_url: width: side_icon_width_2x }}"
                  alt="{{ side_icon_alt | escape }}"
                  width="{{ side_icon_size }}"
                  height="{{ side_icon_size }}"
                  loading="lazy"
                  class="hex-prism-carousel__side-icon hex-prism-carousel__side-icon--{{ section_id }}"
                  {% if side_icon_alt == blank %}aria-hidden="true"{% endif %}
                >
              {%- endif -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
  <div class="hex-prism-carousel__scene hex-prism-carousel__scene--{{ section_id }}">
    <div class="hex-prism-carousel__box hex-prism-carousel__box--{{ section_id }}">
      <div class="hex-prism-carousel__prism hex-prism-carousel__prism--{{ section_id }}" data-prism>
        {%- for block in section.blocks -%}
        {%- liquid
          assign face_image = null
          assign gradient_start = '#4a90e2'
          assign gradient_end = '#7b68ee'
          assign face_link = '#'
          assign face_alt = 'Carousel card ' | append: forloop.index
          
          if block.settings.image
            assign face_image = block.settings.image
            assign face_alt = block.settings.image.alt | default: face_alt
          endif
          
          if block.settings.link != blank
            assign face_link = block.settings.link
          endif
          
          if block.settings.gradient_start != blank
            assign gradient_start = block.settings.gradient_start
          endif
          
          if block.settings.gradient_end != blank
            assign gradient_end = block.settings.gradient_end
          endif
          
          assign face_name = block.settings.name | default: face_alt
          assign face_ages = block.settings.ages | default: ''
          assign face_product = block.settings.product
          assign product_handle_from_link = ''

          if face_product and face_link == '#'
            assign face_link = face_product.url
          endif

          if face_product == blank and face_link contains '/products/'
            assign product_handle_from_link = face_link | split: '/products/' | last | split: '?' | first | split: '#' | first
            assign face_product = all_products[product_handle_from_link]
          endif

          if face_product and face_product.title != blank
            assign face_name = face_product.title
          endif

          assign face_icon = block.settings.card_icon | default: section.settings.tile_top_left_icon
          assign face_is_discounted = false
          if face_product
            for v in face_product.variants
              if v.compare_at_price and v.compare_at_price > v.price
                assign face_is_discounted = true
                break
              endif
            endfor
          endif
        -%}
        <a
          href="{{ face_link }}"
          class="hex-prism-carousel__face hex-prism-carousel__face--{{ section_id }}"
          data-face
          data-face-index="{{ forloop.index0 }}"
          data-ages="{{ face_ages | escape }}"
          aria-label="{{ face_alt }}"
          tabindex="0"
          style="--i: {{ forloop.index0 }};"
        >
          <div class="hex-prism-carousel__face-inner hex-prism-carousel__face-inner--{{ section_id }}">
            {%- if face_icon != blank and face_is_discounted -%}
              <span class="hex-prism-carousel__card-icon hex-prism-carousel__card-icon--{{ section_id }}" aria-hidden="true">
                <img
                  src="{{ face_icon | image_url: width: tile_icon_size_2x }}"
                  alt=""
                  width="{{ tile_icon_size }}"
                  height="{{ tile_icon_size }}"
                  loading="lazy"
                >
              </span>
            {%- endif -%}
            <div class="hex-prism-carousel__clip hex-prism-carousel__clip--{{ section_id }}">
              {%- if face_image -%}
                {%- assign image_width_2x = image_max_width | times: 2 -%}
                {%- assign image_1x_url = face_image | image_url: width: image_max_width -%}
                {%- assign image_2x_url = face_image | image_url: width: image_width_2x -%}
                <img
                  src="{{ image_1x_url }}"
                  srcset="{{ image_1x_url }} 1x, {{ image_2x_url }} 2x"
                  sizes="(max-width: 768px) 100vw, {{ image_max_width }}px"
                  alt="{{ face_alt }}"
                  loading="lazy"
                  class="hex-prism-carousel__image hex-prism-carousel__image--{{ section_id }}"
                >
              {%- else -%}
                <div
                  class="hex-prism-carousel__gradient hex-prism-carousel__gradient--{{ section_id }}"
                  style="background: linear-gradient(135deg, {{ gradient_start }}, {{ gradient_end }});"
                ></div>
              {%- endif -%}
            </div>
            <span class="hex-prism-carousel__name hex-prism-carousel__name--{{ section_id }}" aria-hidden="true">
              {{ face_name }}
            </span>

            {% if section.settings.enable_tile_quick_add and face_product %}
              <button
                type="button"
                class="hex-prism-carousel__quickadd-trigger hex-prism-carousel__quickadd-trigger--{{ section_id }}"
                data-hpc-qa-trigger
                aria-label="Quick add {{ face_product.title | escape }}"
              >+</button>

              <div class="hex-prism-carousel__quickadd-panel hex-prism-carousel__quickadd-panel--{{ section_id }}" data-hpc-qa-panel>
                <p class="hex-prism-carousel__quickadd-title">{{ section.settings.quick_add_title | default: 'Choose size' }}</p>
                <div class="hex-prism-carousel__quickadd-sizes">
                  {%- for v in face_product.variants -%}
                    <button
                      type="button"
                      class="hex-prism-carousel__quickadd-size{% unless v.available %} hex-prism-carousel__quickadd-size--soldout{% endunless %}"
                      data-hpc-qa-size
                      data-variant-id="{{ v.id }}"
                      {% unless v.available %}disabled aria-disabled="true"{% endunless %}
                    >
                      {{ v.title }}
                    </button>
                  {%- endfor -%}
                </div>
                {%- if section.settings.quick_add_size_guide_image != blank -%}
                  <button type="button" class="hex-prism-carousel__quickadd-size-guide" data-hpc-open-size-guide>
                    {{ section.settings.quick_add_size_guide_link_label | default: 'Open size guide' }}
                  </button>
                {%- endif -%}
              </div>
            {% endif %}
          </div>
        </a>
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- if section.settings.enable_tile_quick_add and section.settings.quick_add_size_guide_image != blank -%}
    <div class="hex-prism-carousel__size-guide-modal hex-prism-carousel__size-guide-modal--{{ section_id }}" data-hpc-size-guide-modal hidden>
      <div class="hex-prism-carousel__size-guide-overlay" data-hpc-size-guide-close></div>
      <div class="hex-prism-carousel__size-guide-popup" role="dialog" aria-modal="true" aria-label="Size guide">
        <button type="button" class="hex-prism-carousel__size-guide-close" data-hpc-size-guide-close aria-label="Close size guide">×</button>
        <h3 class="hex-prism-carousel__size-guide-heading">{{ section.settings.quick_add_size_guide_heading | default: 'Size guide' }}</h3>
        <div class="hex-prism-carousel__size-guide-image-wrap">
          <img
            src="{{ section.settings.quick_add_size_guide_image | image_url: width: 1288 }}"
            alt="{{ section.settings.quick_add_size_guide_heading | default: 'Size guide' | escape }}"
            loading="lazy"
          >
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  .hex-prism-carousel--{{ section_id }} {
    position: relative;
    width: 100%;
    min-height: 600px;
    overflow: visible;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    margin-top: -60px;
    display: block;
  }

  .hex-prism-carousel__scene--{{ section_id }} {
    perspective: var(--persp-d);
    perspective-origin: center center;
    width: 100%;
    height: 100%;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    touch-action: pan-y pinch-zoom;
    cursor: grab;
  }

  .hex-prism-carousel__scene--{{ section_id }}:active {
    cursor: grabbing;
  }

  .hex-prism-carousel__box--{{ section_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    transform-origin: center center;
    transform: translate3d(0, 0, 0) scale(var(--carousel-box-scale));
    -webkit-transform: translate3d(0, 0, 0) scale(var(--carousel-box-scale));
    -webkit-transform-style: preserve-3d;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .hex-prism-carousel__prism--{{ section_id }} {
    position: relative;
    width: var(--card-w);
    height: var(--card-h);
    -webkit-transform-style: preserve-3d;
    transform-style: preserve-3d;
    will-change: transform;
    transform: translateZ(0) rotateY(var(--rot, 0deg));
    transition: transform 480ms cubic-bezier(0.23, 1, 0.32, 1);
    --radius: var(--radius-d);
    --step: calc(360deg / var(--faces));
  }

  .hex-prism-carousel__face--{{ section_id }} {
    position: absolute;
    width: var(--card-w);
    height: var(--card-h);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    -webkit-transform-style: preserve-3d;
    transform-style: preserve-3d;
    transform: rotateY(calc(var(--i) * var(--step))) translateZ(calc(var(--radius) + var(--z, 0px)));
    display: block;
    text-decoration: none;
    outline: none;
    pointer-events: auto;
    opacity: 1;
    /* Ensure CSS variable is available to children */
    --card-r: var(--card-r, {{ corner_radius }}px);
  }

  .hex-prism-carousel--{{ section_id }} .hex-prism-carousel__face--{{ section_id }}::after {
    content: none !important;
  }

  .hex-prism-carousel--{{ section_id }} .hex-prism-carousel__face--{{ section_id }} > svg,
  .hex-prism-carousel--{{ section_id }} .hex-prism-carousel__face--{{ section_id }} .icon {
    display: none !important;
  }

  .hex-prism-carousel__face--{{ section_id }}:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 4px;
  }

  .hex-prism-carousel__face-inner--{{ section_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 480ms cubic-bezier(0.23, 1, 0.32, 1), opacity 480ms cubic-bezier(0.23, 1, 0.32, 1);
    /* IMPORTANT: inner is NOT the clipper */
    border-radius: 0 !important;
    overflow: visible !important;
    background: transparent !important;
    /* Pass CSS variable down */
    --card-r: var(--card-r, {{ corner_radius }}px);
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="active"] {
    z-index: 10;
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="active"] .hex-prism-carousel__face-inner--{{ section_id }} {
    opacity: 1;
    transform: scale(1);
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="side"] {
    z-index: 7;
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="side"] .hex-prism-carousel__face-inner--{{ section_id }} {
    opacity: {{ side_opacity }};
    transform: scale(0.92);
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="side"] .hex-prism-carousel__face-inner--{{ section_id }}::after {
    content: none;
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="side2"] {
    z-index: 4;
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="side2"] .hex-prism-carousel__face-inner--{{ section_id }} {
    opacity: {{ side2_opacity }};
    transform: scale(0.86);
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="side2"] .hex-prism-carousel__face-inner--{{ section_id }}::after {
    content: none;
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="far"] {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    z-index: 1;
  }

  .hex-prism-carousel__face--{{ section_id }}[data-state="far"] .hex-prism-carousel__face-inner--{{ section_id }} {
    opacity: 0;
    transform: scale(0.85);
  }

  .hex-prism-carousel__image--{{ section_id }},
  .hex-prism-carousel__gradient--{{ section_id }} {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hex-prism-carousel__image--{{ section_id }} {
    object-fit: cover;
  }



  /* Hide on desktop if setting is enabled */
  {%- if hide_on_desktop -%}
  @media (min-width: 1025px) {
    .hex-prism-carousel--{{ section_id }} {
      display: none !important;
    }
  }
  {%- endif -%}

  /* Tablet/iPad styles */
  @media (min-width: 769px) and (max-width: 1024px) {
    .hex-prism-carousel--{{ section_id }} {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .hex-prism-carousel__section-title--{{ section_id }}{
      font-size: {{ section_title_mobile_size }}px;
      padding: 20px 18px 10px;
    }

    .hex-prism-carousel--{{ section_id }} {
      display: block;
      min-height: auto;
      --radius: var(--radius-m);
      --card-w: min(var(--card-w-m), calc(100vw - 72px));
      --card-h: var(--card-h-m);
    }

    .hex-prism-carousel__scene--{{ section_id }} {
      min-height: auto;
      padding: 20px 0;
      perspective: var(--persp-m);
      touch-action: pan-y pinch-zoom;
      -webkit-overflow-scrolling: touch;
    }

    .hex-prism-carousel__prism--{{ section_id }} {
      --radius: var(--radius-m);
      width: min(var(--card-w-m), calc(100vw - 72px));
      height: var(--card-h-m);
    }

    .hex-prism-carousel__face--{{ section_id }} {
