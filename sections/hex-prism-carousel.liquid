      dragOffset = 0;
      swipeDirection = null; // Reset direction on new drag
      section.style.cursor = 'grabbing';
      section.style.userSelect = 'none';
      // Don't prevent default here - let first move determine direction
    }
    
    function handlePointerMove(e) {
      if (!isDragging) return;
      if (e.touches && !e.touches.length) return;
      
      const x = e.touches ? e.touches[0].clientX : e.clientX;
      const y = e.touches ? e.touches[0].clientY : e.clientY;
      const deltaX = Math.abs(x - startX);
      const deltaY = Math.abs(y - startY);
      
      // Lock direction early, with bias toward horizontal intent.
      if (!swipeDirection) {
        const detectedDirection = detectSwipeDirection(deltaX, deltaY);
        if (detectedDirection === 'horizontal') {
          swipeDirection = 'horizontal';
          if (e.cancelable) {
            e.preventDefault();
          }
        } else if (detectedDirection === 'vertical') {
          swipeDirection = 'vertical';
          return;
        }
      }
      
      // If horizontal swipe is locked, ALWAYS prevent default to stop vertical scrolling
      if (swipeDirection === 'horizontal') {
        // Aggressively prevent default to stop any vertical movement
        if (e.cancelable) {
          e.preventDefault();
        }
        dragOffset = x - startX;
        currentX = x;
      }
      // If vertical, do nothing - let browser handle it naturally
    }
    
    // Separate touchmove handler for mobile devices (non-passive to allow preventDefault)
    function handleTouchMove(e) {
      if (!useTouchDragHandlers) return;
      if (!isDragging) return;
      if (!e.touches || !e.touches.length) return;
      
      // If horizontal is already locked, prevent default immediately to stop vertical scrolling
      if (swipeDirection === 'horizontal') {
        e.preventDefault();
        const x = e.touches[0].clientX;
        dragOffset = x - startX;
        currentX = x;
        return;
      }
      
      // Otherwise, detect direction (same logic as pointermove but for touch)
      const x = e.touches[0].clientX;
      const y = e.touches[0].clientY;
      const deltaX = Math.abs(x - startX);
      const deltaY = Math.abs(y - startY);
      
      // Lock direction early, with bias toward horizontal intent.
      if (!swipeDirection) {
        const detectedDirection = detectSwipeDirection(deltaX, deltaY);
        if (detectedDirection === 'horizontal') {
          swipeDirection = 'horizontal';
          e.preventDefault();
          dragOffset = x - startX;
          currentX = x;
        } else if (detectedDirection === 'vertical') {
          swipeDirection = 'vertical';
          return;
        }
      }
    }

    // Lightweight lock path for pointer-enabled touch devices:
    // only prevents vertical page scroll during horizontal swipes.
    function handleTouchMoveLock(e) {
      if (!useTouchMoveLock) return;
      if (!isDragging) return;
      if (!e.touches || !e.touches.length) return;

      const x = e.touches[0].clientX;
      const y = e.touches[0].clientY;
      const deltaX = Math.abs(x - startX);
      const deltaY = Math.abs(y - startY);

      if (!swipeDirection) {
        const detectedDirection = detectSwipeDirection(deltaX, deltaY);
        if (!detectedDirection) return;
        swipeDirection = detectedDirection;
      }

      if (swipeDirection === 'horizontal' && e.cancelable) {
        e.preventDefault();
      }
    }
    
    function handlePointerUp(e) {
      if (!isDragging) {
        dragOffset = 0;
        swipeDirection = null;
        return;
