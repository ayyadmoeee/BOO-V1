        e.preventDefault();
        goPrev();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        goNext();
      }
    }
    
    function init() {
      if (faces.length === 0) return;
      
      section.style.setProperty('--faces', String(numFaces));
      
      faces.forEach((face, index) => {
        face.style.setProperty('--i', index);
      });

      if (usePointerDragHandlers) {
        section.addEventListener('pointerdown', handlePointerDown);
        section.addEventListener('pointermove', handlePointerMove);
        section.addEventListener('pointerup', handlePointerUp);
        section.addEventListener('pointercancel', handlePointerUp);
        if (useTouchMoveLock) {
          section.addEventListener('touchmove', handleTouchMoveLock, { passive: false });
        }
      } else {
        // Touch path (mobile/coarse pointers) for reliable scroll locking.
        section.addEventListener('touchstart', handlePointerDown, { passive: true });
        section.addEventListener('touchmove', handleTouchMove, { passive: false });
        section.addEventListener('touchend', handlePointerUp, { passive: true });
        section.addEventListener('touchcancel', handlePointerUp, { passive: true });
      }
      section.addEventListener('click', handleClick, true);
      section.addEventListener('keydown', handleKeydown);
      
      // Wire filter chip clicks
      if (chips.length) {
        chips.forEach(btn => {
          btn.addEventListener('click', () => {
            activeFilter = btn.getAttribute('data-age-filter') || 'all';
            chips.forEach(c => c.classList.toggle('is-active', c === btn));
            applyFilter();
            // Keep the current activeIndex but if it becomes filtered, advance until you find a match
            if (!faceMatchesFilter(faces[activeIndex], activeFilter)) {
              // advance up to numFaces to find a match
              for (let i = 0; i < numFaces; i++) {
                rotationIndex += 1;
                const nextIdx = mod(rotationIndex, numFaces);
                if (faceMatchesFilter(faces[nextIdx], activeFilter)) break;
              }
              updateUI();
            } else {
              updateUI();
            }
          });
        });
      }

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          activeFilter = 'all';
          chips.forEach(c => c.classList.remove('is-active'));
          applyFilter();
          updateUI();
        });
      }
      
      applyFilter();
      updateUI();
    }
    
    function cleanup() {
      section.removeEventListener('pointerdown', handlePointerDown);
      section.removeEventListener('pointermove', handlePointerMove);
      section.removeEventListener('pointerup', handlePointerUp);
      section.removeEventListener('pointercancel', handlePointerUp);
      section.removeEventListener('touchstart', handlePointerDown);
      section.removeEventListener('touchmove', handleTouchMove);
      section.removeEventListener('touchmove', handleTouchMoveLock);
      section.removeEventListener('touchend', handlePointerUp);
      section.removeEventListener('touchcancel', handlePointerUp);
      section.removeEventListener('click', handleClick, true);
      section.removeEventListener('keydown', handleKeydown);
      
      if (transitionUnlockTimer) {
        clearTimeout(transitionUnlockTimer);
        transitionUnlockTimer = null;
      }
      isTransitionLocked = false;
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    
    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === sectionId) {
        cleanup();
        setTimeout(init, 100);
      }
    });
    
    document.addEventListener('shopify:section:unload', function(e) {
      if (e.detail.sectionId === sectionId) {
        cleanup();
      }
    });
  })();
</script>

<script>
  (function() {
    const section = document.querySelector('.hex-prism-carousel--{{ section_id }}');
    if (!section) return;

    const modal = section.querySelector('[data-hpc-size-guide-modal]');
    const modalCloseEls = modal ? modal.querySelectorAll('[data-hpc-size-guide-close]') : [];
    let openFace = null;

    function setModalLock(locked) {
      if (window.matchMedia('(max-width: 768px)').matches) {
        document.body.classList.toggle('hpc-modal-lock', locked);
        document.documentElement.classList.toggle('hpc-modal-lock', locked);
      }
    }

    function openSizeGuide() {
      if (!modal) return;
      modal.hidden = false;
      setModalLock(true);
    }

    function closeSizeGuide() {
      if (!modal) return;
      modal.hidden = true;
      setModalLock(false);
    }

    function closePanel() {
      if (!openFace) return;
      openFace.classList.remove('hpc-quickadd-open');
      openFace = null;
    }

    function openPanel(face) {
      if (openFace && openFace !== face) openFace.classList.remove('hpc-quickadd-open');
      openFace = face;
      face.classList.add('hpc-quickadd-open');
    }

    function addVariant(variantId, buttonEl) {
      if (!variantId) return;
      if (buttonEl) buttonEl.disabled = true;

      const formData = new FormData();
      formData.append('id', variantId);
      formData.append('quantity', '1');
      formData.append('sections', 'cart-drawer,cart-icon-bubble');
      formData.append('sections_url', window.location.pathname);

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', Accept: 'application/json' },
        body: formData
      })
        .then((response) => response.json())
        .then((response) => {
          if (response.status) return;
          return fetch('/?sections=cart-drawer,cart-icon-bubble&_=' + Date.now(), { cache: 'no-store' })
            .then((r) => r.json())
            .then((data) => {
              const liveDrawer = document.querySelector('cart-drawer');
              if (!liveDrawer) return;

              const html = data && data['cart-drawer'];
              if (html) {
                const doc = new DOMParser().parseFromString(html, 'text/html');
                const newDrawer = doc.querySelector('cart-drawer');
                if (newDrawer) {
                  liveDrawer.innerHTML = newDrawer.innerHTML;
                  liveDrawer.className = newDrawer.className;
                }
              }

              const bubbleHtml = data && data['cart-icon-bubble'];
              if (bubbleHtml) {
                const bubbleContainer = document.getElementById('cart-icon-bubble');
                if (bubbleContainer) {
                  const doc = new DOMParser().parseFromString(bubbleHtml, 'text/html');
                  const newBubble = doc.getElementById('cart-icon-bubble');
                  if (newBubble) bubbleContainer.innerHTML = newBubble.innerHTML;
                }
              }

              if (typeof liveDrawer.open === 'function') {
                liveDrawer.open();
              } else {
                liveDrawer.classList.add('active');
                liveDrawer.setAttribute('open', '');
                document.body.classList.add('overflow-hidden');
              }
            });
        })
        .catch(() => {})
        .finally(() => {
          if (buttonEl) buttonEl.disabled = false;
        });
    }

    section.querySelectorAll('[data-face]').forEach((face) => {
      const trigger = face.querySelector('[data-hpc-qa-trigger]');
      const panel = face.querySelector('[data-hpc-qa-panel]');
      if (!trigger || !panel) return;

      ['pointerdown', 'mousedown', 'touchstart'].forEach((evtName) => {
        trigger.addEventListener(evtName, (e) => {
          if (evtName !== 'touchstart') e.preventDefault();
          e.stopPropagation();
        }, { passive: false });
      });

      trigger.addEventListener('touchend', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (face.classList.contains('hpc-quickadd-open')) closePanel();
        else openPanel(face);
      }, { passive: false });

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (face.classList.contains('hpc-quickadd-open')) closePanel();
        else openPanel(face);
      });

      panel.querySelectorAll('[data-hpc-qa-size]').forEach((sizeBtn) => {
        sizeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (!face.classList.contains('hpc-quickadd-open')) return;
          addVariant(sizeBtn.getAttribute('data-variant-id'), sizeBtn);
          closePanel();
        });
      });

      const guideBtn = panel.querySelector('[data-hpc-open-size-guide]');
      if (guideBtn) {
        guideBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (!face.classList.contains('hpc-quickadd-open')) return;
          closePanel();
          openSizeGuide();
        });
      }
    });

    section.addEventListener('click', (e) => {
      const insideQuickAdd = e.target.closest('[data-hpc-qa-trigger]') || e.target.closest('[data-hpc-qa-panel]');
      if (!insideQuickAdd) closePanel();
    });

    section.addEventListener('hpc:changed', () => {
      closePanel();
    });

    if (modal) {
      modalCloseEls.forEach((el) => {
        el.addEventListener('click', () => {
          closeSizeGuide();
          closePanel();
        });
      });

      const popup = modal.querySelector('.hex-prism-carousel__size-guide-popup');
      modal.addEventListener('click', (e) => {
        if (!popup) return;
        if (!popup.contains(e.target)) {
          closeSizeGuide();
          closePanel();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.hidden) {
          closeSizeGuide();
          closePanel();
        }
      });

      modal.addEventListener('touchmove', (e) => {
        if (window.matchMedia('(max-width: 768px)').matches) {
          e.preventDefault();
        }
      }, { passive: false });
    }
  })();
</script>

<script>
  (function() {
    const sectionId = '{{ section_id }}';
    const section = document.querySelector(`[data-section-id="${sectionId}"]`);
    if (!section) return;

    function getIconNodes() {
      return Array.from(section.querySelectorAll('[data-hpc-side-icon-json]'));
    }

    function renderLottieIcons() {
      if (!window.lottie || typeof window.lottie.loadAnimation !== 'function') return;
      getIconNodes().forEach((node) => {
        const jsonUrl = node.getAttribute('data-hpc-side-icon-json');
        if (!jsonUrl) return;
        if (node.__hpcLottieAnim && typeof node.__hpcLottieAnim.destroy === 'function') {
          node.__hpcLottieAnim.destroy();
        }
        node.innerHTML = '';
        node.__hpcLottieAnim = window.lottie.loadAnimation({
          container: node,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path: jsonUrl,
          rendererSettings: { preserveAspectRatio: 'xMidYMid meet' }
        });
      });
    }

    function loadLottieLibraryAndRender() {
      if (!getIconNodes().length) return;

      if (window.lottie && typeof window.lottie.loadAnimation === 'function') {
        renderLottieIcons();
        return;
      }

      if (!window.__hpcLottieLoaderPromise) {
        window.__hpcLottieLoaderPromise = new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = 'https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js';
          script.async = true;
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }

      window.__hpcLottieLoaderPromise.then(renderLottieIcons).catch(() => {});
    }

    function destroyLottieIcons() {
      getIconNodes().forEach((node) => {
        if (node.__hpcLottieAnim && typeof node.__hpcLottieAnim.destroy === 'function') {
          node.__hpcLottieAnim.destroy();
          node.__hpcLottieAnim = null;
        }
        node.innerHTML = '';
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadLottieLibraryAndRender);
    } else {
      loadLottieLibraryAndRender();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === sectionId) {
        loadLottieLibraryAndRender();
      }
    });

    document.addEventListener('shopify:section:unload', function(e) {
      if (e.detail.sectionId === sectionId) {
        destroyLottieIcons();
      }
    });
  })();
</script>

