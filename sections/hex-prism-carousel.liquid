<script>
  (function() {
    'use strict';
    
    const sectionId = '{{ section_id }}';
    const section = document.querySelector(`[data-section-id="${sectionId}"]`);
    if (!section) return;
    
    const prism = section.querySelector('[data-prism]');
    const scene = section.querySelector('.hex-prism-carousel__scene--' + sectionId);
    const faces = Array.from(section.querySelectorAll('[data-face]'));
    
    if (!prism || faces.length === 0) return;
    
    let rotationIndex = 0;
    let activeIndex = 0;
    let isDragging = false;
    let startX = 0;
    let startY = 0;
    let currentX = 0;
    let dragOffset = 0;
    let swipeDirection = null; // 'horizontal' or 'vertical' or null
    let isTransitionLocked = false;
    let transitionUnlockTimer = null;
    const supportsPointerEvents = typeof window.PointerEvent !== 'undefined';
    const prefersTouchInput = window.matchMedia('(hover: none), (pointer: coarse)').matches || (navigator.maxTouchPoints || 0) > 0;
    const usePointerDragHandlers = supportsPointerEvents;
    const useTouchDragHandlers = !supportsPointerEvents;
    const useTouchMoveLock = supportsPointerEvents && prefersTouchInput;
    const swipeInputCooldownMs = 120;
    const gestureLockThresholdPx = 4;
    const numFaces = faces.length;
    const degPerFace = 360 / numFaces;
    const filterWrap = section.querySelector('[data-filters]');
    const chips = filterWrap ? Array.from(filterWrap.querySelectorAll('[data-age-filter]')) : [];
    const resetBtn = filterWrap ? filterWrap.querySelector('[data-age-reset]') : null;
    let activeFilter = 'all';
    
    function mod(n, m) {
      return ((n % m) + m) % m;
    }

    function detectSwipeDirection(deltaX, deltaY) {
      if (deltaX < gestureLockThresholdPx && deltaY < gestureLockThresholdPx) return null;
      return deltaX >= deltaY ? 'horizontal' : 'vertical';
    }
    
    function faceMatchesFilter(faceEl, filterValue) {
      if (!filterValue || filterValue === 'all') return true;
      const raw = (faceEl.getAttribute('data-ages') || '').toLowerCase();
      if (!raw) return false;
      const list = raw.split(',').map(s => s.trim()).filter(Boolean);
      return list.includes(String(filterValue).toLowerCase());
    }
    
    function applyFilter() {
      faces.forEach(face => {
        const match = faceMatchesFilter(face, activeFilter);
        face.setAttribute('data-filtered', match ? 'false' : 'true');
      });
    }
    
    function getWrappedDiff(faceIndex, activeIndex) {
      let diff = faceIndex - activeIndex;
      if (diff > numFaces / 2) diff -= numFaces;
      if (diff < -numFaces / 2) diff += numFaces;
      return diff;
    }
    
    function updateUI() {
      activeIndex = mod(rotationIndex, numFaces);
      
      const rotation = -rotationIndex * degPerFace;
      prism.style.setProperty('--rot', `${rotation}deg`);
      
      faces.forEach((face, index) => {
        const diff = getWrappedDiff(index, activeIndex);
        const absDiff = Math.abs(diff);
        
        if (diff === 0) {
          face.setAttribute('data-state', 'active');
          face.setAttribute('tabindex', '0');
          face.style.setProperty('--z', '18px');
        } else if (absDiff === 1) {
          face.setAttribute('data-state', 'side');
          face.setAttribute('tabindex', '-1');
          face.style.setProperty('--z', '6px');
        } else if (absDiff === 2) {
          face.setAttribute('data-state', 'side2');
          face.setAttribute('tabindex', '-1');
          face.style.setProperty('--z', '0px');
        } else {
          face.setAttribute('data-state', 'far');
          face.setAttribute('tabindex', '-1');
          face.style.setProperty('--z', '-40px');
        }
      });

      section.dispatchEvent(new CustomEvent('hpc:changed', { detail: { activeIndex } }));
    }

    function lockTransition() {
      isTransitionLocked = true;
      if (transitionUnlockTimer) clearTimeout(transitionUnlockTimer);
      transitionUnlockTimer = setTimeout(() => {
        isTransitionLocked = false;
      }, swipeInputCooldownMs);
    }
    
    function goNext() {
      if (numFaces <= 1 || isTransitionLocked) return;
      lockTransition();
      for (let i = 0; i < numFaces; i++) {
        rotationIndex += 1;
        const idx = mod(rotationIndex, numFaces);
        if (faceMatchesFilter(faces[idx], activeFilter)) break;
      }
      
      updateUI();
    }
    
    function goPrev() {
      if (numFaces <= 1 || isTransitionLocked) return;
      lockTransition();
      for (let i = 0; i < numFaces; i++) {
        rotationIndex -= 1;
        const idx = mod(rotationIndex, numFaces);
        if (faceMatchesFilter(faces[idx], activeFilter)) break;
      }
      
      updateUI();
    }
    
    function handlePointerDown(e) {
      if (numFaces <= 1) return;
      if (!scene || !scene.contains(e.target)) return;
      if (e.target.closest('[data-hpc-qa-trigger]') || e.target.closest('[data-hpc-qa-panel]') || e.target.closest('[data-hpc-open-size-guide]') || e.target.closest('[data-hpc-size-guide-modal]')) return;
      if (typeof e.button === 'number' && e.button !== 0) return;
      if (e.touches && e.touches.length > 1) return;
      
      isDragging = true;
      startX = e.touches ? e.touches[0].clientX : e.clientX;
      startY = e.touches ? e.touches[0].clientY : e.clientY;
