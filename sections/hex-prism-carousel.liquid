        const threshold = section.dataset.faceWidth ? parseFloat(section.dataset.faceWidth) * 0.06 : 24;
        const wasDrag = Math.abs(dragOffset) > threshold;
        
        if (wasDrag) {
          if (e.cancelable) {
            e.preventDefault();
          }
          e.stopPropagation();
          if (dragOffset > 0) {
            goPrev();
          } else {
            goNext();
          }
        }
      }
      // If vertical, do nothing - browser already handled scrolling
      
      // Always reset state
      isDragging = false;
      section.style.cursor = '';
      section.style.userSelect = '';
      swipeDirection = null;
      dragOffset = 0;
    }
    
    function handleClick(e) {
      if (e.target.closest('[data-hpc-qa-trigger]') || e.target.closest('[data-hpc-qa-panel]') || e.target.closest('[data-hpc-open-size-guide]') || e.target.closest('[data-hpc-size-guide-modal]')) {
        return;
      }

      const faceLink = e.target.closest('[data-face]');
