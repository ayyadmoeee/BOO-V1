<script>
  // Immediately stop any GIFs and videos on page load (except in active slide)
  (function() {
    const sectionId = '{{ section_id }}';
    const section = document.querySelector(`#CenterProductCarousel-${sectionId}`);
    if (section) {
      const allSlides = section.querySelectorAll('.cpc-slide');
      allSlides.forEach((slide) => {
        // Only stop GIFs and videos in non-active slides
        if (!slide.classList.contains('is-active')) {
          // Stop GIFs
          const gifImages = slide.querySelectorAll('.cpc-gif-image[data-gif-url]');
          gifImages.forEach((img) => {
            const gifUrl = img.dataset.gifUrl;
            const placeholderUrl = img.dataset.placeholderUrl;
            if (gifUrl && placeholderUrl) {
              const baseGifUrl = gifUrl.split('?')[0].split('#')[0];
              // If it's showing the GIF, swap to placeholder
              if (img.src.includes(baseGifUrl)) {
                img.src = placeholderUrl;
              }
            }
          });
          // Stop videos
          const videos = slide.querySelectorAll('.cpc-card-video');
          videos.forEach((video) => {
            video.pause();
            video.currentTime = 0;
          });
        }
      });
    }
  })();
</script>

<script>
  (function () {
    'use strict';

    const sectionId = '{{ section_id }}';
    const section = document.querySelector(`#CenterProductCarousel-${sectionId}`);
    if (!section) return;

    const viewport = section.querySelector('[data-viewport]');
    const track = section.querySelector('[data-track]');
    const prevBtn = section.querySelector('.cpc-arrow--prev');
    const nextBtn = section.querySelector('.cpc-arrow--next');
    const dots = Array.from(section.querySelectorAll('[data-dot-index]'));

    const autoplayEnabled = section.dataset.autoplay === 'true';
    const autoplayDelay = (parseInt(section.dataset.autoplayDelay, 10) || 5) * 1000;

    if (!track || !viewport) return;

    // MOBILE DETECTION - Check if we're on mobile (≤ 749px)
    const mobileMediaQuery = window.matchMedia('(max-width: 749px)');
    let isMobile = mobileMediaQuery.matches;
    
    // Update isMobile on resize
    function updateMobileState() {
      isMobile = mobileMediaQuery.matches;
    }
    mobileMediaQuery.addEventListener('change', updateMobileState);

    function applyScrollSnapMode() {
      if (!track) return;
      // Desktop uses scripted centering; keep snap disabled to avoid post-animation kickback.
      track.style.scrollSnapType = isMobile ? 'x proximity' : 'none';
    }

    let originalSlides = [];
    let slides = [];
    let originalCount = 0;
    let clonesCount = 0;
    let currentIndex = 0;
    let currentRealIndex = 0;
    let autoplayTimer = null;
    let isPaused = false;
    let scrollRaf = null;
    let isScrolling = false;
    let lastScrollEventAt = 0;
    let isCorrecting = false;
    let isProgrammaticScroll = false;
    let programmaticScrollTimer = null;
    let isArrowNavigation = false;
    let isDragging = false;
    let lastScrollLeft = 0;
    let lastVideoRealIndex = -1;
    let lastGifRealIndex = -1;
    let isInertia = false;

    function normalizeToMiddleCopy() {
      if (!slides.length || originalCount <= 1) return;

      const closestReal = getClosestIndexToCenter();
      let corrected = closestReal;

      if (closestReal < clonesCount) {
        const offsetInPre = ((closestReal % originalCount) + originalCount) % originalCount;
        corrected = clonesCount + offsetInPre;
      } else if (closestReal >= clonesCount + originalCount) {
        const offsetInPost = ((closestReal - clonesCount - originalCount) % originalCount + originalCount) % originalCount;
        corrected = clonesCount + offsetInPost;
      }

      if (corrected !== closestReal) {
        silentRebaseToRealIndex(corrected);
      }

      currentRealIndex = corrected;
      currentIndex = getOriginalIndexByReal(corrected);
      // Mobile finalizes active state in settleScroll() only.
      if (!isMobile) {
        setActiveByRealIndex(corrected);
      }
      updateDots();
    }

    function lockProgrammaticScroll(duration = 700) {
      isProgrammaticScroll = true;
      if (programmaticScrollTimer) {
        clearTimeout(programmaticScrollTimer);
        programmaticScrollTimer = null;
      }

      programmaticScrollTimer = setTimeout(() => {
        isProgrammaticScroll = false;
        programmaticScrollTimer = null;
        // Arrow navigation finalizes at animation completion; avoid second settle recenter pass.
        if (!isArrowNavigation) {
          // Final sync after scripted scroll completes (desktop only).
          scheduleSettle();
        }
      }, duration);
    }

    function ensureSingleActiveSlide() {
      if (!slides.length) return;
      const activeSlides = section.querySelectorAll('.cpc-slide.is-active');
      const centeredIndex = Math.max(0, Math.min(slides.length - 1, getClosestIndexToCenter()));
      if (activeSlides.length === 1) {
        const activeIndex = slides.indexOf(activeSlides[0]);
        if (activeIndex === centeredIndex) return;
      }
      setActiveByRealIndex(centeredIndex);
    }

    // IntersectionObserver removed - mobile now uses scroll-based detection like desktop

    function getSlidesPerView() {
      if (window.matchMedia('(min-width: 990px)').matches) return 3;
      if (window.matchMedia('(min-width: 750px)').matches) return 2;
      return 1;
    }

    /**
     * Get closest slide to center using scroll position and offsets (not getBoundingClientRect)
     * This is reliable even with CSS transforms and cloned slides
     */
    function getClosestIndexToCenter() {
      if (slides.length === 0) return 0;

      const scrollLeft = track.scrollLeft;
      const trackCenter = track.offsetWidth / 2;
      const viewportCenter = scrollLeft + trackCenter;

      let closestIndex = 0;
      let closestDistance = Infinity;

      slides.forEach((slide, index) => {
        // Use offsetLeft + offsetWidth/2 to get slide center position
        // This is unaffected by CSS transforms
        const slideLeft = slide.offsetLeft;
        const slideWidth = slide.offsetWidth;
        const slideCenter = slideLeft + slideWidth / 2;
        
        // Calculate distance from viewport center to slide center
        const distance = Math.abs(viewportCenter - slideCenter);
        
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      return closestIndex;
    }

    function getOriginalIndexByReal(realIndex) {
      const s = slides[realIndex];
      const v = s ? parseInt(s.dataset.originalIndex || '0', 10) : 0;
      return Number.isNaN(v) ? 0 : v;
    }

    function getRealIndex(originalIndex) {
      return clonesCount + originalIndex;
    }

    /**
     * Set active slide - ensures exactly ONE slide has .is-active at all times.
     * Prevents class churn by never removing/re-adding on the already-active target.
     */
    function forceActiveSlide(targetSlide) {
      if (!targetSlide) return;
      slides.forEach((slide) => {
        slide.classList.toggle('is-active', slide === targetSlide);
      });
    }

    function setActiveByRealIndex(realIndex) {
      if (isProgrammaticScroll) return;
      // Clamp to valid range
      realIndex = Math.max(0, Math.min(slides.length - 1, realIndex));

      const targetSlide = slides[realIndex];
      if (!targetSlide) return;

      const activeSlides = slides.filter((slide) => slide.classList.contains('is-active'));
      if (activeSlides.length === 1 && activeSlides[0] === targetSlide) {
        return;
      }

      // If target is already active but duplicates exist, only remove extras.
      if (targetSlide.classList.contains('is-active')) {
        slides.forEach((slide) => {
          if (slide !== targetSlide) slide.classList.remove('is-active');
        });
        return;
      }

      // Activate target once, remove all others.
      slides.forEach((slide) => {
        slide.classList.toggle('is-active', slide === targetSlide);
      });

      // Preload GIF for active slide immediately (in background, doesn't display yet)
      if (!isDragging && !isInertia) {
        const gifImages = targetSlide.querySelectorAll('.cpc-gif-image[data-gif-url]');
        gifImages.forEach((img) => {
          const gifUrl = img.dataset.gifUrl;
          if (gifUrl) {
            // Preload in background for faster display when scroll settles
            preloadGif(gifUrl);
          }
        });
      }
    }

    /**
     * Preload GIF in background (doesn't display it, just loads into browser cache)
     */
    function preloadGif(gifUrl) {
      if (!gifUrl) return;
      const link = document.createElement('link');
      link.rel = 'preload';
      link.as = 'image';
      link.href = gifUrl;
      document.head.appendChild(link);
      // Remove after a short delay to clean up
      setTimeout(() => {
        if (link.parentNode) {
          link.parentNode.removeChild(link);
        }
      }, 1000);
    }

    /**
     * VIDEO PLAYBACK CONTROL: Only ONE video plays at a time, only on centered slide, only after scroll settles
     * 
     * This function is called:
     * - After scroll settles (in settleScroll() and correctPosition())
     * - When active slide changes (via setActiveByRealIndex() -> scheduleSettle())
     * 
     * It ensures:
     * - All videos are paused during drag/inertia
     * - Only the center (active) slide's video plays
     * - Videos reset to start (currentTime = 0) when switching slides
     * 
     * @param {number} realIndex - The real index of the slide that should have its video playing
     */
    function updateCenterVideo(realIndex) {
      if (isCorrecting) return;
      // Lock video during drag or inertia - pause all videos
      if (isDragging || isInertia) {
        pauseAllVideos(false);
        return;
      }

      // Now play video ONLY for the centered slide
      if (realIndex < 0 || realIndex >= slides.length) return;
      const centerSlide = slides[realIndex];
      if (!centerSlide) return;

      const centerVideos = Array.from(centerSlide.querySelectorAll('.cpc-card-video'));
      // If still on same index, only skip when center video is already healthy/playing.
      if (realIndex === lastVideoRealIndex) {
        const shouldResync = centerVideos.some((video) => video.paused || video.readyState < 2);
        if (!shouldResync) return;
      }

      if (!isMobile) {
        // Desktop: enforce strict single-video playback across all clones.
        const allVideos = Array.from(section.querySelectorAll('.cpc-card-video'));
        allVideos.forEach((video) => {
          if (!centerVideos.includes(video)) {
            video.pause();
          }
        });
      } else {
        // Mobile: lightweight path to reduce per-frame work.
        const previousRealIndex = lastVideoRealIndex;
        if (
          previousRealIndex >= 0 &&
          previousRealIndex < slides.length &&
          previousRealIndex !== realIndex
        ) {
          const previousSlide = slides[previousRealIndex];
          if (previousSlide) {
            const previousVideos = previousSlide.querySelectorAll('.cpc-card-video');
            previousVideos.forEach((video) => video.pause());
          }
        }
      }

      // Preload adjacent videos for faster switching
      preloadAdjacentVideos(realIndex);

      lastVideoRealIndex = realIndex;

      const videos = centerVideos;
      videos.forEach((video) => {
        const tryPlay = () => {
          if (!isDragging && !isInertia && !isCorrecting && video.paused) {
            video.play().catch(() => {});
          }
        };

        // Ensure video is set to preload auto for faster loading
        if (video.preload !== 'auto') {
          video.preload = 'auto';
        }
        video.muted = true;
        video.playsInline = true;
        
        // If video has enough data loaded (readyState >= 2 means HAVE_CURRENT_DATA), play immediately
        if (video.readyState >= 2) {
          tryPlay();
        } else if (video.readyState >= 1) {
          // HAVE_METADATA - video metadata loaded, wait for data
          const onCanPlay = () => {
            video.removeEventListener('canplay', onCanPlay);
            video.removeEventListener('loadeddata', onCanPlay);
            tryPlay();
          };
          video.addEventListener('canplay', onCanPlay, { once: true });
          video.addEventListener('loadeddata', onCanPlay, { once: true });
          // Force fetch of playable data (some browsers stay at metadata-only).
          try { video.load(); } catch (e) {}
          setTimeout(() => {
            if (video.readyState >= 2) tryPlay();
          }, 350);
        } else {
          // Video hasn't started loading - force load
          const onCanPlay = () => {
            video.removeEventListener('canplay', onCanPlay);
            video.removeEventListener('loadeddata', onCanPlay);
            tryPlay();
          };
          video.addEventListener('canplay', onCanPlay, { once: true });
          video.addEventListener('loadeddata', onCanPlay, { once: true });
          
          // Force load immediately
          try { video.load(); } catch (e) {}
          setTimeout(() => {
            if (video.readyState >= 2) tryPlay();
          }, 450);
        }
      });
    }
    
    // Preload videos for adjacent slides (next and previous) for instant switching
    function preloadAdjacentVideos(centerIndex) {
      const preloadIndices = isMobile
        ? [centerIndex - 1, centerIndex + 1]
        : [centerIndex - 1, centerIndex + 1, centerIndex - 2, centerIndex + 2];
      
      preloadIndices.forEach((idx) => {
        if (idx >= 0 && idx < slides.length) {
          const slide = slides[idx];
          if (slide) {
            const videos = slide.querySelectorAll('.cpc-card-video');
            videos.forEach((video) => {
              if (video.preload !== 'auto') {
                video.preload = 'auto';
              }
              if (video.readyState === 0) {
                video.load();
              }
            });
          }
        }
      });
    }

    /**
     * Pause all videos in the section and reset their currentTime
     */
    function pauseAllVideos(resetTime = false) {
      const allVideos = section.querySelectorAll('.cpc-card-video');
      allVideos.forEach((video) => {
        video.pause();
        if (resetTime) video.currentTime = 0;
      });
    }

    /**
     * STRICT GIF CONTROL: Only ONE GIF plays at a time, only on centered slide, only after scroll settles
     * @param {number} realIndex - The real index of the slide that should have its GIF playing
     */
    function updateCenterGif(realIndex) {
      if (isCorrecting) return;
      // Lock GIF during drag or inertia
      if (isDragging || isInertia) return;
      if (realIndex === lastGifRealIndex) return;

      if (!isMobile) {
        // Desktop: enforce strict single-GIF playback across all clones.
        const allGifImages = section.querySelectorAll('.cpc-gif-image[data-gif-url]');
        allGifImages.forEach((img) => {
          const gifUrl = img.dataset.gifUrl;
          const placeholderUrl = img.dataset.placeholderUrl;
          if (!gifUrl || !placeholderUrl) return;
          const baseGifUrl = gifUrl.split('?')[0].split('#')[0];
          if (img.src && img.src.includes(baseGifUrl)) {
            img.src = placeholderUrl;
            img.removeAttribute('srcset');
          }
        });
      } else if (lastGifRealIndex >= 0 && lastGifRealIndex < slides.length) {
        // Mobile: reset only the previous active slide.
        const previousSlide = slides[lastGifRealIndex];
        if (previousSlide) {
          const previousGifImages = previousSlide.querySelectorAll('.cpc-gif-image[data-gif-url]');
          previousGifImages.forEach((img) => {
            const gifUrl = img.dataset.gifUrl;
            const placeholderUrl = img.dataset.placeholderUrl;
            if (!gifUrl || !placeholderUrl) return;
            const baseGifUrl = gifUrl.split('?')[0].split('#')[0];
            if (img.src && img.src.includes(baseGifUrl)) {
              img.src = placeholderUrl;
              img.removeAttribute('srcset');
            }
          });
        }
      }

      // Start GIF only for the centered slide
      if (realIndex >= 0 && realIndex < slides.length) {
        const centerSlide = slides[realIndex];
        if (centerSlide) {
          const gifImages = centerSlide.querySelectorAll('.cpc-gif-image[data-gif-url]');
          gifImages.forEach((img) => {
            const gifUrl = img.dataset.gifUrl;
            const placeholderUrl = img.dataset.placeholderUrl;
            
            if (gifUrl && placeholderUrl) {
              img.src = gifUrl;
            }
          });
        }
      }

      lastGifRealIndex = realIndex;
    }

    function updateDots() {
      // Dots removed - no-op
    }

    // Simple debounce settle engine
    let settleTimer = null;
    let settleRaf = null;
    function getSettleDelay() {
      return window.matchMedia('(max-width: 749px)').matches ? 50 : 90; // ms
    }
    const SETTLE_DELAY = 90; // ms

    /**
     * Schedule settle - finalizes loop correction + GIF after scroll stops
     */
    function scheduleSettle() {
      if (isCorrecting) return;
      if (isMobile) {
        // Mobile: native snap is the only centering authority.
        // Finalize active state on next frame (no delayed timer loops).
        if (settleRaf) cancelAnimationFrame(settleRaf);
        settleRaf = requestAnimationFrame(() => {
          settleRaf = null;
          if (isCorrecting || isDragging || isInertia) return;
          settleScroll();
        });
        return;
      }
      if (isProgrammaticScroll) return;
      if (isArrowNavigation) return;
      clearTimeout(settleTimer);
      const delay = getSettleDelay();
      settleTimer = setTimeout(() => {
        if (isArrowNavigation || isDragging || isInertia || isCorrecting || isProgrammaticScroll) return;
        // finalize: loop correction + gif
        settleScroll();
      }, delay);
    }

    // rAF active preview updater - desktop-only live preview during scroll.
    // Mobile uses settleScroll() as single source of truth to prevent double activation flicker.
    let activeRaf = null;
    function scheduleActivePreview() {
      if (isMobile) {
        if (activeRaf) {
          cancelAnimationFrame(activeRaf);
          activeRaf = null;
        }
        return;
      }
      if (isCorrecting) return;
      if (isArrowNavigation) return;
      if (isProgrammaticScroll) return;
      if (activeRaf) return;
      activeRaf = requestAnimationFrame(() => {
        activeRaf = null;
        if (!slides.length || isCorrecting || isArrowNavigation || isProgrammaticScroll) return; // Skip during correction/locked/programmatic scroll

        // compute closest index based on current scrollLeft
        const idx = getClosestIndexToCenter();

        if (idx !== currentRealIndex) {
          currentRealIndex = idx;
          currentIndex = getOriginalIndexByReal(idx);
          setActiveByRealIndex(idx); // THIS makes the "push up" immediate
          updateDots();
        }
      });
    }

    // setupMobileObserver removed - mobile now uses scroll-based detection like desktop

    /**
     * Process scroll settle - handle correction, final active state, video, and GIF.
     * Mobile finalizes active state here (single source of truth).
     * Desktop still previews during scroll, then confirms here.
     *
     * VIDEO CONTROL: updateCenterVideo() is called here to ensure only the center slide's video plays
     * after scroll settles. This reuses the existing active-slide detection from getClosestIndexToCenter()
     */
    function settleScroll() {
      if (!isMobile && isArrowNavigation) return;
      // Compute centered slide using scroll position (reliable with transforms)
      const centeredIndex = getClosestIndexToCenter();
      
      // Handle infinite loop correction if needed (works for both mobile and desktop)
      let needsCorrection = false;
      
      if (centeredIndex < clonesCount) {
        // In prepended copies - jump to corresponding position in middle copy
        needsCorrection = true;
      } else if (centeredIndex >= clonesCount + originalCount) {
        // In appended copies - jump to corresponding position in middle copy
        needsCorrection = true;
      }
      
      // If correction needed, handle it (desktop only).
      if (!isMobile && needsCorrection) {
        correctPosition();
      } else {
        // Finalize active state once per mode:
        // - Mobile: settle is the only authority.
        // - Desktop: preview already ran during user scroll; settle only enforces a single active slide.
        currentRealIndex = centeredIndex;
        currentIndex = getOriginalIndexByReal(centeredIndex);
        if (isMobile) {
          setActiveByRealIndex(centeredIndex);
        } else {
          ensureSingleActiveSlide();
        }
        updateDots();
        updateCenterVideo(centeredIndex);
        updateCenterGif(centeredIndex);
      }
    }

    /**
     * Handle scroll events - instantly update active state, schedule settle for correction + GIF
     * Works on both mobile and desktop using scroll-based center detection
     */
    function onScroll() {
      // Skip during correction to prevent stutter
      if (isCorrecting || (!isMobile && isArrowNavigation)) return;
      if (!isMobile && isProgrammaticScroll) return;
      lastScrollEventAt = performance.now();
      
      if (isDragging || isInertia) {
        scheduleActivePreview();
        // no settle while dragging/inertia
        return;
      }
      // Mobile: keep active state settle-driven to prevent card-to-card jumping while swiping.
      if (isMobile) {
        scheduleSettle();
        return;
      }
      scheduleActivePreview();
      scheduleSettle();
    }

    /**
     * Correct position when in cloned regions - instant jump without fighting animation
     */
    function correctPosition() {
      // Mobile relies on native scrolling/snap only; no JS correction.
      if (isMobile) return;
      if (isArrowNavigation) return;
      // Desktop correction path only.
      if (isCorrecting || slides.length === 0) return;
      if (isProgrammaticScroll) return;
      
      // Use scroll position-based detection (reliable with transforms)
      const closestReal = getClosestIndexToCenter();
      let corrected = closestReal;
      let needsJump = false;
      
      // With 3 copies per side, we have: [PRE x3] + [MIDDLE] + [POST x3]
      // Middle starts at clonesCount, ends at clonesCount + originalCount
      if (closestReal < clonesCount) {
        // In prepended copies - jump to corresponding position in middle copy
        const offsetInPre = closestReal % originalCount;
        corrected = clonesCount + offsetInPre;
        needsJump = true;
      } else if (closestReal >= clonesCount + originalCount) {
        // In appended copies - jump to corresponding position in middle copy
        const offsetInPost = (closestReal - clonesCount - originalCount) % originalCount;
        corrected = clonesCount + offsetInPost;
        needsJump = true;
      }
      
      // Only jump if we're actually in a clone region
      if (needsJump) {
        // Hard-lock one active slide immediately before any correction work.
        const lockedActiveSlide =
          section.querySelector('.cpc-slide.is-active') ||
          slides[Math.max(0, Math.min(slides.length - 1, closestReal))] ||
          slides[Math.max(0, Math.min(slides.length - 1, corrected))];
        forceActiveSlide(lockedActiveSlide);

        isCorrecting = true;
        clearTimeout(settleTimer);
        if (activeRaf) {
          cancelAnimationFrame(activeRaf);
          activeRaf = null;
        }
        
        // Disable transitions on all slides during correction to prevent stutter.
        slides.forEach(slide => slide.classList.add('is-correcting'));
        
        const target = slides[corrected];
        if (target) {
          const originalScrollSnapType = track.style.scrollSnapType;
          const originalScrollBehavior = track.style.scrollBehavior;

          track.style.scrollBehavior = 'auto';
          
          // Pause all videos during correction to prevent stutter
          pauseAllVideos(false);
          
          requestAnimationFrame(() => {
            track.scrollTo({
              left: target.offsetLeft - (track.offsetWidth / 2) + (target.offsetWidth / 2),
              behavior: 'auto'
            });
            
            // Wait 1 rAF for jump to complete
            requestAnimationFrame(() => {
              if (!section.querySelector('.cpc-slide.is-active') && lockedActiveSlide) {
                lockedActiveSlide.classList.add('is-active');
              }
              // Update indices and active state
              currentRealIndex = corrected;
              currentIndex = getOriginalIndexByReal(corrected);
              // During correction, bypass programmatic guard and atomically switch to corrected target.
              forceActiveSlide(target);
              updateDots();
              
              // Re-enable transitions after correction
              slides.forEach(slide => slide.classList.remove('is-correcting'));
              
              // Restore scroll behavior
              track.style.scrollSnapType = originalScrollSnapType || '';
              track.style.scrollBehavior = originalScrollBehavior || '';
              
              // Correction is a safe enforcement point on desktop.
              setTimeout(() => {
                isCorrecting = false;
                updateCenterVideo(corrected);
                updateCenterGif(corrected);
                ensureSingleActiveSlide();
              }, 50);
            });
          });
        } else {
          slides.forEach(slide => slide.classList.remove('is-correcting'));
          isCorrecting = false;
        }
      } else {
        // Already in middle copy - keep media in sync, no extra active enforcement here.
        updateCenterVideo(corrected);
        updateCenterGif(corrected);
      }
    }

    // --- Controlled snap animation (prevents jitter + too-fast snapping) ---
    let snapRaf = null;

    function cancelSnap() {
      if (snapRaf) cancelAnimationFrame(snapRaf);
      snapRaf = null;
    }

    // quintic ease in/out - smoother, more premium feel
    function easeInOutQuintic(t) {
      return t < 0.5 ? 16 * t * t * t * t * t : 1 - Math.pow(-2 * t + 2, 5) / 2;
    }

    function animateScrollLeft(toLeft, duration = 420) {
      // MOBILE: Disable programmatic scrolling - let native snap handle it
      if (isMobile) {
        // On mobile, just let native scroll-snap handle centering
        return;
      }

      // DESKTOP: Original animation logic
      cancelSnap();

      const fromLeft = track.scrollLeft;
      const delta = toLeft - fromLeft;

      if (Math.abs(delta) < 0.5) {
        track.scrollLeft = toLeft;
        scheduleSettle();
        return;
      }

      const start = performance.now();

      // IMPORTANT: disable snap during animation so browser doesn't "kick" it
      const prevSnapType = track.style.scrollSnapType;
      track.style.scrollSnapType = 'none';

      function step(now) {
        const t = Math.min(1, (now - start) / duration);
        track.scrollLeft = fromLeft + delta * easeInOutQuintic(t);

        if (t < 1) {
          snapRaf = requestAnimationFrame(step);
        } else {
          snapRaf = null;
          track.style.scrollSnapType = prevSnapType || '';
          if (isArrowNavigation) {
            // Arrow flow owns finalization: one center, one active commit, no second settle recenter.
            const centeredIndex = getClosestIndexToCenter();
            currentRealIndex = centeredIndex;
            currentIndex = getOriginalIndexByReal(centeredIndex);
            const previousProgrammatic = isProgrammaticScroll;
            isProgrammaticScroll = false;
            setActiveByRealIndex(centeredIndex);
            isProgrammaticScroll = previousProgrammatic;
            ensureSingleActiveSlide();
            updateDots();
            updateCenterVideo(centeredIndex);
            updateCenterGif(centeredIndex);
            isArrowNavigation = false;
            return;
          }
          scheduleSettle();
        }
      }

      snapRaf = requestAnimationFrame(step);
    }

    /**
     * Scroll to centered position - uses controlled rAF animation
     * Mobile and desktop both use offset math for reliable centering
     */
    function scrollToCentered(target, smooth = true, updateState = true) {
      if (!target) return;
      const useArrowLock = !isMobile && smooth;
      const previousArrowNavigation = isArrowNavigation;
      if (useArrowLock) {
        isArrowNavigation = true;
        if (activeRaf) {
          cancelAnimationFrame(activeRaf);
          activeRaf = null;
        }
        clearTimeout(settleTimer);
      }

      const targetRealIndex = slides.indexOf(target);
      if (updateState && targetRealIndex >= 0) {
        currentRealIndex = targetRealIndex;
        currentIndex = getOriginalIndexByReal(targetRealIndex);
        updateDots();
      }

      // Use offset math for reliable centering (works on both mobile and desktop)
      const targetLeft =
        target.offsetLeft - (track.offsetWidth / 2) + (target.offsetWidth / 2);

      // MOBILE: Fast centering without long native smooth-scroll easing
      if (isMobile) {
        track.scrollLeft = targetLeft;
        scheduleSettle();
        return;
      }

      // DESKTOP: Use controlled rAF animation
      if (smooth) {
        lockProgrammaticScroll(700);
        animateScrollLeft(targetLeft, 420);
      } else {
        lockProgrammaticScroll(220);
        cancelSnap();
        track.scrollLeft = targetLeft;
        scheduleActivePreview();
        scheduleSettle();
        if (useArrowLock) {
          isArrowNavigation = previousArrowNavigation;
        }
      }
    }

    function scrollToRealIndex(realIndex, smooth = true) {
      if (slides.length === 0) return;
      
      // Clamp to valid range
      realIndex = Math.max(0, Math.min(slides.length - 1, realIndex));
      const target = slides[realIndex];
      
      if (!target) return;

      if (!isMobile) {
        // Desktop: keep .is-active settle/finalization-owned (no mid-animation pre-activation).
        lockProgrammaticScroll(smooth ? 800 : 250);
      }
      currentRealIndex = realIndex;
      currentIndex = getOriginalIndexByReal(realIndex);
      updateDots();
      
      // Use unified scroll to centered function
      scrollToCentered(target, smooth, false);

      if (autoplayEnabled && !isPaused) resetAutoplay();
    }

    function scrollToOriginalIndex(originalIndex, smooth = true) {
      if (originalCount === 0) return;
      
      originalIndex = ((originalIndex % originalCount) + originalCount) % originalCount;
      const realIndex = getRealIndex(originalIndex);
      scrollToRealIndex(realIndex, smooth);
    }

    function shiftCurrentRealIndexByGroup(offset) {
      if (originalCount <= 0 || slides.length === 0) return currentRealIndex;
      const shifted = currentRealIndex + offset;
      const target = slides[shifted];
      if (!target) return currentRealIndex;

      // Disable transitions during group shift to prevent stutter (desktop only)
      if (!isMobile) {
        slides.forEach(slide => slide.classList.add('is-correcting'));
      }
      
      const prevProgrammatic = isProgrammaticScroll;
      isProgrammaticScroll = true;
      cancelSnap();
      
      // Pause videos during shift
      pauseAllVideos(false);
      
      const targetLeft = target.offsetLeft - (track.offsetWidth / 2) + (target.offsetWidth / 2);
      
      // MOBILE: Use direct assignment for smoother performance
      if (isMobile) {
        track.scrollLeft = targetLeft;
      } else {
        track.scrollLeft = targetLeft;
      }
      
      currentRealIndex = shifted;
      currentIndex = getOriginalIndexByReal(shifted);
      
      // Re-enable transitions after shift completes
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (!isMobile) {
            slides.forEach(slide => slide.classList.remove('is-correcting'));
          }
          // Update video after transition re-enabled
          setTimeout(() => {
            updateCenterVideo(shifted);
          }, isMobile ? 100 : 50);
        });
      });
      
      isProgrammaticScroll = prevProgrammatic;
      return shifted;
    }

    function silentRebaseToRealIndex(realIndex) {
      if (isMobile) return false;
      if (slides.length === 0) return false;
      const target = slides[realIndex];
      if (!target) return false;

      const prevScrollSnapType = track.style.scrollSnapType;
      const prevScrollBehavior = track.style.scrollBehavior;

      isProgrammaticScroll = true;
      track.style.scrollSnapType = 'none';
      track.style.scrollBehavior = 'auto';

      const targetLeft = target.offsetLeft - (track.offsetWidth / 2) + (target.offsetWidth / 2);
      track.scrollLeft = targetLeft;

      currentRealIndex = realIndex;
      currentIndex = getOriginalIndexByReal(realIndex);

      requestAnimationFrame(() => {
        track.style.scrollSnapType = prevScrollSnapType || '';
        track.style.scrollBehavior = prevScrollBehavior || '';
      });

      return true;
    }

    function scrollToPrev() {
      if (isProgrammaticScroll) return;
      if (slides.length <= 1) return;
      if (!isMobile) {
        isArrowNavigation = true;
      }
      const middleStart = clonesCount;
      const nearLeftBoundary = currentRealIndex <= middleStart;
      let baseRealIndex = currentRealIndex;
      if (!isMobile && nearLeftBoundary) {
        const rebased = currentRealIndex + originalCount;
        if (rebased >= 0 && rebased < slides.length && silentRebaseToRealIndex(rebased)) {
          baseRealIndex = rebased;
        }
      }
      const newRealIndex = Math.max(0, baseRealIndex - 1);
      scrollToRealIndex(newRealIndex, true);
    }

    function scrollToNext() {
      if (isProgrammaticScroll) return;
      if (slides.length <= 1) return;
      if (!isMobile) {
        isArrowNavigation = true;
      }
      const middleEnd = clonesCount + originalCount - 1;
      const nearRightBoundary = currentRealIndex >= middleEnd;
      let baseRealIndex = currentRealIndex;
      if (!isMobile && nearRightBoundary) {
        const rebased = currentRealIndex - originalCount;
        if (rebased >= 0 && rebased < slides.length && silentRebaseToRealIndex(rebased)) {
          baseRealIndex = rebased;
        }
      }
      const newRealIndex = Math.min(slides.length - 1, baseRealIndex + 1);
      scrollToRealIndex(newRealIndex, true);
    }

    function startAutoplay() {
      if (!autoplayEnabled || isPaused || originalCount <= 1) return;
      if (autoplayTimer) return;
      autoplayTimer = window.setInterval(() => {
        scrollToNext();
      }, autoplayDelay);
    }

    function pauseAutoplay() {
      isPaused = true;
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function resumeAutoplay() {
      isPaused = false;
      startAutoplay();
    }

    function resetAutoplay() {
      pauseAutoplay();
      resumeAutoplay();
    }

    // ----- Drag / Swipe (reliable + click-safe) -----
    function getDragThreshold() {
      return window.matchMedia('(max-width: 749px)').matches ? 5 : 8;
    }
    const DRAG_START_PX = 8;

    let isPointerDown = false;
    let moved = false;
    let didDrag = false; // true only when drag exceeded DRAG_START_PX; used for click suppression
    let startX = 0;
    let startScrollLeft = 0;

    // rAF-driven scroll scheduler
    let dragRaf = null;
    let pendingScrollLeft = 0;
    let lastMoveX = 0;
    let lastMoveT = 0;
    let velocity = 0; // px/ms
    let inertiaRaf = null;

    // When we drag, suppress link clicks briefly after release
    let suppressClickUntil = 0;

    // Double-tap detection
    let lastTapTime = 0;
    let lastTapTarget = null;
    const DOUBLE_TAP_DELAY = 300; // ms between taps
    const DOUBLE_TAP_DISTANCE = 50; // max pixel distance between taps

    /**
     * Schedule scrollLeft update via rAF for smooth batched updates
     */
    function scheduleScrollLeft(value) {
      pendingScrollLeft = value;
      if (dragRaf) return;
      dragRaf = requestAnimationFrame(() => {
        track.scrollLeft = pendingScrollLeft;
        dragRaf = null;
      });
    }

    /**
     * Stop ALL GIFs and videos in the section (including active slide) during drag
     */
    function stopAllGifsInSection() {
      // Stop GIFs
      const imgs = section.querySelectorAll('.cpc-gif-image[data-gif-url]');
      imgs.forEach(img => {
        const gifUrl = img.dataset.gifUrl;
        const placeholderUrl = img.dataset.placeholderUrl;
        if (!gifUrl || !placeholderUrl) return;
        const base = gifUrl.split('?')[0].split('#')[0];
        if (img.src && img.src.includes(base)) {
          img.src = placeholderUrl;
          img.removeAttribute('srcset');
        }
      });
      // Stop videos
      pauseAllVideos();
      lastVideoRealIndex = -1;
      lastGifRealIndex = -1;
    }

    /**
     * Start inertia scroll after drag release
     */
    function startInertiaScroll() {
      // MOBILE: Disable custom inertia - let native touch momentum handle it
      if (isMobile) {
        return;
      }

      // DESKTOP: Original inertia logic
      cancelSnap();
      
      if (inertiaRaf) cancelAnimationFrame(inertiaRaf);
      isInertia = true;

      const DECAY = 0.95; // per frame-ish
      let lastT = performance.now();

      function step() {
        const now = performance.now();
        const dt = Math.min(32, now - lastT);
        lastT = now;

        // advance scroll
        const next = track.scrollLeft + velocity * dt;
        scheduleScrollLeft(next);

        // Update center highlight during inertia
        scheduleActivePreview();

        // decay velocity
        velocity *= Math.pow(DECAY, dt / 16);

        if (Math.abs(velocity) < 0.03) {
          isInertia = false;
          inertiaRaf = null;

          // snap to nearest slide (smooth)
          const closest = getClosestIndexToCenter();
          const target = slides[closest];
          if (target) scrollToCentered(target, true);

          return;
        }

        inertiaRaf = requestAnimationFrame(step);
      }

      inertiaRaf = requestAnimationFrame(step);
    }

    function handleWheel(e) {
      cancelSnap();
      
      if (originalCount <= 1) return;

      const absX = Math.abs(e.deltaX);
      const absY = Math.abs(e.deltaY);

      const isVerticalIntent = absY > absX && !e.shiftKey;

      // Vertical scroll → PAGE scroll only
      if (isVerticalIntent) {
        e.preventDefault();
        window.scrollBy({
          top: e.deltaY,
          behavior: 'auto'
        });
        return;
      }

      // Horizontal intent → carousel scroll with momentum
      e.preventDefault();
      const delta = absX > 0 ? e.deltaX : e.deltaY;
      
      // Apply momentum multiplier for smoother trackpad scrolling
      const momentumMultiplier = Math.abs(delta) > 10 ? 1.2 : 1;
      track.scrollLeft += delta * momentumMultiplier;
      
      // Update active preview and schedule settle
      scheduleActivePreview();
      scheduleSettle();
    }

    function handlePointerDown(e) {
      // MOBILE: Disable custom drag handling - let native touch scrolling work
      if (isMobile) {
        return;
      }

      // DESKTOP: Original drag handling
      cancelSnap();
      
      if (originalCount <= 1) return;
      if (e.pointerType === 'mouse' && e.button !== 0) return;

      // Don't start drag if clicking on info card link
      const link = e.target.closest('a.cpc-info-card');
      if (link) return; // Let the link handle the click

      // Cancel any ongoing inertia
      if (inertiaRaf) {
        cancelAnimationFrame(inertiaRaf);
        inertiaRaf = null;
        isInertia = false;
      }

      isPointerDown = true;
      moved = false;
      didDrag = false;
      isDragging = false;

      startX = e.clientX;
      startScrollLeft = track.scrollLeft;

      // Reset velocity tracking
      lastMoveX = e.clientX;
      lastMoveT = performance.now();
      velocity = 0;

      // Do NOT start drag mode here: no .is-dragging, no cursor, no capture.
      // Drag starts in handlePointerMove only when movement exceeds DRAG_START_PX.
    }

    function handlePointerMove(e) {
      // MOBILE: Disable custom drag handling
      if (isMobile) return;
      
      // DESKTOP: Original drag handling
      if (!isPointerDown) return;

      const dx = e.clientX - startX;
      const dragThreshold = getDragThreshold();

      // Start drag mode ONLY after movement exceeds threshold (keeps taps as taps)
      if (!moved && Math.abs(dx) > dragThreshold) {
        moved = true;
        didDrag = true;
        isDragging = true;
        stopAllGifsInSection();
        track.classList.add('is-dragging');
        track.style.cursor = 'grabbing';
        track.style.userSelect = 'none';
        try {
          track.setPointerCapture(e.pointerId);
        } catch (err) {}
      }

      if (moved) {
        // prevent the browser from interpreting as a "scroll/tap"
        e.preventDefault();

        // Reset double-tap tracking when dragging
        lastTapTime = 0;
        lastTapTarget = null;

        // Compute velocity (px/ms)
        const now = performance.now();
        const dt = Math.max(8, now - lastMoveT);
        const dxStep = e.clientX - lastMoveX;
        // scrollLeft moves opposite to pointer movement:
        const v = (-dxStep) / dt;
        // smooth it:
        velocity = velocity * 0.8 + v * 0.2;
        lastMoveX = e.clientX;
        lastMoveT = now;

        // Drag-to-scroll using rAF scheduler
        const next = startScrollLeft - dx;
        scheduleScrollLeft(next);
        
        // Update center highlight while dragging
        scheduleActivePreview();
        
        // Update last scroll position for settle engine
        lastScrollLeft = next;
      }
    }

    function handlePointerUp(e) {
      // MOBILE: Disable custom drag handling
      if (isMobile) return;
      
      // DESKTOP: Original drag handling
      if (!isPointerDown) return;

      isPointerDown = false;

      track.classList.remove('is-dragging');
      track.style.cursor = 'grab';
      track.style.userSelect = '';

      try {
        track.releasePointerCapture(e.pointerId);
      } catch (err) {}

      isDragging = false;

      if (didDrag) {
        // Real drag (exceeded threshold): suppress accidental clicks for a short window
        suppressClickUntil = Date.now() + 350;

        // Start inertia if velocity is meaningful, otherwise snap immediately
        const velocityThreshold = 0.15;
        if (Math.abs(velocity) > velocityThreshold) {
          startInertiaScroll();
        } else {
          const closest = getClosestIndexToCenter();
          const target = slides[closest];
          if (target) scrollToCentered(target, true);
        }
      }
      didDrag = false;

      // reset moved shortly after (keep window for click suppression)
      setTimeout(() => {
        moved = false;
      }, 0);
    }

    function buildInfiniteLoop() {
      lastVideoRealIndex = -1;
      lastGifRealIndex = -1;

      // For 1 or fewer slides, no loop needed (applies to both mobile and desktop)
      if (originalCount <= 1) {
        slides = Array.from(originalSlides);
        clonesCount = 0;
        currentRealIndex = 0;
        currentIndex = 0;
        setActiveByRealIndex(0);
        updateDots();
        return;
      }

      // Remove existing clones
      const existingClones = track.querySelectorAll('.cpc-slide[data-clone="1"]');
      existingClones.forEach(clone => clone.remove());

      // Create clones: 1× on mobile, 3× on desktop for seamless infinite loop
      const copiesPerSide = isMobile ? 1 : 3;
      clonesCount = originalCount * copiesPerSide;

      // Prepend 3 FULL copies in original order
      for (let copy = 0; copy < copiesPerSide; copy++) {
        for (let i = 0; i < originalCount; i++) {
          const clone = originalSlides[i].cloneNode(true);
          clone.dataset.clone = '1';
          clone.dataset.originalIndex = i;
          track.insertBefore(clone, originalSlides[0]);
        }
      }

      // Append 3 FULL copies in original order
      for (let copy = 0; copy < copiesPerSide; copy++) {
        for (let i = 0; i < originalCount; i++) {
          const clone = originalSlides[i].cloneNode(true);
          clone.dataset.clone = '1';
          clone.dataset.originalIndex = i;
          track.appendChild(clone);
        }
      }

      // Rebuild slides array
      slides = Array.from(track.querySelectorAll('.cpc-slide'));

      // Preload strategy:
      // - keep all videos lightweight (metadata) by default
      // - warm only center + adjacent slides for smoother playback and less memory pressure
      const allVideos = Array.from(track.querySelectorAll('.cpc-card-video'));
      allVideos.forEach((video) => {
        video.loop = true;
        video.preload = 'metadata';
      });
      
      // Initial warm-up: center and immediate neighbors only
      if (slides.length > 0) {
        const initialIndex = clonesCount + currentIndex;
        const warmRadius = isMobile ? 1 : 2;
        for (let offset = -warmRadius; offset <= warmRadius; offset++) {
          const idx = initialIndex + offset;
          if (idx < 0 || idx >= slides.length) continue;
          const warmSlide = slides[idx];
          if (!warmSlide) continue;
          warmSlide.querySelectorAll('.cpc-card-video').forEach((video) => {
            video.preload = 'auto';
            if (video.readyState === 0) {
              video.load();
            }
          });
        }
        preloadAdjacentVideos(initialIndex);
      }
      
      // Start in the middle copy (first slide of middle copy)
      const middleStartIndex = clonesCount + currentIndex;
      const middleStartSlide = slides[middleStartIndex];
      if (middleStartSlide) {
        track.scrollTo({
          left: middleStartSlide.offsetLeft - (track.offsetWidth / 2) + (middleStartSlide.offsetWidth / 2),
          behavior: 'auto'
        });
      }
      
      currentRealIndex = middleStartIndex;
      setActiveByRealIndex(middleStartIndex);
      ensureSingleActiveSlide();
      updateDots();
      
      // Trigger active preview and settle after initialization
      requestAnimationFrame(() => {
        if (track) {
          scheduleActivePreview();
          scheduleSettle();
        }
      });
    }

    function init() {
      if (section.dataset.cpcInitialized === 'true') return;
      section.dataset.cpcInitialized = 'true';

      // Get original slides
      originalSlides = Array.from(track.querySelectorAll('.cpc-slide')).filter(slide => !slide.dataset.clone);
      originalCount = originalSlides.length;
      
      if (originalCount === 0) return;

      // Mark original slides with data-original-index
      originalSlides.forEach((slide, index) => {
        slide.dataset.originalIndex = index;
      });

      // Build infinite loop (skips on mobile)
      buildInfiniteLoop();
      applyScrollSnapMode();

      // Add scroll listener for both mobile and desktop (both use scroll-based detection)
      track.addEventListener('scroll', () => {
        onScroll();
      }, { passive: true });

      // Button-only navigation (no swipe / wheel scrolling)
      if (prevBtn) {
        prevBtn.addEventListener('click', (e) => {
          e.preventDefault();
          scrollToPrev();
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', (e) => {
          e.preventDefault();
          scrollToNext();
        });
      }

      // Register click handler for product links and video play/pause
          section.addEventListener('click', (e) => {
        // MOBILE: Simplified tap behavior
        if (isMobile) {
          if (isProgrammaticScroll) {
            e.preventDefault();
            e.stopPropagation();
            return;
          }
          const link = e.target.closest('a.cpc-info-card');
          const slide = e.target.closest('.cpc-slide');
          
          if (link && slide) {
            // If slide is already active, allow default link navigation
            if (slide.classList.contains('is-active')) {
              // Double-tap detection for immediate navigation
              const currentTime = Date.now();
              const timeSinceLastTap = currentTime - lastTapTime;
              const isDoubleTap = timeSinceLastTap < DOUBLE_TAP_DELAY && 
                                 lastTapTarget === link;

              if (isDoubleTap) {
                // Double tap - navigate immediately
                e.preventDefault();
                e.stopPropagation();
                const href = link.getAttribute('href');
                if (href) {
                  window.location.href = href;
                }
                lastTapTime = 0;
                lastTapTarget = null;
              } else {
                // Single tap on active slide - allow default navigation
                lastTapTime = currentTime;
                lastTapTarget = link;
                setTimeout(() => {
                  if (Date.now() - lastTapTime >= DOUBLE_TAP_DELAY) {
                    lastTapTime = 0;
                    lastTapTarget = null;
                  }
                }, DOUBLE_TAP_DELAY);
              }
            } else {
              // Slide not active - center it first (native snap will handle)
              e.preventDefault();
              e.stopPropagation();
              scrollToCentered(slide, true);
            }
          } else if (slide && !link) {
            // Click on card (not link) - center if not already active
            if (!slide.classList.contains('is-active')) {
              e.preventDefault();
              e.stopPropagation();
              scrollToCentered(slide, true);
            }
          }
          return;
        }

        // DESKTOP: Original click handling
        // Handle video play/pause ONLY when slide has video AND is already active (otherwise fall through to center-on-click)
        const mediaTile = e.target.closest('.cpc-media-tile');
        if (mediaTile && !e.target.closest('a.cpc-info-card')) {
          const slide = mediaTile.closest('.cpc-slide');
          const video = mediaTile.querySelector('.cpc-card-video');
          if (slide && slide.classList.contains('is-active') && video) {
            if (Date.now() < suppressClickUntil) {
              e.preventDefault();
              e.stopPropagation();
              return;
            }
            e.preventDefault();
            e.stopPropagation();
            if (video.paused) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
            return;
          }
        }

        const link = e.target.closest('a.cpc-info-card');
        if (!link) {
          // Click anywhere on card (not link, not video): scroll slide to center
          if (Date.now() < suppressClickUntil) return;
          const slide = e.target.closest('.cpc-slide');
          if (slide) {
            // Do not interfere during drag or inertia
            if (isDragging || isInertia) return;

            const clickedIndex = slides.indexOf(slide);
            const centeredIndex = getClosestIndexToCenter();

            // Only center if this slide is NOT already centered
            if (clickedIndex !== centeredIndex) {
              e.preventDefault();
              e.stopPropagation();
              scrollToCentered(slide, true);
            }
          }
          return;
        }

        // Desktop info-card behavior:
        // - If not centered: center only (no navigation)
        // - If centered: allow normal navigation
        // - Never navigate during drag/inertia/programmatic scroll/suppressed click window
        if (Date.now() < suppressClickUntil || isDragging || isInertia || isProgrammaticScroll) {
          e.preventDefault();
          e.stopPropagation();
          return;
        }

        const slide = link.closest('.cpc-slide');
        if (!slide) return;

        const clickedIndex = slides.indexOf(slide);
        const centeredIndex = getClosestIndexToCenter();
        if (clickedIndex !== centeredIndex) {
          e.preventDefault();
          e.stopPropagation();
          scrollToCentered(slide, true);
          return;
        }
      }, false); // Use bubbling phase so link's default behavior works

      if (autoplayEnabled) {
        startAutoplay();
        section.addEventListener('mouseenter', pauseAutoplay);
        section.addEventListener('mouseleave', resumeAutoplay);
        section.addEventListener('focusin', pauseAutoplay);
        section.addEventListener('focusout', resumeAutoplay);
      }

      // Re-sync media when section leaves/re-enters viewport.
      // Prevents blank paused videos after scrolling past and back.
      if ('IntersectionObserver' in window) {
        const visibilityObserver = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry) return;

            if (entry.isIntersecting) {
              const centeredIndex = getClosestIndexToCenter();
              lastVideoRealIndex = -1;
              lastGifRealIndex = -1;
              updateCenterVideo(centeredIndex);
              updateCenterGif(centeredIndex);
            } else {
              pauseAllVideos(false);
            }
          },
          { threshold: 0.12 }
        );
        visibilityObserver.observe(section);
      }

      // Handle window resize
      let resizeTimeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          // Update mobile state
          updateMobileState();
          // Rebuild (handles mobile/desktop switch)
          buildInfiniteLoop();
          applyScrollSnapMode();
          // Both mobile and desktop use scroll-based detection, no observer needed
        }, 250);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    document.addEventListener('shopify:section:load', function (e) {
      const root = e.detail || e.target;
      const loaded = root.querySelector
        ? root.querySelector(`#CenterProductCarousel-${sectionId}`)
        : (root.id === `CenterProductCarousel-${sectionId}` ? root : null);

      if (loaded) setTimeout(init, 60);
    });

  })();
</script>

