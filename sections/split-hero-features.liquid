{%- liquid
  assign section_id = section.id
  assign top_heading = section.settings.top_heading
  assign top_heading_tag = section.settings.top_heading_tag | default: 'h2'
  assign top_heading_size = section.settings.top_heading_size | default: 4.8
  assign top_heading_weight = section.settings.top_heading_weight | default: '700'
  assign top_button_text = section.settings.top_button_text
  assign top_button_url = section.settings.top_button_url
  assign top_button_text_2 = section.settings.top_button_text_2
  assign top_button_url_2 = section.settings.top_button_url_2
  assign button_size_scale = section.settings.button_size_scale | default: 100 | divided_by: 100.0
  assign button_size_scale_mobile = section.settings.button_size_scale_mobile | default: 100 | divided_by: 100.0
  assign top_bg_type = section.settings.top_bg_type | default: 'image'
  assign top_bg_image = section.settings.top_bg_image
  assign top_bg_gradient = section.settings.top_bg_gradient
  assign top_logo = section.settings.top_logo
  assign top_center_image = section.settings.top_center_image
  assign top_center_image_height = section.settings.top_center_image_height
  assign top_center_image_x_offset = section.settings.top_center_image_x_offset | default: 0
  assign top_center_image_x_offset_mobile = section.settings.top_center_image_x_offset_mobile | default: 0
  assign top_center_image_y_offset = section.settings.top_center_image_y_offset | default: 0
  assign top_center_image_y_offset_mobile = section.settings.top_center_image_y_offset_mobile | default: 0
  assign center_image_anchor_bottom = section.settings.center_image_anchor_bottom
  assign top_center_text_above = section.settings.top_center_text_above
  assign top_center_text_overlap = section.settings.top_center_text_overlap
  assign bottom_bg_color = section.settings.bottom_bg_color
  assign bottom_bg_gradient = section.settings.bottom_bg_gradient
  assign bridge_bg_color = section.settings.bridge_bg_color
  assign bridge_bg_gradient = section.settings.bridge_bg_gradient
  assign bottom_padding = section.settings.bottom_padding | default: 4
  assign features_area_min_height = section.settings.features_area_min_height | default: 0
  assign features_layout = section.settings.features_layout | default: '3-columns'
  assign features_container_width = section.settings.features_container_width
  assign section_radius = section.settings.section_radius | default: 24
  assign button_location = section.settings.button_location | default: 'center'
  assign button_vertical_position = section.settings.button_vertical_position | default: 'top'
  assign button_radius = section.settings.button_radius | default: 0.8
  assign button_primary_bg = section.settings.button_primary_bg
  assign button_primary_text = section.settings.button_primary_text
  assign button_secondary_bg = section.settings.button_secondary_bg
  assign button_secondary_text = section.settings.button_secondary_text
  assign full_width_enabled = section.settings.enable_full_width
  assign feature_blocks = section.blocks | where: 'type', 'feature'
-%}

<section
  id="SplitHeroFeatures-{{ section_id }}"
  class="split-section split-section--{{ section_id }}{% if full_width_enabled %} split-section--full-width{% endif %}"
  style="
    --split-section-radius: {{ section_radius }}px;
    --split-bottom-padding-raw: {{ bottom_padding }}rem;
    --split-bottom-padding: min(var(--split-bottom-padding-raw), 40px);
    --button-radius-raw: {{ button_radius }}rem;
    --button-radius: var(--button-radius-raw);
    --button-vertical-offset-raw: {{ section.settings.button_vertical_offset | default: 0 }}px;
    --button-vertical-offset: var(--button-vertical-offset-raw);
    --top-heading-size-raw: {{ top_heading_size }}rem;
    --top-heading-size: var(--top-heading-size-raw);
    --top-heading-weight: {{ top_heading_weight }};
    --button-size-scale-raw: {{ button_size_scale }};
    --button-size-scale: var(--button-size-scale-raw);
    --button-size-scale-mobile: {{ button_size_scale_mobile }};
    --top-center-text-overlap-size-mobile: {{ section.settings.top_center_text_overlap_size_mobile | default: 2.4 }}rem;
    --disclaimer-collapsed-height-raw: {{ section.settings.disclaimer_collapsed_height | default: 120 }}px;
    --disclaimer-collapsed-height: var(--disclaimer-collapsed-height-raw);
    --mobile-features-gap-raw: {{ section.settings.mobile_features_gap | default: 1.2 }}rem;
    --mobile-features-gap: var(--mobile-features-gap-raw);
    --mobile-features-row-gap-raw: {{ section.settings.mobile_features_row_gap | default: 1.2 }}rem;
    --mobile-features-row-gap: var(--mobile-features-row-gap-raw);
    --mobile-features-user-scale: {{ section.settings.mobile_features_scale | default: 100 | divided_by: 100.0 }};
    --mobile-title-scale: {{ section.settings.mobile_title_scale | default: 85 | divided_by: 100.0 }};
    --mobile-description-scale: {{ section.settings.mobile_description_scale | default: 85 | divided_by: 100.0 }};
    --mobile-middle-text-scale: {{ section.settings.mobile_middle_text_scale | default: 85 | divided_by: 100.0 }};
    --mobile-image-scale: {{ section.settings.mobile_image_scale | default: 100 | divided_by: 100.0 }};
    --mobile-box-padding-scale: {{ section.settings.mobile_box_padding_scale | default: 100 | divided_by: 100.0 }};
    {% if section.settings.button_width != blank and section.settings.button_width > 0 %}
      --button-width-raw: {{ section.settings.button_width }}px;
      --button-width: var(--button-width-raw);
    {% endif %}
    {% if section.settings.button_height != blank and section.settings.button_height > 0 %}
      --button-height-raw: {{ section.settings.button_height }}px;
      --button-height: var(--button-height-raw);
    {% endif %}
    {% if features_container_width != blank and features_container_width > 0 %}
      --features-container-width-raw: {{ features_container_width }}px;
      --features-container-width: var(--features-container-width-raw);
    {% endif %}
    {% if features_area_min_height != blank and features_area_min_height > 0 %}
      --features-grid-min-height-raw: {{ features_area_min_height }}px;
      --features-grid-min-height: var(--features-grid-min-height-raw);
    {% endif %}

    {% if bottom_bg_gradient != blank %} --split-bottom-bg: {{ bottom_bg_gradient }};{% elsif bottom_bg_color != blank %} --split-bottom-bg: {{ bottom_bg_color }};{% endif %}
    {% if bridge_bg_gradient != blank %} --split-bridge-bg: {{ bridge_bg_gradient }};{% elsif bridge_bg_color != blank %} --split-bridge-bg: {{ bridge_bg_color }};{% elsif bottom_bg_gradient != blank %} --split-bridge-bg: {{ bottom_bg_gradient }};{% elsif bottom_bg_color != blank %} --split-bridge-bg: {{ bottom_bg_color }};{% endif %}
    {% if button_primary_bg != blank %} --button-primary-bg: {{ button_primary_bg }};{% endif %}
    {% if button_primary_text != blank %} --button-primary-text: {{ button_primary_text }};{% endif %}
    {% if section.settings.button_primary_hover_bg != blank %} --button-primary-hover-bg: {{ section.settings.button_primary_hover_bg }};{% endif %}
    {% if section.settings.button_primary_hover_text != blank %} --button-primary-hover-text: {{ section.settings.button_primary_hover_text }};{% endif %}
    {% if button_secondary_bg != blank %} --button-secondary-bg: {{ button_secondary_bg }};{% endif %}
    {% if button_secondary_text != blank %} --button-secondary-text: {{ button_secondary_text }};{% endif %}
    {% if section.settings.button_secondary_hover_bg != blank %} --button-secondary-hover-bg: {{ section.settings.button_secondary_hover_bg }};{% endif %}
    {% if section.settings.button_secondary_hover_text != blank %} --button-secondary-hover-text: {{ section.settings.button_secondary_hover_text }};{% endif %}
    {% if top_bg_type == 'gradient' and top_bg_gradient != blank %} --split-top-bg: {{ top_bg_gradient }};{% elsif top_bg_type == 'image' and top_bg_image != blank %} --split-top-bg-image: url({{ top_bg_image | image_url: width: 1600 }});{% endif %}
  "
>
  <div class="split-top {% if top_bg_type == 'gradient' and top_bg_gradient != blank %}split-top--gradient{% endif %}">
    <div class="split-top-background">
      <div class="split-top-rive-animation">
        {%- if top_bg_image != blank -%}
          <canvas width="1728" height="736" style="vertical-align: top; width: 1728px; height: 736px;"></canvas>
        {%- endif -%}
      </div>
    </div>
    
    <div class="split-top-content">
      {%- if top_logo != blank -%}
        <h3 class="split-top-logo">
          {%- if top_logo contains '<svg' or top_logo contains '<img' -%}
            {{ top_logo }}
          {%- else -%}
            <span>{{ top_logo }}</span>
          {%- endif -%}
        </h3>
      {%- endif -%}

      {%- if top_heading != blank -%}
        {%- assign heading_lines = top_heading | split: '|' -%}
        {%- for line in heading_lines -%}
          <{{ top_heading_tag }} class="split-top-heading"><span>{{ line | strip }}</span></{{ top_heading_tag }}>
        {%- endfor -%}
      {%- endif -%}

      {%- if top_center_text_above != blank -%}
        <p class="split-top-center-text split-top-center-text--above">{{- top_center_text_above | newline_to_br -}}</p>
      {%- endif -%}

      {%- if top_center_text_overlap != blank -%}
        <p class="split-top-center-text split-top-center-text--overlap">{{- top_center_text_overlap | newline_to_br -}}</p>
      {%- endif -%}

      {%- if top_center_image != blank -%}
        <div class="split-top-image-wrapper{% if center_image_anchor_bottom %} split-top-image-wrapper--anchored{% endif %}">
          <div class="split-top-image-spacer"></div>
          <img
            src="{{ top_center_image | image_url: width: 1400 }}"
            srcset="{{ top_center_image | image_url: width: 700 }} 700w, {{ top_center_image | image_url: width: 1400 }} 1400w"
            sizes="(max-width: 749px) 100vw, 1400px"
            alt="{{ top_center_image.alt | default: '' | escape }}"
            loading="lazy"
            decoding="async"
            fetchpriority="high"
          >
        </div>
      {%- endif -%}

    </div>

    {%- if top_button_text != blank or top_button_text_2 != blank -%}
      <div class="split-top-buttons split-top-buttons--{{ button_location }} split-top-buttons--v-{{ button_vertical_position }}">
        {%- if top_button_text != blank and top_button_url != blank -%}
          <a href="{{ top_button_url }}" class="split-button-link" rel="noreferrer noopener" tabindex="-1">
            <button type="button" class="split-button split-button--primary{% if section.settings.button_glassy_primary %} split-button--glassy{% endif %}{% if section.settings.button_glassy_hover_primary %} split-button--glassy-hover{% endif %}">
              <span>{{ top_button_text }}</span>
            </button>
          </a>
        {%- endif -%}
        {%- if top_button_text_2 != blank and top_button_url_2 != blank -%}
          <a href="{{ top_button_url_2 }}" class="split-button-link split-button-link--secondary" rel="noreferrer noopener" tabindex="-1">
            <button type="button" class="split-button split-button--secondary{% if section.settings.button_glassy_secondary %} split-button--glassy{% endif %}{% if section.settings.button_glassy_hover_secondary %} split-button--glassy-hover{% endif %}">
              <span>{{ top_button_text_2 }}</span>
            </button>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div id="SplitTransitionBridge-{{ section_id }}" class="split-transition-bridge" data-split-bridge="true" aria-hidden="true"></div>

  <div class="split-bottom">
    <div class="split-bottom-container">
      {%- if feature_blocks.size > 0 -%}
        <div class="split-features-grid split-features-grid--{{ features_layout }}">
          {%- for block in feature_blocks -%}
            {%- liquid
              assign image_position = block.settings.image_position | default: 'top'
              assign title_color = block.settings.title_color
              assign description_color = block.settings.description_color
              assign image_size = block.settings.image_size_desktop | default: 120
              assign image_size_mobile = block.settings.image_size_mobile | default: image_size
              assign image_padding = block.settings.image_padding | default: 0
              assign box_width = block.settings.box_width
              assign box_height = block.settings.box_height
              assign mobile_box_width = block.settings.mobile_box_width
              assign mobile_box_height = block.settings.mobile_box_height
              assign animation_type = block.settings.animation_type | default: 'fade-up'
              assign animation_speed = block.settings.animation_speed | default: 800
              assign animation_style = block.settings.animation_style | default: 'ease-out'
              assign animation_delay = block.settings.animation_delay | default: 0
              assign feature_description_2 = block.settings.feature_description_2
              assign desc1_size = block.settings.desc1_size | default: 1.5
              assign desc1_size_mobile = block.settings.desc1_size_mobile | default: 0
              assign desc2_size = block.settings.desc2_size | default: 1.5
              assign desc2_size_mobile = block.settings.desc2_size_mobile | default: 0
              assign desc1_bold = block.settings.desc1_bold | default: false
              assign desc2_bold = block.settings.desc2_bold | default: false
              assign desc1_position = block.settings.desc1_position | default: 'left'
              assign desc2_position = block.settings.desc2_position | default: 'right'
              assign desc1_alignment = block.settings.desc1_alignment | default: 'left'
              assign desc2_alignment = block.settings.desc2_alignment | default: 'right'
              assign center_image_position = block.settings.center_image_position | default: 'center'
              assign right_offset_value = block.settings.right_offset_value | default: 20
              assign title_size = block.settings.title_size | default: 2
              assign title_size_mobile = block.settings.title_size_mobile | default: 0
              assign description_size = block.settings.description_size | default: 1.5
              assign description_size_mobile = block.settings.description_size_mobile | default: 0
              assign title_weight = block.settings.title_weight | default: '600'
              assign description_weight = block.settings.description_weight | default: '400'
              assign feature_button_text = block.settings.feature_button_text
              assign feature_button_url = block.settings.feature_button_url
              assign feature_button_style = block.settings.feature_button_style | default: 'primary'
              assign feature_button_max_width_desktop = block.settings.feature_button_max_width_desktop | default: 240
              assign feature_button_max_width_mobile = block.settings.feature_button_max_width_mobile | default: feature_button_max_width_desktop
            -%}
            <div 
              class="split-feature-box split-feature-box--image-{{ image_position }} split-feature-box--animate split-feature-box--{{ animation_type }}{% if box_width != blank and box_width > 0 %} split-feature-box--custom-width{% endif %}{% if box_height != blank and box_height > 0 %} split-feature-box--custom-height{% endif %}{% if mobile_box_width != blank and mobile_box_width > 0 %} split-feature-box--custom-mobile-width{% endif %}{% if mobile_box_height != blank and mobile_box_height > 0 %} split-feature-box--custom-mobile-height{% endif %}{% if block.settings.enable_canvas_mode %} split-feature-box--canvas{% endif %}" 
              data-animation-type="{{ animation_type }}"
              data-animation-speed="{{ animation_speed }}"
              data-animation-style="{{ animation_style }}"
              data-animation-delay="{{ animation_delay }}"
              {{ block.shopify_attributes }}
              style="{% if title_color != blank %}--feature-title-color: {{ title_color }};{% endif %}{% if description_color != blank %}--feature-description-color: {{ description_color }};{% endif %}--feature-image-size-raw-desktop: {{ image_size }}px;--feature-image-size-raw-mobile: {{ image_size_mobile }}px;{% if image_padding != blank %}--feature-image-padding-raw: {{ image_padding }}px;--feature-image-padding: var(--feature-image-padding-raw);{% endif %}{% if box_width != blank and box_width > 0 %}--feature-box-width-raw: {{ box_width }}px;--feature-box-width: var(--feature-box-width-raw);{% endif %}{% if box_height != blank and box_height > 0 %}--feature-box-height-raw: {{ box_height }}px;--feature-box-height: var(--feature-box-height-raw);{% endif %}{% if mobile_box_width != blank and mobile_box_width > 0 %}--feature-box-mobile-width-raw: {{ mobile_box_width }}px;--feature-box-mobile-width: var(--feature-box-mobile-width-raw);{% endif %}{% if mobile_box_height != blank and mobile_box_height > 0 %}--feature-box-mobile-height-raw: {{ mobile_box_height }}px;--feature-box-mobile-height: var(--feature-box-mobile-height-raw);{% endif %}{% if image_position == 'middle' %}--desc1-size-raw: {{ desc1_size }}rem;--desc1-size: var(--desc1-size-raw);{% if desc1_size_mobile != blank and desc1_size_mobile > 0 %}--desc1-size-mobile-raw: {{ desc1_size_mobile }}rem;--desc1-size-mobile: var(--desc1-size-mobile-raw);{% endif %}--desc2-size-raw: {{ desc2_size }}rem;--desc2-size: var(--desc2-size-raw);{% if desc2_size_mobile != blank and desc2_size_mobile > 0 %}--desc2-size-mobile-raw: {{ desc2_size_mobile }}rem;--desc2-size-mobile: var(--desc2-size-mobile-raw);{% endif %}--desc1-weight: {% if desc1_bold %}700{% else %}400{% endif %};--desc2-weight: {% if desc2_bold %}700{% else %}400{% endif %};--desc1-align: {{ desc1_alignment }};--desc2-align: {{ desc2_alignment }};{% endif %}{% if image_position == 'right-offset' %}--right-offset-value-raw: {{ right_offset_value }}px;--right-offset-value: var(--right-offset-value-raw);{% endif %}--feature-title-size-raw: {{ title_size }}rem;--feature-title-size: var(--feature-title-size-raw);{% if title_size_mobile != blank and title_size_mobile > 0 %}--feature-title-size-mobile-raw: {{ title_size_mobile }}rem;--feature-title-size-mobile: var(--feature-title-size-mobile-raw);{% endif %}--feature-description-size-raw: {{ description_size }}rem;--feature-description-size: var(--feature-description-size-raw);{% if description_size_mobile != blank and description_size_mobile > 0 %}--feature-description-size-mobile-raw: {{ description_size_mobile }}rem;--feature-description-size-mobile: var(--feature-description-size-mobile-raw);{% endif %}--feature-title-weight: {{ title_weight }};--feature-description-weight: {{ description_weight }};--feature-description-align: {{ block.settings.description_align | default: 'left' }};{% if block.settings.feature_title_font %}--feature-title-font-family: {{ block.settings.feature_title_font.family }}, {{ block.settings.feature_title_font.fallback_families }};--feature-title-font-style: {{ block.settings.feature_title_font.style }};{% endif %}{% if block.settings.feature_description_font %}--feature-description-font-family: {{ block.settings.feature_description_font.family }}, {{ block.settings.feature_description_font.fallback_families }};--feature-description-font-style: {{ block.settings.feature_description_font.style }};{% endif %}--feature-image-offset-x-desktop: {{ block.settings.feature_image_offset_x_desktop | default: 0 }}px;--feature-image-offset-y-desktop: {{ block.settings.feature_image_offset_y_desktop | default: 0 }}px;--feature-image-offset-x-mobile: {{ block.settings.feature_image_offset_x_mobile | default: 0 }}px;--feature-image-offset-y-mobile: {{ block.settings.feature_image_offset_y_mobile | default: 0 }}px;--feature-title-offset-x-desktop: {{ block.settings.feature_title_offset_x_desktop | default: 0 }}px;--feature-title-offset-y-desktop: {{ block.settings.feature_title_offset_y_desktop | default: 0 }}px;--feature-title-offset-x-mobile: {{ block.settings.feature_title_offset_x_mobile | default: 0 }}px;--feature-title-offset-y-mobile: {{ block.settings.feature_title_offset_y_mobile | default: 0 }}px;--feature-desc1-offset-x-desktop: {{ block.settings.feature_desc1_offset_x_desktop | default: 0 }}px;--feature-desc1-offset-y-desktop: {{ block.settings.feature_desc1_offset_y_desktop | default: 0 }}px;--feature-desc1-offset-x-mobile: {{ block.settings.feature_desc1_offset_x_mobile | default: 0 }}px;--feature-desc1-offset-y-mobile: {{ block.settings.feature_desc1_offset_y_mobile | default: 0 }}px;--feature-desc2-offset-x-desktop: {{ block.settings.feature_desc2_offset_x_desktop | default: 0 }}px;--feature-desc2-offset-y-desktop: {{ block.settings.feature_desc2_offset_y_desktop | default: 0 }}px;--feature-desc2-offset-x-mobile: {{ block.settings.feature_desc2_offset_x_mobile | default: 0 }}px;--feature-desc2-offset-y-mobile: {{ block.settings.feature_desc2_offset_y_mobile | default: 0 }}px;--feature-button-offset-x-desktop: {{ block.settings.feature_button_offset_x_desktop | default: 0 }}px;--feature-button-offset-y-desktop: {{ block.settings.feature_button_offset_y_desktop | default: 0 }}px;--feature-button-offset-x-mobile: {{ block.settings.feature_button_offset_x_mobile | default: 0 }}px;--feature-button-offset-y-mobile: {{ block.settings.feature_button_offset_y_mobile | default: 0 }}px;--feature-canvas-min-height: {{ block.settings.feature_canvas_min_height | default: 360 }}px;--animation-duration: {{ animation_speed }}ms;--animation-timing: {{ animation_style }};--feature-button-max-width-desktop: {{ feature_button_max_width_desktop }}px;--feature-button-max-width-mobile: {{ feature_button_max_width_mobile }}px;--feature-button-font-size-desktop: {{ block.settings.feature_button_font_size_desktop | default: 1.4 }}rem;--feature-button-font-size-mobile: {{ block.settings.feature_button_font_size_mobile | default: 1.4 }}rem;{% if block.settings.feature_button_primary_bg != blank %}--feature-button-primary-bg: {{ block.settings.feature_button_primary_bg }};{% endif %}{% if block.settings.feature_button_primary_text != blank %}--feature-button-primary-text: {{ block.settings.feature_button_primary_text }};{% endif %}{% if block.settings.feature_button_primary_hover_bg != blank %}--feature-button-primary-hover-bg: {{ block.settings.feature_button_primary_hover_bg }};{% endif %}{% if block.settings.feature_button_primary_hover_text != blank %}--feature-button-primary-hover-text: {{ block.settings.feature_button_primary_hover_text }};{% endif %}{% if block.settings.feature_button_secondary_bg != blank %}--feature-button-secondary-bg: {{ block.settings.feature_button_secondary_bg }};{% endif %}{% if block.settings.feature_button_secondary_text != blank %}--feature-button-secondary-text: {{ block.settings.feature_button_secondary_text }};{% endif %}{% if block.settings.feature_button_secondary_hover_bg != blank %}--feature-button-secondary-hover-bg: {{ block.settings.feature_button_secondary_hover_bg }};{% endif %}{% if block.settings.feature_button_secondary_hover_text != blank %}--feature-button-secondary-hover-text: {{ block.settings.feature_button_secondary_hover_text }};{% endif %}transition: opacity {{ animation_speed }}ms {{ animation_style }}, transform {{ animation_speed }}ms {{ animation_style }}, box-shadow 0.3s ease;"
            >
              {%- if image_position == 'middle' -%}
                {%- comment -%} Left side content {%- endcomment -%}
                <div class="split-feature-middle-left">
                  {%- if desc1_position == 'left' and block.settings.feature_description != blank -%}
                    <p class="split-feature-description split-feature-description--middle split-feature-description--desc1">{{ block.settings.feature_description | newline_to_br }}</p>
                  {%- endif -%}
                  {%- if desc2_position == 'left' and feature_description_2 != blank -%}
                    <p class="split-feature-description split-feature-description--middle split-feature-description--desc2">{{ feature_description_2 | newline_to_br }}</p>
                  {%- endif -%}
                </div>
                
                {%- comment -%} Middle image/icon {%- endcomment -%}
                {%- if block.settings.feature_image != blank -%}
                  <div class="split-feature-image split-feature-image--middle split-feature-image--middle-{{ center_image_position }}">
                    <img
                      src="{{ block.settings.feature_image | image_url: width: 400 }}"
                      srcset="{{ block.settings.feature_image | image_url: width: 120 }} 120w, {{ block.settings.feature_image | image_url: width: 240 }} 240w, {{ block.settings.feature_image | image_url: width: 400 }} 400w"
                      sizes="(max-width: 749px) {{ image_size_mobile }}px, {{ image_size }}px"
                      alt="{{ block.settings.feature_image.alt | default: block.settings.feature_title | escape }}"
                      loading="lazy"
                      decoding="async"
                      width="{{ image_size }}"
                      height="{{ image_size | times: block.settings.feature_image.height | divided_by: block.settings.feature_image.width }}"
                    >
                  </div>
                {%- elsif block.settings.feature_icon != blank -%}
                  <div class="split-feature-icon split-feature-icon--middle split-feature-icon--middle-{{ center_image_position }}">
                    {{ block.settings.feature_icon }}
                  </div>
                {%- endif -%}
                
                {%- comment -%} Right side content {%- endcomment -%}
                <div class="split-feature-middle-right">
                  {%- if desc1_position == 'right' and block.settings.feature_description != blank -%}
                    <p class="split-feature-description split-feature-description--middle split-feature-description--desc1">{{ block.settings.feature_description | newline_to_br }}</p>
                  {%- endif -%}
                  {%- if desc2_position == 'right' and feature_description_2 != blank -%}
                    <p class="split-feature-description split-feature-description--middle split-feature-description--desc2">{{ feature_description_2 | newline_to_br }}</p>
                  {%- endif -%}
                </div>
              {%- elsif image_position == 'left-edge' or image_position == 'right-edge' -%}
                {%- if block.settings.feature_image != blank -%}
                  <div class="split-feature-image split-feature-image--{{ image_position }}">
                    <img
                      src="{{ block.settings.feature_image | image_url: width: 400 }}"
