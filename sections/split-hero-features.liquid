<script>
  (function() {
    const sectionId = 'SplitHeroFeatures-{{ section_id }}';
    const section = document.getElementById(sectionId);
    
    if (!section) return;

    const featureBoxes = section.querySelectorAll('.split-feature-box--animate');
    
    if (featureBoxes.length === 0) return;

    // Create Intersection Observer
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.2 // Trigger when 20% of the section is visible
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Add visible class to each box with custom delay
          featureBoxes.forEach((box) => {
            const customDelay = parseInt(box.dataset.animationDelay) || 0;
            const baseDelay = 150; // Base delay between boxes
            const index = Array.from(featureBoxes).indexOf(box);
            const totalDelay = customDelay + (index * baseDelay);
            
            setTimeout(() => {
              box.classList.add('split-feature-box--visible');
            }, totalDelay);
          });
          
          // Unobserve after animation triggers
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Start observing the bottom section
    const bottomSection = section.querySelector('.split-bottom');
    if (bottomSection) {
      observer.observe(bottomSection);
    }
  })();
</script>

<script>
  (function() {
    const section = document.getElementById('SplitHeroFeatures-{{ section_id }}');
    if (!section) return;
    const splitTop = section.querySelector('.split-top');
    const bridge = section.querySelector('.split-transition-bridge');
    if (!splitTop || !bridge) return;

    function positionBridge() {
      bridge.style.top = splitTop.offsetHeight + 'px';
    }

    // ResizeObserver keeps the bridge in sync with split-top's rendered height.
    // rAF defers the read until after the browser has fully committed layout,
    // preventing stale mid-reflow offsetHeight values on initial page load.
    if (typeof ResizeObserver !== 'undefined') {
      let rafId = null;
      const ro = new ResizeObserver(() => {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(positionBridge);
      });
      ro.observe(splitTop);
    } else {
      positionBridge();
      window.addEventListener('resize', positionBridge);
      window.addEventListener('load', positionBridge);
    }
  })();
</script>

<script>
(function() {
  const section = document.getElementById('SplitHeroFeatures-{{ section_id }}');
  if (!section) return;

  const track = section.querySelector('[data-testimonials-track]');
  const slides = track ? Array.from(track.querySelectorAll('[data-testimonials-slide]')) : [];
  const prevBtn = section.querySelector('[data-testimonials-prev]');
  const nextBtn = section.querySelector('[data-testimonials-next]');

  let activeIndex = 0;

  function scrollToIndex(index) {
    if (!slides.length) return;
    activeIndex = (index + slides.length) % slides.length;
    slides[activeIndex].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => scrollToIndex(activeIndex - 1));
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => scrollToIndex(activeIndex + 1));
  }

  if (track) {
    track.addEventListener('scroll', () => {
      const trackLeft = track.getBoundingClientRect().left;
      let closest = 0;
      let closestOffset = Infinity;
      slides.forEach((slide, idx) => {
        const offset = Math.abs(slide.getBoundingClientRect().left - trackLeft);
        if (offset < closestOffset) {
          closestOffset = offset;
          closest = idx;
        }
      });
      activeIndex = closest;
    }, { passive: true });
  }

  const disclaimer = section.querySelector('[data-disclaimer]');
  const disclaimerToggle = section.querySelector('[data-disclaimer-toggle]');
  if (disclaimer && disclaimerToggle) {
    disclaimerToggle.addEventListener('click', () => {
      const isExpanded = disclaimer.classList.toggle('is-expanded');
      const readMore = disclaimerToggle.getAttribute('data-read-more') || disclaimerToggle.textContent;
      const readLess = disclaimerToggle.getAttribute('data-read-less') || readMore;
      disclaimerToggle.textContent = isExpanded ? readLess : readMore;
    });
  }
})();
</script>

