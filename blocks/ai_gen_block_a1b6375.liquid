{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-premium-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    min-height: {{ block.settings.section_height }}vh;
    position: relative;
    overflow: hidden;
    background: {{ block.settings.bg_gradient_start }};
    background: linear-gradient(
      135deg,
      {{ block.settings.bg_gradient_start }} 0%,
      {{ block.settings.bg_gradient_end }} 100%
    );
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-premium-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal }}px;
    padding-right: {{ block.settings.padding_horizontal }}px;
    min-height: {{ block.settings.section_height }}vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .ai-premium-hero-content-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-premium-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    line-height: {{ block.settings.title_line_height }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    color: {{ block.settings.text_color }};
    overflow: hidden;
  }

  .ai-premium-hero-title-{{ ai_gen_id }} .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%);
  }

  .ai-premium-hero-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    line-height: {{ block.settings.subtitle_line_height }};
    margin: 0 0 {{ block.settings.subtitle_margin_bottom }}px;
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.subtitle_opacity | divided_by: 100.0 }};
    max-width: {{ block.settings.subtitle_max_width }}px;
    opacity: 0;
    filter: blur(10px);
  }

  .ai-premium-hero-badges-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.badge_gap }}px;
    margin-bottom: {{ block.settings.badges_margin_bottom }}px;
  }

  .ai-premium-hero-badge-{{ ai_gen_id }} {
    background: {{ block.settings.badge_bg }};
    backdrop-filter: blur(10px);
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_radius }}px;
    box-shadow: 0 {{ block.settings.badge_shadow_y }}px {{ block.settings.badge_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.badge_shadow_opacity | divided_by: 100.0 }});
    opacity: 0;
    transform: scale(0.8);
    flex: 0 1 auto;
  }

  .ai-premium-hero-badge-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_number_size }}px;
    font-weight: {{ block.settings.badge_number_weight }};
    color: {{ block.settings.badge_number_color }};
    display: block;
    line-height: 1;
    margin-bottom: {{ block.settings.badge_number_spacing }}px;
  }

  .ai-premium-hero-badge-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_label_size }}px;
    color: {{ block.settings.badge_text_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.badge_letter_spacing }}px;
    font-weight: {{ block.settings.badge_label_weight }};
  }

  .ai-premium-hero-stats-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax({{ block.settings.stat_min_width }}px, 1fr));
    gap: {{ block.settings.stats_gap }}px;
    margin-bottom: {{ block.settings.stats_margin_bottom }}px;
    opacity: 0;
  }

  .ai-premium-hero-stat-{{ ai_gen_id }} {
    transform: translateY(30px);
    opacity: 0;
  }

  .ai-premium-hero-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_size }}px;
    font-weight: {{ block.settings.stat_number_weight }};
    color: {{ block.settings.accent_color }};
    line-height: 1;
    margin-bottom: {{ block.settings.stat_number_spacing }}px;
    display: block;
  }

  .ai-premium-hero-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_label_size }}px;
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.stat_label_opacity | divided_by: 100.0 }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.stat_letter_spacing }}px;
    font-weight: {{ block.settings.stat_label_weight }};
  }

  .ai-premium-hero-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.button_icon_gap }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    box-shadow: 0 {{ block.settings.button_shadow_y }}px {{ block.settings.button_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.button_shadow_opacity | divided_by: 100.0 }});
  }

  .ai-premium-hero-cta-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, {{ block.settings.button_hover_opacity | divided_by: 100.0 }});
    transform: translate(-50%, -50%);
    transition: width 0.6s ease, height 0.6s ease;
  }

  .ai-premium-hero-cta-{{ ai_gen_id }}:hover::before {
    width: 300px;
    height: 300px;
  }

  .ai-premium-hero-cta-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.button_hover_lift }}px);
    box-shadow: 0 {{ block.settings.button_shadow_y | plus: 10 }}px {{ block.settings.button_shadow_blur | plus: 10 }}px rgba(0, 0, 0, {{ block.settings.button_shadow_opacity | divided_by: 100.0 }});
  }

  .ai-premium-hero-cta-text-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
  }

  .ai-premium-hero-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    opacity: 0;
    transform: scale(0.8) rotate(-5deg);
    padding: {{ block.settings.image_padding }}px;
  }

  .ai-premium-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_radius }}px;
    box-shadow: 0 {{ block.settings.image_shadow_y }}px {{ block.settings.image_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.image_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.3s ease;
  }

  .ai-premium-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background: rgba(255, 255, 255, 0.1);
    border-radius: {{ block.settings.image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 {{ block.settings.image_shadow_y }}px {{ block.settings.image_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.image_shadow_opacity | divided_by: 100.0 }});
  }

  .ai-premium-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-premium-hero-floating-shape-{{ ai_gen_id }} {
    position: absolute;
    border-radius: 50%;
    opacity: {{ block.settings.shape_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-premium-hero-shape-1-{{ ai_gen_id }} {
    width: {{ block.settings.shape_1_size }}px;
    height: {{ block.settings.shape_1_size }}px;
    background: {{ block.settings.accent_color }};
    top: {{ block.settings.shape_1_top }}%;
    right: {{ block.settings.shape_1_right }}%;
    animation: ai-float-{{ ai_gen_id }}-1 20s ease-in-out infinite;
  }

  .ai-premium-hero-shape-2-{{ ai_gen_id }} {
    width: {{ block.settings.shape_2_size }}px;
    height: {{ block.settings.shape_2_size }}px;
    background: {{ block.settings.button_bg }};
    bottom: {{ block.settings.shape_2_bottom }}%;
    left: {{ block.settings.shape_2_left }}%;
    animation: ai-float-{{ ai_gen_id }}-2 15s ease-in-out infinite;
  }

  @keyframes ai-float-{{ ai_gen_id }}-1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(30px, -30px) rotate(120deg); }
    66% { transform: translate(-20px, 20px) rotate(240deg); }
  }

  @keyframes ai-float-{{ ai_gen_id }}-2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-40px, -40px) rotate(180deg); }
  }

  @media (max-width: 768px) {
    .ai-premium-hero-{{ ai_gen_id }} {
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-premium-hero-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_content_gap }}px;
      padding-left: {{ block.settings.mobile_padding_horizontal }}px;
      padding-right: {{ block.settings.mobile_padding_horizontal }}px;
    }

    .ai-premium-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_title_size }}px;
    }

    .ai-premium-hero-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_subtitle_size }}px;
    }

    .ai-premium-hero-stats-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.mobile_stats_gap }}px;
    }

    .ai-premium-hero-badges-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-premium-hero-badge-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-premium-hero-image-wrapper-{{ ai_gen_id }} {
      order: -1;
    }

    .ai-premium-hero-shape-1-{{ ai_gen_id }},
    .ai-premium-hero-shape-2-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-premium-hero-{{ ai_gen_id }} * {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstyle %}

<premium-hero-{{ ai_gen_id }} class="ai-premium-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.enable_shapes %}
    <div class="ai-premium-hero-floating-shape-{{ ai_gen_id }} ai-premium-hero-shape-1-{{ ai_gen_id }}"></div>
    <div class="ai-premium-hero-floating-shape-{{ ai_gen_id }} ai-premium-hero-shape-2-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-premium-hero-container-{{ ai_gen_id }}">
    <div class="ai-premium-hero-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h1 class="ai-premium-hero-title-{{ ai_gen_id }}" data-split-text>
          {{ block.settings.title }}
        </h1>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <p class="ai-premium-hero-subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </p>
      {% endif %}

      <div class="ai-premium-hero-badges-{{ ai_gen_id }}">
        {% if block.settings.badge_1_number != blank %}
          <div class="ai-premium-hero-badge-{{ ai_gen_id }}" data-badge-index="0">
            <span class="ai-premium-hero-badge-number-{{ ai_gen_id }}" data-badge-count="{{ block.settings.badge_1_number }}">0</span>
            <span class="ai-premium-hero-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_1_label }}</span>
          </div>
        {% endif %}

        {% if block.settings.badge_2_number != blank %}
          <div class="ai-premium-hero-badge-{{ ai_gen_id }}" data-badge-index="1">
            <span class="ai-premium-hero-badge-number-{{ ai_gen_id }}" data-badge-count="{{ block.settings.badge_2_number }}">0</span>
            <span class="ai-premium-hero-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_2_label }}</span>
          </div>
        {% endif %}

        {% if block.settings.badge_3_number != blank %}
          <div class="ai-premium-hero-badge-{{ ai_gen_id }}" data-badge-index="2">
            <span class="ai-premium-hero-badge-number-{{ ai_gen_id }}" data-badge-count="{{ block.settings.badge_3_number }}">0</span>
            <span class="ai-premium-hero-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_3_label }}</span>
          </div>
        {% endif %}
      </div>

      <div class="ai-premium-hero-stats-{{ ai_gen_id }}">
        {% if block.settings.stat_1_number != blank %}
          <div class="ai-premium-hero-stat-{{ ai_gen_id }}" data-stat-index="0">
            <span class="ai-premium-hero-stat-number-{{ ai_gen_id }}" data-count="{{ block.settings.stat_1_number }}">0</span>
            <span class="ai-premium-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</span>
          </div>
        {% endif %}

        {% if block.settings.stat_2_number != blank %}
          <div class="ai-premium-hero-stat-{{ ai_gen_id }}" data-stat-index="1">
            <span class="ai-premium-hero-stat-number-{{ ai_gen_id }}" data-count="{{ block.settings.stat_2_number }}">0</span>
            <span class="ai-premium-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</span>
          </div>
        {% endif %}

        {% if block.settings.stat_3_number != blank %}
          <div class="ai-premium-hero-stat-{{ ai_gen_id }}" data-stat-index="2">
            <span class="ai-premium-hero-stat-number-{{ ai_gen_id }}" data-count="{{ block.settings.stat_3_number }}">0</span>
            <span class="ai-premium-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</span>
          </div>
        {% endif %}

        {% if block.settings.stat_4_number != blank %}
          <div class="ai-premium-hero-stat-{{ ai_gen_id }}" data-stat-index="3">
            <span class="ai-premium-hero-stat-number-{{ ai_gen_id }}" data-count="{{ block.settings.stat_4_number }}">0</span>
            <span class="ai-premium-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_4_label }}</span>
          </div>
        {% endif %}
      </div>

      {% if block.settings.cta_text != blank %}
        <a href="{{ block.settings.cta_link }}" class="ai-premium-hero-cta-{{ ai_gen_id }}">
          <span class="ai-premium-hero-cta-text-{{ ai_gen_id }}">{{ block.settings.cta_text }}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {% endif %}
    </div>

    <div class="ai-premium-hero-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product_image %}
        <img
          src="{{ block.settings.product_image | image_url: width: 1200 }}"
          alt="{{ block.settings.product_image.alt | escape }}"
          class="ai-premium-hero-image-{{ ai_gen_id }}"
          loading="eager"
          width="{{ block.settings.product_image.width }}"
          height="{{ block.settings.product_image.height }}"
        >
      {% else %}
        <div class="ai-premium-hero-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>
</premium-hero-{{ ai_gen_id }}>

<script>
(function() {
  class PremiumHero{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.animationEnabled = {{ block.settings.enable_animations | json }};
    }

    connectedCallback() {
      if (!this.animationEnabled) return;
      
      this.splitText();
      this.animateOnLoad();
      this.setupParallax();
      this.setupMagneticButton();
    }

    splitText() {
      const title = this.querySelector('[data-split-text]');
      if (!title) return;

      const text = title.textContent.trim();
      const words = text.split(' ');
      
      title.innerHTML = words.map(word => 
        `<span class="word">${word}</span>`
      ).join(' ');
    }

    animateOnLoad() {
      const words = this.querySelectorAll('.word');
      const subtitle = this.querySelector('.ai-premium-hero-subtitle-{{ ai_gen_id }}');
      const badges = this.querySelectorAll('.ai-premium-hero-badge-{{ ai_gen_id }}');
      const stats = this.querySelectorAll('.ai-premium-hero-stat-{{ ai_gen_id }}');
      const cta = this.querySelector('.ai-premium-hero-cta-{{ ai_gen_id }}');
      const image = this.querySelector('.ai-premium-hero-image-wrapper-{{ ai_gen_id }}');
      const content = this.querySelector('.ai-premium-hero-content-{{ ai_gen_id }}');

      if (content) {
        setTimeout(() => {
          content.style.opacity = '1';
        }, 100);
      }

      words.forEach((word, index) => {
        setTimeout(() => {
          word.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease';
          word.style.transform = 'translateY(0)';
          word.style.opacity = '1';
        }, index * 100);
      });

      if (subtitle) {
        setTimeout(() => {
          subtitle.style.transition = 'opacity 1s ease, filter 1s ease';
          subtitle.style.opacity = '{{ block.settings.subtitle_opacity | divided_by: 100.0 }}';
          subtitle.style.filter = 'blur(0)';
        }, words.length * 100 + 300);
      }

      badges.forEach((badge, index) => {
        setTimeout(() => {
          badge.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease';
          badge.style.transform = 'scale(1)';
          badge.style.opacity = '1';
          this.animateCounter(badge.querySelector('[data-badge-count]'));
        }, words.length * 100 + 600 + (index * 150));
      });

      stats.forEach((stat, index) => {
        setTimeout(() => {
          stat.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease';
          stat.style.transform = 'translateY(0)';
          stat.style.opacity = '1';
          this.animateCounter(stat.querySelector('[data-count]'));
        }, words.length * 100 + 1200 + (index * 150));
      });

      if (cta) {
        setTimeout(() => {
          cta.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease';
          cta.style.transform = 'translateY(0)';
          cta.style.opacity = '1';
        }, words.length * 100 + 1800);
      }

      if (image) {
        setTimeout(() => {
          image.style.transition = 'transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.2s ease';
          image.style.transform = 'scale(1) rotate(0deg)';
          image.style.opacity = '1';
        }, 400);
      }
    }

    animateCounter(element) {
      if (!element) return;
      
      const target = element.getAttribute('data-count') || element.getAttribute('data-badge-count');
      const numericTarget = parseInt(target.replace(/[^0-9]/g, ''));
      const suffix = target.replace(/[0-9]/g, '');
      const duration = 2000;
      const steps = 60;
      const increment = numericTarget / steps;
      let current = 0;
      let step = 0;

      const timer = setInterval(() => {
        step++;
        current = Math.min(current + increment, numericTarget);
        
        const easeOut = 1 - Math.pow(1 - (step / steps), 3);
        const value = Math.floor(numericTarget * easeOut);
        
        element.textContent = value.toLocaleString() + suffix;

        if (step >= steps) {
          element.textContent = numericTarget.toLocaleString() + suffix;
          clearInterval(timer);
        }
      }, duration / steps);
    }

    setupParallax() {
      const image = this.querySelector('.ai-premium-hero-image-{{ ai_gen_id }}');
      if (!image) return;

      let ticking = false;

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            const scrolled = window.pageYOffset;
            const rate = scrolled * 0.3;
            image.style.transform = `translateY(${rate}px)`;
            ticking = false;
          });
          ticking = true;
        }
      });
    }

    setupMagneticButton() {
      const button = this.querySelector('.ai-premium-hero-cta-{{ ai_gen_id }}');
      if (!button) return;

      button.addEventListener('mousemove', (e) => {
        const rect = button.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        button.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
      });

      button.addEventListener('mouseleave', () => {
        button.style.transform = 'translate(0, 0)';
      });

      button.addEventListener('click', (e) => {
        const ripple = document.createElement('span');
        const rect = button.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;

        ripple.style.cssText = `
          position: absolute;
          width: ${size}px;
          height: ${size}px;
          border-radius: 50%;
          background: rgba(255, 255, 255, 0.5);
          left: ${x}px;
          top: ${y}px;
          pointer-events: none;
          transform: scale(0);
          animation: ripple-{{ ai_gen_id }} 0.6s ease-out;
        `;

        button.appendChild(ripple);
        setTimeout(() => ripple.remove(), 600);
      });

      const style = document.createElement('style');
      style.textContent = `
        @keyframes ripple-{{ ai_gen_id }} {
          to {
            transform: scale(2);
            opacity: 0;
          }
        }
      `;
      document.head.appendChild(style);
    }
  }

  customElements.define('premium-hero-{{ ai_gen_id }}', PremiumHero{{ ai_gen_id }});
})();
</script>

