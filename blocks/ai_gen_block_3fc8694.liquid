{% doc %}
  @prompt
    Create a split-layout contact section with an image on the left (40% width) and contact form with information on the right (60% width). The right side should include a large "Contact Us" heading, a contact form with fields for Full Name, E-mail, and Message, contact information displaying an email address and location (San Francisco, California), a rounded black submit button labeled "Contact Us", and clickable social media icons (Facebook, Instagram, WhatsApp) at the bottom right that can be linked to custom URLs through theme settings. The icons should be styled consistently and have hover effects. The design should have a clean, modern aesthetic with a light beige/cream background, proper spacing between elements, and be fully responsive on mobile devices with the image stacking above the form.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign overlay_alpha = block.settings.overlay_opacity | divided_by: 100.0 %}
{% assign content_bg_alpha = block.settings.content_background_opacity | divided_by: 100.0 %}
{% assign content_border_alpha = block.settings.content_border_opacity | divided_by: 100.0 %}
{% assign content_shadow_alpha = block.settings.content_shadow_opacity | divided_by: 100.0 %}
{% assign input_bg_alpha = block.settings.input_background_opacity | divided_by: 100.0 %}

{% if block.settings.heading_font or block.settings.body_font or block.settings.button_font %}
  <style>
    {% if block.settings.heading_font %}{{ block.settings.heading_font | font_face: font_display: 'swap' }}{% endif %}
    {% if block.settings.body_font %}{{ block.settings.body_font | font_face: font_display: 'swap' }}{% endif %}
    {% if block.settings.button_font %}{{ block.settings.button_font | font_face: font_display: 'swap' }}{% endif %}
  </style>
{% endif %}

{% style %}
  .ai-contact-split-{{ ai_gen_id }} {
    --ai-contact-type-scale: clamp(0.52, calc(0.52 + (100vw - 900px) / 1020px * 0.48), 1);
    --ai-contact-spacing-scale: clamp(0.42, calc(0.42 + (100vw - 900px) / 1020px * 0.58), 1);
    --ai-contact-panel-width: clamp(220px, 38vw, 600px);
    --ai-contact-side-offset: clamp(0px, calc((100vw - 900px) * 0.10), 100px);
    --ai-contact-frame-width: calc(var(--ai-contact-panel-width) + var(--ai-contact-side-offset));
    display: block;
    width: 100%;
    min-height: 100svh;
    height: auto;
    position: relative;
    overflow-x: hidden;
    overflow-y: visible;
    {% if block.settings.image %}
      background-image: url('{{ block.settings.image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: scroll;
    {% else %}
      background-color: {{ block.settings.background_color | color_modify: 'alpha', block.settings.background_opacity | divided_by: 100.0 }};
    {% endif %}
  }

  .ai-contact-split-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
    z-index: 1;
  }

  .ai-contact-split-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: min(100%, {{ block.settings.max_width }}px);
    min-height: 100svh;
    height: auto;
    margin: 0 auto;
    padding: 0 clamp(12px, 2vw, 28px);
    box-sizing: border-box;
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
    overflow: visible;
  }

  .ai-contact-split-fit-{{ ai_gen_id }} {
    width: min(100%, var(--ai-contact-frame-width));
    min-height: 100svh;
    height: auto;
    flex: 0 0 auto;
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
  }

  .ai-contact-split-content-{{ ai_gen_id }} {
    width: min(100%, var(--ai-contact-panel-width));
    max-width: var(--ai-contact-panel-width);
    min-width: 0;
    min-height: auto;
    height: auto;
    margin-right: var(--ai-contact-side-offset);
    padding: calc({{ block.settings.content_padding }}px * var(--ai-contact-spacing-scale));
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-height: none;
    overflow-y: visible;
    box-sizing: border-box;
    background: {{ block.settings.content_background_color | color_modify: 'alpha', content_bg_alpha }};
    backdrop-filter: blur({{ block.settings.content_backdrop_blur }}px);
    -webkit-backdrop-filter: blur({{ block.settings.content_backdrop_blur }}px);
    border-left: {{ block.settings.content_border_width }}px solid {{ block.settings.content_border_color | color_modify: 'alpha', content_border_alpha }};
    border-radius: {{ block.settings.content_border_radius }}px;
    box-shadow: 0 8px 32px {{ block.settings.content_shadow_color | color_modify: 'alpha', content_shadow_alpha }};
  }

  .ai-contact-split-heading-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.heading_size }}px * var(--ai-contact-type-scale));
    color: {{ block.settings.heading_color }};
    font-family: {% if block.settings.heading_font %}{{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }}{% else %}inherit{% endif %};
    font-weight: {{ block.settings.heading_font_weight }};
    font-style: {% if block.settings.heading_font %}{{ block.settings.heading_font.style }}{% else %}normal{% endif %};
    margin: 0 0 calc({{ block.settings.spacing }}px * var(--ai-contact-spacing-scale)) 0;
    letter-spacing: {{ block.settings.heading_letter_spacing | divided_by: 1000.0 }}em;
    line-height: {{ block.settings.heading_line_height }};
    opacity: {{ block.settings.heading_opacity | divided_by: 100.0 }};
  }

  .ai-contact-split-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: calc({{ block.settings.field_spacing }}px * var(--ai-contact-spacing-scale));
    margin-bottom: calc({{ block.settings.spacing }}px * var(--ai-contact-spacing-scale));
  }

  .ai-contact-split-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: calc(8px * var(--ai-contact-spacing-scale));
  }

  .ai-contact-split-label-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.label_size }}px * var(--ai-contact-type-scale));
    color: {{ block.settings.text_color }};
    font-family: {% if block.settings.body_font %}{{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }}{% else %}inherit{% endif %};
    font-weight: {{ block.settings.label_font_weight }};
    opacity: {{ block.settings.label_opacity | divided_by: 100.0 }};
  }

  .ai-contact-split-input-{{ ai_gen_id }},
  .ai-contact-split-textarea-{{ ai_gen_id }} {
    padding:
      calc({{ block.settings.input_padding }}px * var(--ai-contact-spacing-scale))
      calc({{ block.settings.input_padding | times: 1.5 }}px * var(--ai-contact-spacing-scale));
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: calc({{ block.settings.input_border_radius }}px * var(--ai-contact-spacing-scale));
    font-size: calc({{ block.settings.input_text_size }}px * var(--ai-contact-type-scale));
    color: {{ block.settings.input_text_color }};
    background: {{ block.settings.input_background | color_modify: 'alpha', input_bg_alpha }};
    backdrop-filter: blur({{ block.settings.input_backdrop_blur }}px);
    -webkit-backdrop-filter: blur({{ block.settings.input_backdrop_blur }}px);
    font-family: {% if block.settings.body_font %}{{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }}{% else %}inherit{% endif %};
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .ai-contact-split-input-{{ ai_gen_id }}::placeholder,
  .ai-contact-split-textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: {{ block.settings.placeholder_opacity | divided_by: 100.0 }};
  }

  .ai-contact-split-input-{{ ai_gen_id }}:focus,
  .ai-contact-split-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_color }};
    box-shadow: 0 0 0 2px {{ block.settings.input_focus_color | color_modify: 'alpha', 0.2 }};
  }

  .ai-contact-split-textarea-{{ ai_gen_id }} {
    min-height: calc({{ block.settings.textarea_min_height }}px * var(--ai-contact-spacing-scale));
    resize: {{ block.settings.textarea_resize }};
    border-radius: calc({{ block.settings.input_border_radius }}px * var(--ai-contact-spacing-scale));
  }

  .ai-contact-split-button-{{ ai_gen_id }} {
    appearance: none;
    -webkit-appearance: none;
    overflow: hidden;
    width: 100%;
    padding:
      calc({{ block.settings.button_padding }}px * var(--ai-contact-spacing-scale))
      calc({{ block.settings.button_padding | times: 1.5 }}px * var(--ai-contact-spacing-scale));
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: calc({{ block.settings.button_border_radius | default: 24 }}px * var(--ai-contact-spacing-scale));
    font-size: calc({{ block.settings.button_text_size }}px * var(--ai-contact-type-scale));
    font-family: {% if block.settings.button_font %}{{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }}{% else %}inherit{% endif %};
    font-weight: {{ block.settings.button_font_weight }};
    opacity: {{ block.settings.button_opacity | divided_by: 100.0 }};
    cursor: pointer;
    transition: background-color 0.3s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .ai-contact-split-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    opacity: {{ block.settings.button_hover_opacity | divided_by: 100.0 }};
  }

  .ai-contact-split-button-{{ ai_gen_id }}:focus,
  .ai-contact-split-button-{{ ai_gen_id }}:active {
    outline: none;
    border-color: {{ block.settings.button_border_color }};
  }

  .ai-contact-split-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: calc({{ block.settings.info_spacing }}px * var(--ai-contact-spacing-scale));
    margin-bottom: calc({{ block.settings.spacing }}px * var(--ai-contact-spacing-scale));
  }

  .ai-contact-split-info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: calc(12px * var(--ai-contact-spacing-scale));
    font-size: calc({{ block.settings.info_text_size }}px * var(--ai-contact-type-scale));
    color: {{ block.settings.info_text_color }};
    font-family: {% if block.settings.body_font %}{{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }}{% else %}inherit{% endif %};
    opacity: {{ block.settings.info_opacity | divided_by: 100.0 }};
  }

  .ai-contact-split-info-icon-{{ ai_gen_id }} {
    width: calc(20px * var(--ai-contact-spacing-scale));
    height: calc(20px * var(--ai-contact-spacing-scale));
    flex-shrink: 0;
  }

  .ai-contact-split-info-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-contact-split-social-{{ ai_gen_id }} {
    display: flex;
    gap: calc({{ block.settings.social_spacing }}px * var(--ai-contact-spacing-scale));
    align-items: center;
    flex-wrap: wrap;
    margin-top: calc({{ block.settings.social_margin_top }}px * var(--ai-contact-spacing-scale));
  }

  .ai-contact-split-social-link-{{ ai_gen_id }} {
    width: calc({{ block.settings.social_icon_size }}px * var(--ai-contact-spacing-scale));
    height: calc({{ block.settings.social_icon_size }}px * var(--ai-contact-spacing-scale));
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.social_bg_color }};
    border-radius: calc({{ block.settings.social_border_radius | default: 8 }}px * var(--ai-contact-spacing-scale));
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-decoration: none;
  }

  .ai-contact-split-social-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.social_hover_bg_color }};
    transform: translateY(-3px);
  }

  .ai-contact-split-social-link-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.social_icon_size | times: 0.5 }}px * var(--ai-contact-spacing-scale));
    height: calc({{ block.settings.social_icon_size | times: 0.5 }}px * var(--ai-contact-spacing-scale));
    fill: {{ block.settings.social_icon_color }};
  }

  .ai-contact-split-success-{{ ai_gen_id }} {
    padding:
      calc(16px * var(--ai-contact-spacing-scale))
      calc(20px * var(--ai-contact-spacing-scale));
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: calc({{ block.settings.message_border_radius }}px * var(--ai-contact-spacing-scale));
    border: {{ block.settings.success_border_width }}px solid {{ block.settings.success_border_color }};
    margin-bottom: calc({{ block.settings.spacing }}px * var(--ai-contact-spacing-scale));
    font-size: calc({{ block.settings.message_text_size }}px * var(--ai-contact-type-scale));
    font-family: {% if block.settings.body_font %}{{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }}{% else %}inherit{% endif %};
  }

  .ai-contact-split-error-{{ ai_gen_id }} {
    padding:
      calc(16px * var(--ai-contact-spacing-scale))
      calc(20px * var(--ai-contact-spacing-scale));
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: calc({{ block.settings.message_border_radius }}px * var(--ai-contact-spacing-scale));
    border: {{ block.settings.error_border_width }}px solid {{ block.settings.error_border_color }};
    margin-bottom: calc({{ block.settings.spacing }}px * var(--ai-contact-spacing-scale));
    font-size: calc({{ block.settings.message_text_size }}px * var(--ai-contact-type-scale));
    font-family: {% if block.settings.body_font %}{{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }}{% else %}inherit{% endif %};
  }


  @media screen and (min-width: 1400px) {
    .ai-contact-split-{{ ai_gen_id }} {
      --ai-contact-side-offset: 0px;
    }
    .ai-contact-split-container-{{ ai_gen_id }} {
      padding-right: 0;
    }
  }

  @media screen and (max-width: 767px) {
    .ai-contact-split-{{ ai_gen_id }} {
      --ai-contact-type-scale: 0.8;
      --ai-contact-spacing-scale: 0.76;
      --ai-contact-panel-width: 420px;
      --ai-contact-side-offset: 0px;
    }

    .ai-contact-split-container-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_top_padding | default: 24 }}px 10px 0;
      min-height: auto;
      height: auto;
      align-items: flex-start;
    }

    .ai-contact-split-fit-{{ ai_gen_id }} {
      min-height: auto;
      height: auto;
    }

    .ai-contact-split-content-{{ ai_gen_id }} {
      margin-right: 0;
      min-height: auto;
      height: auto;
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 479px) {
    .ai-contact-split-{{ ai_gen_id }} {
      --ai-contact-type-scale: 0.74;
      --ai-contact-spacing-scale: 0.7;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .ai-contact-split-{{ ai_gen_id }} {
      background-attachment: scroll;
    }
  }
{% endstyle %}

<contact-split-{{ ai_gen_id }} class="ai-contact-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-split-container-{{ ai_gen_id }}">
    <div class="ai-contact-split-fit-{{ ai_gen_id }}">
      <div class="ai-contact-split-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-contact-split-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {%- form 'contact' -%}
        {% if form.posted_successfully? %}
          <div class="ai-contact-split-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="ai-contact-split-error-{{ ai_gen_id }}">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="ai-contact-split-form-{{ ai_gen_id }}">
          <div class="ai-contact-split-field-{{ ai_gen_id }}">
            <label class="ai-contact-split-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
              {{ block.settings.name_label }}
            </label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-split-input-{{ ai_gen_id }}"
              value="{% if form.name %}{{ form.name }}{% endif %}"
              placeholder="{{ block.settings.name_placeholder }}"
              required
            >
          </div>

          <div class="ai-contact-split-field-{{ ai_gen_id }}">
            <label class="ai-contact-split-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
              {{ block.settings.email_label }}
            </label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-split-input-{{ ai_gen_id }}"
              value="{% if form.email %}{{ form.email }}{% endif %}"
              placeholder="{{ block.settings.email_placeholder }}"
              autocomplete="email"
              required
            >
          </div>

          <div class="ai-contact-split-field-{{ ai_gen_id }}">
            <label class="ai-contact-split-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
              {{ block.settings.message_label }}
            </label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-split-textarea-{{ ai_gen_id }}"
              placeholder="{{ block.settings.message_placeholder }}"
              required
            >{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="ai-contact-split-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {%- endform -%}

      <div class="ai-contact-split-info-{{ ai_gen_id }}">
        {% if block.settings.email_address != blank %}
          <div class="ai-contact-split-info-item-{{ ai_gen_id }}">
            <div class="ai-contact-split-info-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <span>{{ block.settings.email_address }}</span>
          </div>
        {% endif %}

        {% if block.settings.location != blank %}
          <div class="ai-contact-split-info-item-{{ ai_gen_id }}">
            <div class="ai-contact-split-info-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </div>
            <span>{{ block.settings.location }}</span>
          </div>
        {% endif %}
      </div>

      <div class="ai-contact-split-social-{{ ai_gen_id }}">
        {% if block.settings.facebook_url != blank %}
          <a
            href="{{ block.settings.facebook_url }}"
            class="ai-contact-split-social-link-{{ ai_gen_id }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.instagram_url != blank %}
          <a
            href="{{ block.settings.instagram_url }}"
            class="ai-contact-split-social-link-{{ ai_gen_id }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.whatsapp_phone != blank or block.settings.whatsapp_url != blank %}
          {%- liquid
            assign whatsapp_link = block.settings.whatsapp_url
            if block.settings.whatsapp_phone != blank
              assign phone_clean = block.settings.whatsapp_phone | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' | replace: '+', ''
              assign whatsapp_link = 'https://wa.me/' | append: phone_clean
              if block.settings.whatsapp_message != blank
                assign message_encoded = block.settings.whatsapp_message | url_encode
