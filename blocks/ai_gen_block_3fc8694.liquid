<script>
  (function() {
    class ContactSplit{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.handleSubmit = this.handleSubmit.bind(this);
        this.isSetup = false;
      }

      connectedCallback() {
        if (this.isSetup) return;
        this.isSetup = true;

        this.form = this.querySelector('form');
        if (this.form) this.form.addEventListener('submit', this.handleSubmit);
      }

      disconnectedCallback() {
        if (!this.isSetup) return;
        this.isSetup = false;
        if (this.form) this.form.removeEventListener('submit', this.handleSubmit);
      }

      handleSubmit(event) {
        const nameInput = this.querySelector('input[name="contact[name]"]');
        const emailInput = this.querySelector('input[name="contact[email]"]');
        const messageInput = this.querySelector('textarea[name="contact[body]"]');

        if (!nameInput || !emailInput || !messageInput) return;

        if (!nameInput.value.trim() || !emailInput.value.trim() || !messageInput.value.trim()) {
          event.preventDefault();
          alert('Please fill in all required fields.');
          return false;
        }
      }
    }

    if (!customElements.get('contact-split-{{ ai_gen_id }}')) {
      customElements.define('contact-split-{{ ai_gen_id }}', ContactSplit{{ ai_gen_id }});
    }
  })();
</script>

