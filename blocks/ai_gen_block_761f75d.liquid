{% doc %}
  @prompt
    Act as an expert Shopify developer and creative 3D frontend engineer.
     
    Create a futuristic Shopify landing page section with a 3D product showcase.
     
    TECHNOLOGY
     
    - Shopify Liquid
    - Three.js for 3D rendering
    - CSS Grid
    - responsive design
    - optimized WebGL performance
     
    SECTION DESIGN
     
    Layout:
    - full width section
    - dark modern background
    - glowing accents
    - center aligned 3D product model
     
    3D PRODUCT AREA
     
    Create a 3D viewer area.
     
    Features:
    - rotating 3D product model
    - subtle lighting effects
    - shadow beneath product
    - user can drag to rotate
     
    Camera:
    - slight zoom on scroll
    - smooth inertia rotation
     
    Lighting Setup:
    - soft ambient light
    - directional highlight
    - subtle rim glow
     
    SCROLL ANIMATION
     
    As the user scrolls:
     
    Step 1
    product slowly rotates
     
    Step 2
    text appears describing features
     
    Step 3
    secondary images fade in
     
    Step 4
    call-to-action appears
     
    TEXT BLOCK
     
    Typography:
    - large product title
    - feature list
    - short description
     
    Animation:
    - fade + slide up
    - staggered timing
     
    CTA BUTTON
     
    Style:
    - glowing button
    - hover scaling
    - click ripple effect
     
    RESPONSIVE DESIGN
     
    Mobile:
    - static image fallback instead of heavy 3D
    - stacked layout
    - simple fade animations
     
    Tablet:
    - simplified 3D viewer
    - smaller model
     
    Desktop:
    - full 3D viewer
    - full animation effects
     
    Ultra-wide / TV:
    - centered product with large whitespace
    - large readable typography
     
    SHOPIFY SETTINGS
     
    Allow merchant to upload:
     
    - 3D model (.glb)
    - product title
    - product description
    - button text
    - button link
     
    PERFORMANCE
     
    - lazy load Three.js
    - reduce poly count
    - fallback image for low devices
    - optimize WebGL
     
    OUTPUT
     
    Return:
    - Liquid section
    - JS for Three.js
    - responsive CSS
    - Shopify schema settings, make them super extreme animation please, make them extreme animation please and customizable 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-3d-extreme-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    min-height: 100vh;
    background: {{ block.settings.background_color }};
    position: relative;
    overflow: hidden;
  }

  @keyframes ai-extreme-pulse-{{ ai_gen_id }} {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  @keyframes ai-extreme-rotate-{{ ai_gen_id }} {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes ai-extreme-shake-{{ ai_gen_id }} {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
    20%, 40%, 60%, 80% { transform: translateX(10px); }
  }

  @keyframes ai-extreme-bounce-{{ ai_gen_id }} {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-30px); }
  }

  @keyframes ai-extreme-glow-{{ ai_gen_id }} {
    0%, 100% { 
      box-shadow: 0 0 20px {{ block.settings.glow_color }},
                  0 0 40px {{ block.settings.glow_color }},
                  0 0 60px {{ block.settings.glow_color }};
    }
    50% { 
      box-shadow: 0 0 40px {{ block.settings.glow_color }},
                  0 0 80px {{ block.settings.glow_color }},
                  0 0 120px {{ block.settings.glow_color }};
    }
  }

  @keyframes ai-extreme-glitch-{{ ai_gen_id }} {
    0% { transform: translate(0); }
    20% { transform: translate(-5px, 5px); }
    40% { transform: translate(-5px, -5px); }
    60% { transform: translate(5px, 5px); }
    80% { transform: translate(5px, -5px); }
    100% { transform: translate(0); }
  }

  @keyframes ai-extreme-neon-flicker-{{ ai_gen_id }} {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
      text-shadow: 
        0 0 10px {{ block.settings.neon_color }},
        0 0 20px {{ block.settings.neon_color }},
        0 0 30px {{ block.settings.neon_color }},
        0 0 40px {{ block.settings.neon_color }};
      opacity: 1;
    }
    20%, 24%, 55% {
      text-shadow: none;
      opacity: 0.7;
    }
  }

  @keyframes ai-extreme-spin-3d-{{ ai_gen_id }} {
    0% { transform: rotateY(0deg) rotateX(0deg); }
    100% { transform: rotateY(360deg) rotateX(360deg); }
  }

  @keyframes ai-extreme-zoom-{{ ai_gen_id }} {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  @keyframes ai-extreme-slide-in-{{ ai_gen_id }} {
    0% { 
      transform: translateX(-100%) rotate(-180deg);
      opacity: 0;
    }
    100% { 
      transform: translateX(0) rotate(0deg);
      opacity: 1;
    }
  }

  @keyframes ai-extreme-explode-{{ ai_gen_id }} {
    0% { 
      transform: scale(0) rotate(0deg);
      opacity: 0;
    }
    50% {
      transform: scale(1.3) rotate(180deg);
    }
    100% { 
      transform: scale(1) rotate(360deg);
      opacity: 1;
    }
  }

  .ai-3d-extreme-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    min-height: 100vh;
  }

  .ai-3d-extreme-viewer-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 600px;
    border-radius: {{ block.settings.viewer_border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.viewer_background }};
    {% if block.settings.enable_viewer_pulse %}
      animation: ai-extreme-pulse-{{ ai_gen_id }} {{ block.settings.pulse_speed }}s ease-in-out infinite;
    {% endif %}
    {% if block.settings.enable_viewer_glow %}
      animation: ai-extreme-glow-{{ ai_gen_id }} {{ block.settings.glow_speed }}s ease-in-out infinite;
    {% endif %}
    {% if block.settings.enable_viewer_rotate %}
      animation: ai-extreme-rotate-{{ ai_gen_id }} {{ block.settings.rotate_speed }}s linear infinite;
    {% endif %}
  }

  .ai-3d-extreme-canvas-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }

  .ai-3d-extreme-canvas-{{ ai_gen_id }}:active {
    cursor: grabbing;
  }

  .ai-3d-extreme-fallback-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.viewer_background }};
  }

  .ai-3d-extreme-fallback-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    {% if block.settings.enable_image_spin %}
      animation: ai-extreme-spin-3d-{{ ai_gen_id }} {{ block.settings.spin_speed }}s linear infinite;
    {% endif %}
  }

  .ai-3d-extreme-fallback-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.viewer_background }};
    position: relative;
  }

  .ai-3d-extreme-fallback-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-3d-extreme-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    border-radius: 8px;
    font-size: 14px;
    text-align: center;
    pointer-events: none;
  }

  .ai-3d-extreme-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
    {% if block.settings.enable_content_shake %}
      animation: ai-extreme-shake-{{ ai_gen_id }} {{ block.settings.shake_speed }}s ease-in-out infinite;
    {% endif %}
  }

  .ai-3d-extreme-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 20px;
    line-height: 1.2;
    background: {{ block.settings.title_gradient }};
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    {% if block.settings.enable_title_neon %}
      animation: ai-extreme-neon-flicker-{{ ai_gen_id }} {{ block.settings.neon_speed }}s linear infinite;
      -webkit-text-fill-color: {{ block.settings.neon_color }};
    {% endif %}
    {% if block.settings.enable_title_glitch %}
      animation: ai-extreme-glitch-{{ ai_gen_id }} {{ block.settings.glitch_speed }}s ease-in-out infinite;
    {% endif %}
    {% if block.settings.enable_title_bounce %}
      animation: ai-extreme-bounce-{{ ai_gen_id }} {{ block.settings.bounce_speed }}s ease-in-out infinite;
    {% endif %}
  }

  .ai-3d-extreme-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin: 0 0 30px;
    opacity: 0.9;
  }

  .ai-3d-extreme-features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 40px;
  }

  .ai-3d-extreme-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-feature-{{ ai_gen_id }}:nth-child(1) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
    {% if block.settings.enable_feature_explode %}
      animation: ai-extreme-explode-{{ ai_gen_id }} 1s ease-out 0.2s;
    {% endif %}
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-feature-{{ ai_gen_id }}:nth-child(2) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.4s;
    {% if block.settings.enable_feature_explode %}
      animation: ai-extreme-explode-{{ ai_gen_id }} 1s ease-out 0.4s;
    {% endif %}
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-feature-{{ ai_gen_id }}:nth-child(3) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.6s;
    {% if block.settings.enable_feature_explode %}
      animation: ai-extreme-explode-{{ ai_gen_id }} 1s ease-out 0.6s;
    {% endif %}
  }

  .ai-3d-extreme-feature-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: {{ block.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 20px {{ block.settings.accent_color }};
    {% if block.settings.enable_icon_pulse %}
      animation: ai-extreme-pulse-{{ ai_gen_id }} {{ block.settings.icon_pulse_speed }}s ease-in-out infinite;
    {% endif %}
    {% if block.settings.enable_icon_rotate %}
      animation: ai-extreme-rotate-{{ ai_gen_id }} {{ block.settings.icon_rotate_speed }}s linear infinite;
    {% endif %}
  }

  .ai-3d-extreme-feature-icon-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
    stroke: {{ block.settings.background_color }};
  }

  .ai-3d-extreme-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    background: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 600;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 0 30px {{ block.settings.button_glow_color }};
    opacity: 0;
    transform: translateY(20px);
    {% if block.settings.enable_button_pulse %}
      animation: ai-extreme-pulse-{{ ai_gen_id }} {{ block.settings.button_pulse_speed }}s ease-in-out infinite;
    {% endif %}
    {% if block.settings.enable_button_glow %}
      animation: ai-extreme-glow-{{ ai_gen_id }} {{ block.settings.button_glow_speed }}s ease-in-out infinite;
    {% endif %}
    {% if block.settings.enable_button_shake %}
      animation: ai-extreme-shake-{{ ai_gen_id }} {{ block.settings.button_shake_speed }}s ease-in-out infinite;
    {% endif %}
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-cta-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease 0.8s, transform 0.8s ease 0.8s, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .ai-3d-extreme-cta-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.button_hover_scale }});
    box-shadow: 0 0 50px {{ block.settings.button_glow_color }};
  }

  .ai-3d-extreme-cta-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s ease, height 0.6s ease;
  }

  .ai-3d-extreme-cta-{{ ai_gen_id }}:active::before {
    width: 300px;
    height: 300px;
  }

  .ai-3d-extreme-secondary-images-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .ai-3d-extreme-secondary-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.6s ease, transform 0.6s ease;
    {% if block.settings.enable_secondary_zoom %}
      animation: ai-extreme-zoom-{{ ai_gen_id }} {{ block.settings.secondary_zoom_speed }}s ease-in-out infinite;
    {% endif %}
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-secondary-image-{{ ai_gen_id }}:nth-child(1) {
    opacity: 1;
    transform: scale(1);
    transition-delay: 1s;
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-secondary-image-{{ ai_gen_id }}:nth-child(2) {
    opacity: 1;
    transform: scale(1);
    transition-delay: 1.2s;
  }

  .ai-3d-extreme-content-{{ ai_gen_id }}.visible .ai-3d-extreme-secondary-image-{{ ai_gen_id }}:nth-child(3) {
    opacity: 1;
    transform: scale(1);
    transition-delay: 1.4s;
  }

  .ai-3d-extreme-secondary-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 989px) {
    .ai-3d-extreme-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 20px;
    }

    .ai-3d-extreme-viewer-{{ ai_gen_id }} {
      height: 400px;
    }

    .ai-3d-extreme-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-3d-extreme-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-3d-extreme-content-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateY(0);
    }

    .ai-3d-extreme-feature-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateX(0);
    }

    .ai-3d-extreme-cta-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateY(0);
      width: 100%;
    }

    .ai-3d-extreme-secondary-image-{{ ai_gen_id }} {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media screen and (min-width: 1600px) {
    .ai-3d-extreme-container-{{ ai_gen_id }} {
      max-width: 1600px;
      gap: 100px;
    }

    .ai-3d-extreme-viewer-{{ ai_gen_id }} {
      height: 700px;
    }
  }
{% endstyle %}

<ai-3d-extreme-showcase-{{ ai_gen_id }}
  class="ai-3d-extreme-{{ ai_gen_id }}"
  data-model-url="{{ block.settings.model_file }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-3d-extreme-container-{{ ai_gen_id }}">
    <div class="ai-3d-extreme-viewer-{{ ai_gen_id }}">
      {% if block.settings.enable_3d and block.settings.model_file != blank %}
        <canvas class="ai-3d-extreme-canvas-{{ ai_gen_id }}" id="ai-3d-extreme-canvas-{{ ai_gen_id }}"></canvas>
      {% elsif block.settings.fallback_image %}
        <div class="ai-3d-extreme-fallback-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.fallback_image | image_url: width: 1200 }}"
            alt="{{ block.settings.fallback_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.fallback_image.width }}"
            height="{{ block.settings.fallback_image.height }}"
          >
        </div>
      {% else %}
        <div class="ai-3d-extreme-fallback-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
          <div class="ai-3d-extreme-empty-state-{{ ai_gen_id }}">
            Add a 3D model or fallback image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-3d-extreme-content-{{ ai_gen_id }}" id="ai-3d-extreme-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-3d-extreme-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-3d-extreme-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank %}
        <ul class="ai-3d-extreme-features-{{ ai_gen_id }}">
          {% if block.settings.feature_1 != blank %}
            <li class="ai-3d-extreme-feature-{{ ai_gen_id }}">
              <div class="ai-3d-extreme-feature-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>{{ block.settings.feature_1 }}</span>
            </li>
          {% endif %}
          {% if block.settings.feature_2 != blank %}
            <li class="ai-3d-extreme-feature-{{ ai_gen_id }}">
              <div class="ai-3d-extreme-feature-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>{{ block.settings.feature_2 }}</span>
            </li>
          {% endif %}
          {% if block.settings.feature_3 != blank %}
            <li class="ai-3d-extreme-feature-{{ ai_gen_id }}">
              <div class="ai-3d-extreme-feature-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>{{ block.settings.feature_3 }}</span>
            </li>
          {% endif %}
        </ul>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-3d-extreme-cta-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}

      {% if block.settings.secondary_image_1 or block.settings.secondary_image_2 or block.settings.secondary_image_3 %}
        <div class="ai-3d-extreme-secondary-images-{{ ai_gen_id }}">
          {% if block.settings.secondary_image_1 %}
            <div class="ai-3d-extreme-secondary-image-{{ ai_gen_id }}">
              <img
                src="{{ block.settings.secondary_image_1 | image_url: width: 400 }}"
                alt="{{ block.settings.secondary_image_1.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            </div>
          {% endif %}
          {% if block.settings.secondary_image_2 %}
            <div class="ai-3d-extreme-secondary-image-{{ ai_gen_id }}">
              <img
                src="{{ block.settings.secondary_image_2 | image_url: width: 400 }}"
                alt="{{ block.settings.secondary_image_2.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            </div>
          {% endif %}
          {% if block.settings.secondary_image_3 %}
            <div class="ai-3d-extreme-secondary-image-{{ ai_gen_id }}">
              <img
                src="{{ block.settings.secondary_image_3 | image_url: width: 400 }}"
                alt="{{ block.settings.secondary_image_3.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</ai-3d-extreme-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class AI3DExtremeShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.modelUrl = this.dataset.modelUrl;
        this.canvas = this.querySelector('#ai-3d-extreme-canvas-{{ ai_gen_id }}');
        this.content = this.querySelector('#ai-3d-extreme-content-{{ ai_gen_id }}');
        this.scene = null;
        this.camera = null;
        this.renderer = null;
        this.model = null;
        this.isDragging = false;
        this.previousMousePosition = { x: 0, y: 0 };
        this.rotation = { x: 0, y: 0 };
        this.targetRotation = { x: 0, y: 0 };
        this.autoRotate = true;
        this.scrollAnimationTriggered = false;
      }

      connectedCallback() {
        this.setupScrollAnimation();
        
        if (this.canvas && this.modelUrl && {{ block.settings.enable_3d | json }}) {
          this.loadThreeJS();
        }
      }

      setupScrollAnimation() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !this.scrollAnimationTriggered) {
              this.content.classList.add('visible');
              this.scrollAnimationTriggered = true;
            }
          });
        }, { threshold: 0.2 });

        observer.observe(this.content);
      }

      async loadThreeJS() {
        if (window.THREE) {
          this.initThreeJS();
          return;
        }

        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';
        script.onload = () => {
          const loaderScript = document.createElement('script');
          loaderScript.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/examples/js/loaders/GLTFLoader.js';
          loaderScript.onload = () => this.initThreeJS();
          document.head.appendChild(loaderScript);
        };
        document.head.appendChild(script);
      }

      initThreeJS() {
        if (!window.THREE || !this.canvas) return;

        this.scene = new THREE.Scene();
        
        this.camera = new THREE.PerspectiveCamera(
          45,
          this.canvas.offsetWidth / this.canvas.offsetHeight,
          0.1,
          1000
        );
        this.camera.position.z = 5;

        this.renderer = new THREE.WebGLRenderer({
          canvas: this.canvas,
          antialias: true,
          alpha: true
        });
        this.renderer.setSize(this.canvas.offsetWidth, this.canvas.offsetHeight);
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        this.renderer.shadowMap.enabled = true;

        const ambientLight = new THREE.AmbientLight(0xffffff, {{ block.settings.ambient_light }});
        this.scene.add(ambientLight);

        const directionalLight = new THREE.DirectionalLight(0xffffff, {{ block.settings.directional_light }});
        directionalLight.position.set(5, 5, 5);
        directionalLight.castShadow = true;
        this.scene.add(directionalLight);

        const rimLight = new THREE.DirectionalLight(0x{{ block.settings.rim_light_color | remove: '#' }}, {{ block.settings.rim_light }});
        rimLight.position.set(-5, 0, -5);
        this.scene.add(rimLight);

        this.loadModel();
        this.setupEventListeners();
        this.animate();
      }

      loadModel() {
        const loader = new THREE.GLTFLoader();
        
        loader.load(
          this.modelUrl,
          (gltf) => {
            this.model = gltf.scene;
            
            const box = new THREE.Box3().setFromObject(this.model);
            const center = box.getCenter(new THREE.Vector3());
            const size = box.getSize(new THREE.Vector3());
            
            const maxDim = Math.max(size.x, size.y, size.z);
            const scale = 3 / maxDim;
            this.model.scale.multiplyScalar(scale);
            
            this.model.position.sub(center.multiplyScalar(scale));
            
            this.model.traverse((child) => {
              if (child.isMesh) {
                child.castShadow = true;
                child.receiveShadow = true;
              }
            });

            this.scene.add(this.model);
          },
          undefined,
          (error) => {
            console.error('Error loading 3D model:', error);
          }
        );
      }

      setupEventListeners() {
        this.canvas.addEventListener('mousedown', (e) => this.onMouseDown(e));
        this.canvas.addEventListener('mousemove', (e) => this.onMouseMove(e));
        this.canvas.addEventListener('mouseup', () => this.onMouseUp());
        this.canvas.addEventListener('mouseleave', () => this.onMouseUp());

        this.canvas.addEventListener('touchstart', (e) => this.onTouchStart(e));
        this.canvas.addEventListener('touchmove', (e) => this.onTouchMove(e));
        this.canvas.addEventListener('touchend', () => this.onTouchEnd());

        window.addEventListener('resize', () => this.onResize());
      }

      onMouseDown(e) {
        this.isDragging = true;
        this.autoRotate = false;
        this.previousMousePosition = { x: e.clientX, y: e.clientY };
      }

      onMouseMove(e) {
        if (!this.isDragging) return;

        const deltaX = e.clientX - this.previousMousePosition.x;
        const deltaY = e.clientY - this.previousMousePosition.y;

        this.targetRotation.y += deltaX * {{ block.settings.drag_sensitivity }};
        this.targetRotation.x += deltaY * {{ block.settings.drag_sensitivity }};

        this.previousMousePosition = { x: e.clientX, y: e.clientY };
      }

      onMouseUp() {
        this.isDragging = false;
      }

      onTouchStart(e) {
        if (e.touches.length === 1) {
          this.isDragging = true;
          this.autoRotate = false;
          this.previousMousePosition = {
            x: e.touches[0].clientX,
            y: e.touches[0].clientY
          };
        }
      }

      onTouchMove(e) {
        if (!this.isDragging || e.touches.length !== 1) return;

        const deltaX = e.touches[0].clientX - this.previousMousePosition.x;
        const deltaY = e.touches[0].clientY - this.previousMousePosition.y;

        this.targetRotation.y += deltaX * {{ block.settings.drag_sensitivity }};
        this.targetRotation.x += deltaY * {{ block.settings.drag_sensitivity }};

        this.previousMousePosition = {
          x: e.touches[0].clientX,
          y: e.touches[0].clientY
        };
      }

      onTouchEnd() {
        this.isDragging = false;
      }

      onResize() {
        if (!this.camera || !this.renderer) return;

        this.camera.aspect = this.canvas.offsetWidth / this.canvas.offsetHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(this.canvas.offsetWidth, this.canvas.offsetHeight);
      }

      animate() {
        requestAnimationFrame(() => this.animate());

        if (this.model) {
          if (this.autoRotate) {
            this.targetRotation.y += {{ block.settings.model_auto_rotate_speed }};
          }

          this.rotation.x += (this.targetRotation.x - this.rotation.x) * {{ block.settings.rotation_smoothness }};
          this.rotation.y += (this.targetRotation.y - this.rotation.y) * {{ block.settings.rotation_smoothness }};

          this.model.rotation.x = this.rotation.x;
          this.model.rotation.y = this.rotation.y;
        }

        if (this.renderer && this.scene && this.camera) {
          this.renderer.render(this.scene, this.camera);
        }
      }
    }

    customElements.define('ai-3d-extreme-showcase-{{ ai_gen_id }}', AI3DExtremeShowcase{{ ai_gen_id }});
  })();
</script>

